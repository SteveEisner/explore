# Copy to .env.local (gitignored) for local secrets and overrides. The server
# loads it at startup; variables already set in the real environment win over
# file values, and a missing .env.local is fine — everything below is
# optional, and the core app runs with none of it.

# Voice agent: ephemeral browser sessions against the OpenAI Realtime API.
# Without a key the rest of the app works normally; only voice is disabled.
#OPENAI_API_KEY=sk-...
#VOICE_MODEL=            # Realtime model override (see server/src/voice.ts)
#VOICE_VOICE=            # output voice name
#VOICE_FAST_MODEL=haiku  # Claude model for FAST voice delegation
#VOICE_SMART_MODEL=opus  # Claude model for SMART voice delegation

# Server port (default 3001). In dev, leave it alone: the Vite dev server's
# /ws, /docs, and /api proxies target :3001.
#PORT=3001

# Instance identity — every path is overridable so a second isolated instance
# can run alongside the main one (see scripts/side-instance.sh for a
# one-command version). Defaults: the repo's docs/, sandbox/, server/data,
# and /tmp/explore-events.jsonl.
#WIKI_DIR=
#SANDBOX_DIR=
#DATA_DIR=
#EVENTS_LOG=

# Claude session knobs (server/src/index.ts).
#CLAUDE_MODEL=claude-opus-4-8
#CLAUDE_EFFORT=
#APPEND_PROMPT_FILE=
#WARMUP=0                # 0 disables the pre-warm turn on first client connect
#WIKI_PRELOAD_BYTES=     # byte budget for wiki content preloaded into the prompt
