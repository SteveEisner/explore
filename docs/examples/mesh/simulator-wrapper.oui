root = Stack([styles, simulator], "simulator-wrapper")
styles = Content("<style>\n.stack.simulator-wrapper {\n  min-height: 720px;\n  height: 100%;\n  background: #070a11;\n}\n.stack.simulator-wrapper > [data-statement=\"simulator\"] {\n  min-height: 720px;\n  height: 100%;\n}\n.stack.simulator-wrapper .simulator-frame {\n  display: block;\n  width: 100%;\n  height: max(720px, calc(100vh - 96px));\n  border: 0;\n  background: #070a11;\n}\n</style>")
simulator = Content("<iframe class='simulator-frame' title='Mesh Simulator' sandbox='allow-scripts allow-same-origin allow-downloads' allow='clipboard-write' srcdoc='&lt;!doctype html&gt;\n&lt;html lang=\"en\"&gt;\n&lt;head&gt;\n  &lt;meta charset=\"utf-8\"&gt;\n  &lt;meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"&gt;\n  &lt;meta name=\"color-scheme\" content=\"dark\"&gt;\n  &lt;title&gt;Mesh Simulator&lt;/title&gt;\n  &lt;style&gt;\n    :root {\n      --ink: #f4f7ff;\n      --muted: #94a0b8;\n      --faint: #667189;\n      --panel: rgba(13, 18, 30, 0.92);\n      --panel-strong: #111827;\n      --line: rgba(151, 167, 200, 0.16);\n      --accent: #8ef0d0;\n      --accent-strong: #51dcb5;\n      --blue: #70b7ff;\n      --danger: #ff7f91;\n      --shadow: 0 18px 54px rgba(0, 0, 0, 0.32);\n    }\n\n    * { box-sizing: border-box; }\n\n    html, body {\n      width: 100%;\n      height: 100%;\n      margin: 0;\n      overflow: hidden;\n      background: #070a11;\n      color: var(--ink);\n      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif;\n    }\n\n    button, select, input { font: inherit; }\n\n    button:focus-visible,\n    select:focus-visible,\n    input:focus-visible,\n    canvas:focus-visible {\n      outline: 2px solid var(--accent);\n      outline-offset: 2px;\n    }\n\n    .app {\n      display: grid;\n      grid-template-rows: auto auto minmax(0, 1fr);\n      height: 100%;\n      background:\n        radial-gradient(circle at 25% -20%, rgba(65, 115, 165, 0.18), transparent 36rem),\n        #070a11;\n    }\n\n    .masthead {\n      min-height: 44px;\n      padding: 8px 12px;\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n      gap: 10px;\n      border-bottom: 1px solid var(--line);\n      background: rgba(8, 11, 19, 0.84);\n      backdrop-filter: blur(18px);\n    }\n\n    .brand { min-width: 0; }\n\n    .eyebrow {\n      color: var(--accent);\n      font-size: 10px;\n      font-weight: 800;\n      letter-spacing: 0.18em;\n      text-transform: uppercase;\n    }\n\n    h1 {\n      margin: 0;\n      font-size: clamp(16px, 1.6vw, 22px);\n      line-height: 1.1;\n      letter-spacing: -0.03em;\n    }\n\n    .toolbar {\n      display: grid;\n      grid-template-columns: repeat(12, minmax(0, 1fr));\n      align-items: stretch;\n      gap: 7px;\n      padding: 8px 12px;\n      border-bottom: 1px solid var(--line);\n      background: rgba(13, 18, 30, 0.9);\n    }\n\n    .tool-group {\n      min-width: 0;\n      display: grid;\n      align-content: start;\n      gap: 6px;\n      padding: 7px 9px 8px;\n      border: 1px solid rgba(151, 167, 200, 0.13);\n      border-radius: 9px;\n      background: rgba(8, 12, 21, 0.48);\n    }\n\n    .tool-group.devices { grid-column: span 4; }\n    .tool-group.radio-model { grid-column: span 3; }\n    .tool-group.radio-uncertainty { grid-column: span 3; }\n    .tool-group.timing { grid-column: span 2; }\n    .tool-group.resources { grid-column: span 3; }\n    .tool-group.wire-format { grid-column: span 4; }\n    .tool-group.view-options { grid-column: span 5; min-width: 0; }\n\n    .tool-group-title {\n      color: var(--faint);\n      font-size: 9px;\n      font-weight: 850;\n      letter-spacing: 0.13em;\n      line-height: 1;\n      text-transform: uppercase;\n    }\n\n    .tool-group-content {\n      min-width: 0;\n      display: flex;\n      align-items: center;\n      gap: 7px;\n    }\n\n    .tool-group-content.wrap { flex-wrap: wrap; flex-direction: row; row-gap: 6px; }\n    .view-options .tool-group-content { justify-content: space-between; width: 100%; }\n    .devices .tool-group-content {\n      display: grid;\n      align-items: stretch;\n      gap: 6px;\n    }\n\n    .device-actions,\n    .scenario-actions {\n      min-width: 0;\n      display: grid;\n      gap: 6px;\n    }\n\n    .device-actions {\n      grid-template-columns: 1.25fr 1.25fr 0.85fr 38px 0.8fr 0.8fr;\n    }\n\n    .scenario-actions {\n      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) auto;\n    }\n\n    .device-actions button,\n    .scenario-actions button,\n    .scenario-actions select {\n      min-width: 0;\n      width: 100%;\n      padding-inline: 8px;\n    }\n    .tool-group-content.control-grid {\n      display: grid;\n      grid-template-columns: repeat(3, minmax(0, 1fr));\n      align-items: end;\n      gap: 9px;\n    }\n\n    .control {\n      min-width: 0;\n      display: grid;\n      grid-template-columns: minmax(0, 1fr) auto;\n      align-items: end;\n      gap: 4px 7px;\n      flex: 1 1 120px;\n    }\n\n    .tool-label {\n      min-width: 0;\n      color: var(--muted);\n      font-size: 10px;\n      font-weight: 750;\n      letter-spacing: 0.08em;\n      text-transform: uppercase;\n    }\n\n    .control .tool-label { grid-column: 1; }\n    .control .tool-label + output {\n      grid-column: 2;\n      color: var(--ink);\n      font-size: 10px;\n      font-variant-numeric: tabular-nums;\n      white-space: nowrap;\n    }\n    .control &gt; input[type=\"range\"],\n    .control &gt; .range-with-preset { grid-column: 1 / -1; width: 100%; }\n    .control &gt; select { grid-column: 1 / -1; width: 100%; min-width: 0; }\n\n    .range-with-preset {\n      position: relative;\n      min-height: 33px;\n    }\n\n    .range-with-preset input[type=\"range\"] {\n      display: block;\n      width: 100%;\n      margin: 0;\n    }\n\n    .range-preset {\n      position: absolute;\n      left: var(--preset-position);\n      bottom: 0;\n      width: max-content;\n      height: auto;\n      padding: 0;\n      border: 0;\n      border-radius: 0;\n      background: none;\n      color: #d9c88f;\n      font-size: 8px;\n      font-weight: 750;\n      line-height: 1;\n      transform: translateX(-50%);\n    }\n\n    .range-preset::before {\n      content: \"\";\n      position: absolute;\n      left: 50%;\n      bottom: calc(100% + 2px);\n      height: 7px;\n      border-left: 1px solid #f6d365;\n    }\n\n    .range-preset:hover,\n    .range-preset:active {\n      border: 0;\n      background: none;\n      color: #f6d365;\n      transform: translateX(-50%);\n    }\n\n    button,\n    select {\n      height: 34px;\n      border: 1px solid rgba(155, 172, 205, 0.22);\n      border-radius: 8px;\n      background: #182133;\n      color: var(--ink);\n      cursor: pointer;\n    }\n\n    button {\n      padding: 0 12px;\n      font-size: 12px;\n      font-weight: 750;\n      transition: border-color 120ms ease, background 120ms ease, transform 120ms ease;\n    }\n\n    button:hover { border-color: rgba(142, 240, 208, 0.55); background: #202d43; }\n    button:active { transform: translateY(1px); }\n    button.primary { background: var(--accent); border-color: var(--accent); color: #07120f; }\n    button.primary:hover { background: #adf8df; }\n    button.icon-button { width: 38px; padding: 0; font-size: 15px; }\n\n    select {\n      min-width: 136px;\n      padding: 0 30px 0 10px;\n      font-size: 12px;\n    }\n\n    input[type=\"range\"] {\n      width: 100%;\n      min-width: 72px;\n      accent-color: var(--accent-strong);\n      cursor: pointer;\n    }\n\n    .check {\n      display: flex;\n      align-items: center;\n      gap: 6px;\n      color: var(--muted);\n      font-size: 11px;\n      white-space: nowrap;\n      cursor: pointer;\n    }\n\n    .check input { accent-color: var(--accent); }\n\n    .wire-format .tool-group-content.control-grid {\n      grid-template-columns: repeat(5, minmax(0, 1fr));\n    }\n\n    .wire-format select,\n    .devices select { min-width: 0; }\n\n    .workbench {\n      min-height: 0;\n      display: grid;\n      grid-template-columns: minmax(0, 1fr) 310px;\n    }\n\n    .space {\n      position: relative;\n      min-width: 0;\n      min-height: 0;\n      overflow: hidden;\n      background: #090d16;\n    }\n\n    #spaceCanvas {\n      display: block;\n      width: 100%;\n      height: 100%;\n      touch-action: none;\n      cursor: grab;\n    }\n\n    #spaceCanvas.dragging { cursor: grabbing; }\n\n    .space-hint {\n      position: absolute;\n      left: 16px;\n      bottom: 14px;\n      pointer-events: none;\n      display: flex;\n      flex-wrap: wrap;\n      gap: 15px;\n      padding: 7px 10px;\n      border: 1px solid var(--line);\n      border-radius: 8px;\n      background: rgba(8, 12, 20, 0.76);\n      color: var(--faint);\n      font-size: 10px;\n      backdrop-filter: blur(12px);\n    }\n\n    .space-hint b { color: var(--muted); font-weight: 750; }\n\n    .inspector {\n      min-height: 0;\n      overflow-y: auto;\n      padding: 18px;\n      border-left: 1px solid var(--line);\n      background: var(--panel);\n      scrollbar-width: thin;\n    }\n\n    .inspector-head {\n      display: flex;\n      align-items: flex-start;\n      justify-content: space-between;\n      gap: 12px;\n      margin-bottom: 17px;\n    }\n\n    .inspector-title {\n      margin: 0;\n      font: 800 24px/1 ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;\n      letter-spacing: -0.04em;\n    }\n\n    .role-badge {\n      padding: 5px 7px;\n      border: 1px solid rgba(142, 240, 208, 0.24);\n      border-radius: 999px;\n      background: rgba(142, 240, 208, 0.08);\n      color: var(--accent);\n      font-size: 9px;\n      font-weight: 850;\n      letter-spacing: 0.1em;\n      text-transform: uppercase;\n    }\n\n    .dna-card {\n      position: relative;\n      overflow: hidden;\n      margin-bottom: 18px;\n      padding: 14px;\n      border: 1px solid var(--line);\n      border-radius: 11px;\n      background: rgba(24, 33, 51, 0.68);\n    }\n\n    .dna-strip {\n      height: 7px;\n      margin: -14px -14px 12px;\n      background: var(--dna-gradient, linear-gradient(90deg, #fff, #777));\n    }\n\n    .dna-code {\n      color: var(--accent);\n      font: 800 11px/1.2 ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;\n      letter-spacing: 0.08em;\n      text-transform: uppercase;\n    }\n\n    .dna-name {\n      margin-top: 4px;\n      font-size: 17px;\n      font-weight: 760;\n      letter-spacing: -0.02em;\n    }\n\n    .section {\n      margin-top: 18px;\n      padding-top: 16px;\n      border-top: 1px solid var(--line);\n    }\n\n    [hidden] { display: none !important; }\n\n    .section:first-of-type { margin-top: 0; }\n\n    .section-title {\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n      margin: 0 0 10px;\n      color: var(--muted);\n      font-size: 10px;\n      font-weight: 850;\n      letter-spacing: 0.12em;\n      text-transform: uppercase;\n    }\n\n    .section-title em {\n      color: var(--faint);\n      font-size: 9px;\n      font-style: normal;\n      font-weight: 650;\n      letter-spacing: 0;\n      text-transform: none;\n    }\n\n    .facts { display: grid; gap: 8px; }\n\n    .fact {\n      display: flex;\n      align-items: baseline;\n      justify-content: space-between;\n      gap: 15px;\n      color: var(--muted);\n      font-size: 11px;\n    }\n\n    .fact strong {\n      color: var(--ink);\n      font: 700 11px/1.3 ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;\n      text-align: right;\n    }\n\n    .traffic-list {\n      display: grid;\n      gap: 7px;\n      margin: 0;\n      padding: 0;\n      list-style: none;\n    }\n\n    .traffic-item {\n      display: grid;\n      grid-template-columns: 39px 1fr;\n      gap: 8px;\n      color: var(--muted);\n      font-size: 10px;\n      line-height: 1.35;\n    }\n\n    .traffic-time {\n      color: var(--faint);\n      font-variant-numeric: tabular-nums;\n    }\n\n    .empty-state {\n      color: var(--faint);\n      font-size: 11px;\n      line-height: 1.5;\n    }\n\n    .outlier-item {\n      color: var(--danger);\n      font-size: 10px;\n      line-height: 1.45;\n    }\n\n    .note {\n      margin-top: 10px;\n      padding: 9px 10px;\n      border-radius: 8px;\n      background: rgba(112, 183, 255, 0.07);\n      color: #8291aa;\n      font-size: 10px;\n      line-height: 1.45;\n    }\n\n    .warning-note {\n      margin: 0 0 16px;\n      padding: 10px 11px;\n      border: 1px solid rgba(246, 211, 101, 0.32);\n      border-radius: 9px;\n      background: rgba(246, 211, 101, 0.08);\n      color: #d9c88f;\n      font-size: 10px;\n      line-height: 1.5;\n    }\n\n    .warning-note strong { color: #f6d365; }\n\n    .diagnostic-actions {\n      display: flex;\n      flex-wrap: wrap;\n      align-items: center;\n      gap: 8px;\n      margin-bottom: 9px;\n    }\n\n    .copy-status { color: var(--accent); font-size: 10px; }\n\n    .snapshot {\n      max-height: 230px;\n      overflow: auto;\n      margin: 0;\n      padding: 10px;\n      border: 1px solid var(--line);\n      border-radius: 8px;\n      background: rgba(4, 7, 12, 0.72);\n      color: #aab7cc;\n      font: 9px/1.45 ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;\n      white-space: pre-wrap;\n      word-break: break-word;\n      scrollbar-width: thin;\n    }\n\n    .quality-chart {\n      display: block;\n      width: 100%;\n      height: 112px;\n      border: 1px solid var(--line);\n      border-radius: 8px;\n      background: rgba(4, 7, 12, 0.72);\n    }\n\n    .evaluation-controls {\n      display: grid;\n      grid-template-columns: repeat(2, minmax(0, 1fr));\n      gap: 10px;\n      margin-bottom: 10px;\n    }\n\n    .evaluation-facts,\n    .evaluation-outliers { margin-top: 10px; }\n\n    .schedule-progress {\n      display: grid;\n      gap: 10px;\n      margin-top: 13px;\n    }\n\n    .progress-row { display: grid; gap: 5px; }\n\n    .progress-heading {\n      display: flex;\n      justify-content: space-between;\n      gap: 10px;\n      color: var(--muted);\n      font-size: 9px;\n      font-weight: 750;\n      letter-spacing: 0.06em;\n      text-transform: uppercase;\n    }\n\n    .progress-heading output {\n      color: var(--ink);\n      font-variant-numeric: tabular-nums;\n      letter-spacing: 0;\n      text-transform: none;\n    }\n\n    .progress-track {\n      position: relative;\n      height: 9px;\n      overflow: hidden;\n      border: 1px solid rgba(155, 172, 205, 0.18);\n      border-radius: 999px;\n      background:\n        repeating-linear-gradient(90deg, transparent 0, transparent calc(10% - 1px), rgba(176, 190, 217, 0.12) calc(10% - 1px), rgba(176, 190, 217, 0.12) 10%),\n        rgba(4, 7, 12, 0.72);\n    }\n\n    .progress-fill {\n      width: 100%;\n      height: 100%;\n      border-radius: inherit;\n      background: var(--progress-color, var(--accent));\n      box-shadow: 0 0 12px color-mix(in srgb, var(--progress-color, var(--accent)) 45%, transparent);\n      transition: width 100ms linear;\n    }\n\n    .legend {\n      display: flex;\n      flex-wrap: wrap;\n      gap: 10px 14px;\n      margin-top: 2px;\n    }\n\n    .legend-item {\n      display: flex;\n      align-items: center;\n      gap: 6px;\n      color: var(--muted);\n      font-size: 10px;\n    }\n\n    .legend-mark {\n      width: 16px;\n      height: 2px;\n      border-radius: 9px;\n      background: var(--mark);\n    }\n\n    @media (max-width: 860px) {\n      html, body { overflow: auto; }\n      .app { height: auto; min-height: 100%; grid-template-rows: auto auto auto; }\n      .masthead { align-items: flex-start; }\n      .tool-group.devices,\n      .tool-group.radio-model,\n      .tool-group.view-options,\n      .tool-group.metrics { grid-column: span 6; }\n      .tool-group.radio-uncertainty,\n      .tool-group.timing,\n      .tool-group.resources,\n      .tool-group.wire-format,\n      .tool-group.metrics { grid-column: span 12; }\n      .workbench { grid-template-columns: 1fr; grid-template-rows: 65vh auto; }\n      .inspector { border-left: 0; border-top: 1px solid var(--line); }\n      .space-hint { display: none; }\n    }\n\n    @media (min-width: 861px) and (max-width: 1300px) {\n      .tool-group.devices,\n      .tool-group.radio-model,\n      .tool-group.view-options { grid-column: span 4; }\n      .tool-group.radio-uncertainty,\n      .tool-group.timing { grid-column: span 6; }\n      .tool-group.metrics,\n      .tool-group.resources,\n      .tool-group.wire-format { grid-column: span 12; }\n    }\n\n    @media (max-width: 600px) {\n      .tool-group.devices,\n      .tool-group.radio-model,\n      .tool-group.radio-uncertainty,\n      .tool-group.timing,\n      .tool-group.view-options,\n      .tool-group.metrics,\n      .tool-group.resources,\n      .tool-group.wire-format { grid-column: span 12; }\n      .tool-group-content.control-grid { grid-template-columns: 1fr; }\n      .wire-format .tool-group-content.control-grid { grid-template-columns: 1fr; }\n    }\n  &lt;/style&gt;\n&lt;/head&gt;\n&lt;body&gt;\n  &lt;div class=\"app\"&gt;\n    &lt;header class=\"masthead\"&gt;\n      &lt;div class=\"brand\"&gt;\n      &lt;/div&gt;\n    &lt;/header&gt;\n\n    &lt;nav class=\"toolbar\" aria-label=\"Simulation controls\"&gt;\n      &lt;div class=\"tool-group devices\"&gt;\n        &lt;div class=\"tool-group-title\"&gt;Devices &amp;amp; scenario&lt;/div&gt;\n        &lt;div class=\"tool-group-content\"&gt;\n          &lt;div class=\"device-actions\"&gt;\n            &lt;button class=\"primary\" id=\"addDevice\" title=\"Add one tube near the center without restarting the current run.\"&gt;+ Add tube&lt;/button&gt;\n            &lt;button id=\"addAnchor\" title=\"Add one fixed, no-light anchor near the center without restarting the current run.\"&gt;+ Add anchor&lt;/button&gt;\n            &lt;button id=\"addEight\" title=\"Add eight tubes around the center without restarting the current run.\"&gt;+ Add 8&lt;/button&gt;\n            &lt;button class=\"icon-button\" id=\"pauseToggle\" aria-label=\"Pause simulation\" title=\"Pause simulation\"&gt;Ⅱ&lt;/button&gt;\n            &lt;button id=\"resetSimulation\" title=\"Reset the current tube and anchor scenario to its deterministic starting layout.\"&gt;Reset&lt;/button&gt;\n            &lt;button id=\"clearSimulation\" title=\"Remove every tube and anchor and clear the current run history, leaving an empty field.\"&gt;Clear&lt;/button&gt;\n          &lt;/div&gt;\n          &lt;div class=\"scenario-actions\"&gt;\n            &lt;select id=\"scenarioDeviceCount\" aria-label=\"Number of tubes in field\" title=\"Choose how many light-bearing tubes the next scenario run will create.\"&gt;\n              &lt;option value=\"1\"&gt;1 tube&lt;/option&gt;\n              &lt;option value=\"2\" selected&gt;2 tubes&lt;/option&gt;\n              &lt;option value=\"3\"&gt;3 tubes&lt;/option&gt;\n              &lt;option value=\"4\"&gt;4 tubes&lt;/option&gt;\n              &lt;option value=\"8\"&gt;8 tubes&lt;/option&gt;\n              &lt;option value=\"16\"&gt;16 tubes&lt;/option&gt;\n              &lt;option value=\"32\"&gt;32 tubes&lt;/option&gt;\n              &lt;option value=\"64\"&gt;64 tubes&lt;/option&gt;\n            &lt;/select&gt;\n            &lt;select id=\"scenarioAnchorCount\" aria-label=\"Number of fixed anchors in field\" title=\"Choose how many fixed-position anchors the next run will add. Zero provides the unanchored baseline.\"&gt;\n              &lt;option value=\"0\" selected&gt;0 anchors&lt;/option&gt;\n              &lt;option value=\"1\"&gt;1 anchor&lt;/option&gt;\n              &lt;option value=\"2\"&gt;2 anchors&lt;/option&gt;\n              &lt;option value=\"3\"&gt;3 anchors&lt;/option&gt;\n              &lt;option value=\"4\"&gt;4 anchors&lt;/option&gt;\n              &lt;option value=\"5\"&gt;5 anchors&lt;/option&gt;\n            &lt;/select&gt;\n            &lt;button class=\"primary\" id=\"runScenario\" title=\"Clear the current run and start the selected deterministic tube and anchor configuration.\"&gt;Run scenario&lt;/button&gt;\n          &lt;/div&gt;\n        &lt;/div&gt;\n      &lt;/div&gt;\n\n      &lt;div class=\"tool-group radio-model\"&gt;\n        &lt;div class=\"tool-group-title\"&gt;Radio model&lt;/div&gt;\n        &lt;div class=\"tool-group-content\"&gt;\n          &lt;div class=\"control\" title=\"Maximum physical distance at which a packet can be received. Signal strength falls toward zero before this edge.\"&gt;\n            &lt;label class=\"tool-label\" for=\"rangeControl\"&gt;Range&lt;/label&gt;\n            &lt;output id=\"rangeOutput\"&gt;600 px&lt;/output&gt;\n            &lt;input id=\"rangeControl\" type=\"range\" min=\"80\" max=\"2000\" step=\"20\" value=\"600\" title=\"Set the radio&#39;s hard maximum range in simulation pixels.\"&gt;\n          &lt;/div&gt;\n          &lt;div class=\"control\" title=\"Formula used to reduce signal power as physical distance increases.\"&gt;\n            &lt;label class=\"tool-label\" for=\"dropoffControl\"&gt;Dropoff&lt;/label&gt;\n            &lt;select id=\"dropoffControl\" title=\"Choose how quickly radio power decays with distance.\"&gt;\n              &lt;option value=\"linear\" title=\"Signal decreases at a constant rate from 1.0 at the transmitter to zero at the range boundary.\"&gt;Linear&lt;/option&gt;\n              &lt;option value=\"quadratic\" title=\"Signal falls faster than linear as distance increases.\"&gt;Squared&lt;/option&gt;\n              &lt;option value=\"smooth\" title=\"An S-shaped falloff with gentle slopes near the transmitter and boundary.\"&gt;Smoothstep&lt;/option&gt;\n              &lt;option value=\"inverseSquare\" title=\"A normalized inverse-square-like power curve that still reaches zero at the configured boundary.\"&gt;Inverse square&lt;/option&gt;\n            &lt;/select&gt;\n          &lt;/div&gt;\n          &lt;div class=\"control\" title=\"Maps received signal strength to the chance that a complete packet arrives. This is separate from the RSSI used for range estimation.\"&gt;\n            &lt;label class=\"tool-label\" for=\"deliveryModelControl\"&gt;Packet delivery&lt;/label&gt;\n            &lt;select id=\"deliveryModelControl\" title=\"Hard range makes the configured boundary binary. Receiver threshold adds a narrow lossy edge. Proportional preserves the older signal-equals-probability model.\"&gt;\n              &lt;option value=\"hard\" selected title=\"Every packet inside range arrives; every packet outside range does not.\"&gt;Hard range&lt;/option&gt;\n              &lt;option value=\"threshold\" title=\"Packets are reliable through most of the range and become lossy only near the weak-signal edge.\"&gt;Lossy edge&lt;/option&gt;\n              &lt;option value=\"proportional\" title=\"Legacy model: normalized signal strength is used directly as packet delivery probability.\"&gt;Proportional loss&lt;/option&gt;\n            &lt;/select&gt;\n          &lt;/div&gt;\n        &lt;/div&gt;\n      &lt;/div&gt;\n\n      &lt;div class=\"tool-group radio-uncertainty\" aria-label=\"Radio uncertainty\"&gt;\n        &lt;div class=\"tool-group-title\"&gt;Radio uncertainty&lt;/div&gt;\n        &lt;div class=\"tool-group-content control-grid\"&gt;\n          &lt;div class=\"control\" title=\"Random packet-to-packet RSSI measurement noise. Higher values make successive range estimates fluctuate.\"&gt;\n            &lt;label class=\"tool-label\" for=\"rssiJitterControl\"&gt;RSSI noise σ&lt;/label&gt;\n            &lt;output id=\"rssiJitterOutput\"&gt;0 dB&lt;/output&gt;\n            &lt;div class=\"range-with-preset\" style=\"--preset-position:25%\"&gt;\n              &lt;input id=\"rssiJitterControl\" type=\"range\" min=\"0\" max=\"8\" step=\"0.25\" value=\"0\" title=\"Gaussian packet-to-packet RSSI noise, expressed as one standard deviation in dB\"&gt;\n              &lt;button class=\"range-preset\" id=\"rssiJitterPreset\" type=\"button\" data-value=\"2\" aria-label=\"Set normal indoor RSSI noise to 2 dB sigma\" title=\"Set normal indoor RSSI noise: 2 dB σ\"&gt;normal 2&lt;/button&gt;\n            &lt;/div&gt;\n          &lt;/div&gt;\n          &lt;div class=\"control\" title=\"Stable transmit-power difference assigned to each device. Balanced and full payloads can advertise calibration to compensate for it.\"&gt;\n            &lt;label class=\"tool-label\" for=\"txSpreadControl\"&gt;TX bias σ&lt;/label&gt;\n            &lt;output id=\"txSpreadOutput\"&gt;0 dB&lt;/output&gt;\n            &lt;div class=\"range-with-preset\" style=\"--preset-position:25%\"&gt;\n              &lt;input id=\"txSpreadControl\" type=\"range\" min=\"0\" max=\"3\" step=\"0.25\" value=\"0\" title=\"Stable Gaussian transmit-power bias assigned to each device, expressed as one standard deviation in dB\"&gt;\n              &lt;button class=\"range-preset\" id=\"txSpreadPreset\" type=\"button\" data-value=\"0.75\" aria-label=\"Set normal ESP32 TX bias to 0.75 dB sigma\" title=\"Set normal ESP32 TX bias: 0.75 dB σ\"&gt;normal 0.75&lt;/button&gt;\n            &lt;/div&gt;\n          &lt;/div&gt;\n          &lt;div class=\"control\" title=\"Stable obstacle and antenna-orientation bias assigned separately to each radio link.\"&gt;\n            &lt;label class=\"tool-label\" for=\"linkBiasControl\"&gt;Link shadow σ&lt;/label&gt;\n            &lt;output id=\"linkBiasOutput\"&gt;0 dB&lt;/output&gt;\n            &lt;div class=\"range-with-preset\" style=\"--preset-position:35%\"&gt;\n              &lt;input id=\"linkBiasControl\" type=\"range\" min=\"0\" max=\"10\" step=\"0.25\" value=\"0\" title=\"Stable Gaussian obstacle and orientation bias assigned to each device pair, expressed as one standard deviation in dB\"&gt;\n              &lt;button class=\"range-preset\" id=\"linkBiasPreset\" type=\"button\" data-value=\"3.5\" aria-label=\"Set normal indoor link shadowing to 3.5 dB sigma\" title=\"Set normal indoor link shadowing: 3.5 dB σ\"&gt;normal 3.5&lt;/button&gt;\n            &lt;/div&gt;\n          &lt;/div&gt;\n        &lt;/div&gt;\n      &lt;/div&gt;\n\n      &lt;div class=\"tool-group timing\"&gt;\n        &lt;div class=\"tool-group-title\"&gt;Timing&lt;/div&gt;\n        &lt;div class=\"tool-group-content\"&gt;\n          &lt;div class=\"control\" title=\"Multiplier applied to simulated time. It changes how quickly the experiment runs, not protocol constants.\"&gt;\n            &lt;label class=\"tool-label\" for=\"speedControl\"&gt;Simulation&lt;/label&gt;\n            &lt;output id=\"speedOutput\"&gt;0.5×&lt;/output&gt;\n            &lt;input id=\"speedControl\" type=\"range\" min=\"0.1\" max=\"4\" step=\"0.1\" value=\"0.5\" title=\"Set simulated-time speed from 0.1× to 4×.\"&gt;\n          &lt;/div&gt;\n          &lt;div class=\"control\" title=\"Lighting beat tempo originated by leading tubes. Position broadcasts use their own independent interval.\"&gt;\n            &lt;label class=\"tool-label\" for=\"bpmControl\"&gt;Leader tempo&lt;/label&gt;\n            &lt;output id=\"bpmOutput\"&gt;120 BPM&lt;/output&gt;\n            &lt;input id=\"bpmControl\" type=\"range\" min=\"60\" max=\"180\" step=\"1\" value=\"120\" title=\"Set the lighting tempo sent by leading tubes.\"&gt;\n          &lt;/div&gt;\n          &lt;button id=\"forceNext\" title=\"Move each leading tube&#39;s nearest scheduled change to the current phrase\"&gt;Force next&lt;/button&gt;\n        &lt;/div&gt;\n      &lt;/div&gt;\n\n      &lt;div class=\"tool-group view-options\"&gt;\n        &lt;div class=\"tool-group-content wrap\"&gt;\n          &lt;label class=\"check\" title=\"Show arrows from each following device to the immediate device it selected as uplink.\"&gt;&lt;input id=\"showTopology\" type=\"checkbox\" checked title=\"Toggle uplink arrows.\"&gt; Uplinks&lt;/label&gt;\n          &lt;label class=\"check\" title=\"Show the selected device&#39;s maximum range and link strengths.\"&gt;&lt;input id=\"showRadio\" type=\"checkbox\" checked title=\"Toggle radio range and link visualization.\"&gt; Radio field&lt;/label&gt;\n          &lt;label class=\"check\" title=\"Show an illustrative circle expanding from every transmission. Packet delivery remains immediate.\"&gt;&lt;input id=\"showSignalWaves\" type=\"checkbox\" checked title=\"Toggle expanding transmission circles.\"&gt; Signal waves&lt;/label&gt;\n          &lt;label class=\"check\" title=\"Show device-estimated positions, ambiguity circles, mirror candidates, and estimator labels.\"&gt;&lt;input id=\"showEstimates\" type=\"checkbox\" checked title=\"Toggle estimated-position visualization.\"&gt; Estimates&lt;/label&gt;\n          &lt;label class=\"check\" title=\"Relayed lighting preserves the logical leader. Each device advertises Leader via: the physical source of its latest accepted leader state. That observation renews only the relays still carrying traffic downstream. Unchecked follows the current firmware&#39;s header-replacement behavior.\"&gt;&lt;input id=\"fixedRelay\" type=\"checkbox\" title=\"Toggle logical-leader propagation with locally renewed relay leases.\"&gt; Fixed RELAY&lt;/label&gt;\n        &lt;/div&gt;\n      &lt;/div&gt;\n\n      &lt;div class=\"tool-group resources\"&gt;\n        &lt;div class=\"tool-group-content control-grid\"&gt;\n          &lt;div class=\"control\" title=\"Hard maximum number of immediate neighbors whose position and RSSI state one device may retain. This bounds per-device RAM usage.\"&gt;\n            &lt;label class=\"tool-label\" for=\"peerCapacityControl\"&gt;Peer slots&lt;/label&gt;\n            &lt;output id=\"peerCapacityOutput\"&gt;4&lt;/output&gt;\n            &lt;input id=\"peerCapacityControl\" type=\"range\" min=\"3\" max=\"24\" step=\"1\" value=\"4\" title=\"Set the fixed peer-table capacity per device. Four means each device retains at most four immediate-neighbor position records; extra neighbors are rejected or replace a less useful entry.\"&gt;\n          &lt;/div&gt;\n          &lt;div class=\"control\" title=\"Maximum number of the best retained peers used in one multilateration update. A device can remember more peers than it solves with.\"&gt;\n            &lt;label class=\"tool-label\" for=\"solveCapacityControl\"&gt;Solve with&lt;/label&gt;\n            &lt;output id=\"solveCapacityOutput\"&gt;4&lt;/output&gt;\n            &lt;input id=\"solveCapacityControl\" type=\"range\" min=\"3\" max=\"12\" step=\"1\" value=\"4\" title=\"Limit the fresh peer constraints used by each solver pass. This cannot exceed Peer slots; four lets every retained peer participate.\"&gt;\n          &lt;/div&gt;\n          &lt;div class=\"control\" title=\"Number of fresh anchor entries protected from eviction when the bounded peer table is full. It reserves slots, not anchors in the whole field.\"&gt;\n            &lt;label class=\"tool-label\" for=\"anchorReserveControl\"&gt;Anchor reserve&lt;/label&gt;\n            &lt;output id=\"anchorReserveOutput\"&gt;2&lt;/output&gt;\n            &lt;input id=\"anchorReserveControl\" type=\"range\" min=\"0\" max=\"4\" step=\"1\" value=\"2\" title=\"Protect this many direct anchors in each device&#39;s local peer table.\"&gt;\n          &lt;/div&gt;\n        &lt;/div&gt;\n      &lt;/div&gt;\n\n      &lt;div class=\"tool-group wire-format\"&gt;\n        &lt;div class=\"tool-group-content control-grid\"&gt;\n          &lt;div class=\"control\" title=\"Select which optional quality, residual, calibration, and lifecycle fields are carried in the positioning payload.\"&gt;\n            &lt;label class=\"tool-label\" for=\"payloadProfileControl\"&gt;Fields&lt;/label&gt;\n            &lt;select id=\"payloadProfileControl\" title=\"Tiny minimizes bytes; Balanced adds useful quality and TX calibration; Full models the complete proposed payload.\"&gt;\n              &lt;option value=\"tiny\" title=\"Coordinates and essential frame metadata only; smallest packet and peer record.\"&gt;Tiny&lt;/option&gt;\n              &lt;option value=\"balanced\" selected title=\"Adds useful confidence and transmitter-calibration fields while keeping payload size moderate.\"&gt;Balanced&lt;/option&gt;\n              &lt;option value=\"full\" title=\"Carries the complete proposed quality, calibration, residual, and lifecycle metadata.\"&gt;Full&lt;/option&gt;\n            &lt;/select&gt;\n          &lt;/div&gt;\n          &lt;div class=\"control\" title=\"Bit width used to encode the advertised X and Y coordinates. Smaller encodings reduce bytes but reduce representable range.\"&gt;\n            &lt;label class=\"tool-label\" for=\"coordinateEncodingControl\"&gt;Coordinates&lt;/label&gt;\n            &lt;select id=\"coordinateEncodingControl\" title=\"Choose packed coordinate width for both X and Y.\"&gt;\n              &lt;option value=\"int8\" title=\"One signed byte per axis; smallest range before coordinate saturation.\"&gt;2 × int8&lt;/option&gt;\n              &lt;option value=\"int12\" selected title=\"Twelve signed bits per axis; a middle ground between range and wire size.\"&gt;2 × int12&lt;/option&gt;\n              &lt;option value=\"int16\" title=\"Two signed bytes per axis; largest coordinate range and payload.\"&gt;2 × int16&lt;/option&gt;\n            &lt;/select&gt;\n          &lt;/div&gt;\n          &lt;div class=\"control\" title=\"Coordinate quantization step. Larger values send less precise positions and increase quantization error.\"&gt;\n            &lt;label class=\"tool-label\" for=\"coordinateQuantumControl\"&gt;Resolution&lt;/label&gt;\n            &lt;select id=\"coordinateQuantumControl\" title=\"Round every advertised coordinate to this many simulation pixels.\"&gt;\n              &lt;option value=\"1\" title=\"Round coordinates to single pixels: highest precision and smallest representable physical range for a given bit width.\"&gt;1 px&lt;/option&gt;\n              &lt;option value=\"5\" selected title=\"Round coordinates to five-pixel increments: moderate precision with five times the coordinate range.\"&gt;5 px&lt;/option&gt;\n              &lt;option value=\"10\" title=\"Round coordinates to ten-pixel increments, trading visible precision for greater range.\"&gt;10 px&lt;/option&gt;\n              &lt;option value=\"25\" title=\"Coarse twenty-five-pixel coordinates for experiments prioritizing representable area.\"&gt;25 px&lt;/option&gt;\n              &lt;option value=\"50\" title=\"Very coarse fifty-pixel coordinates with the largest representable area.\"&gt;50 px&lt;/option&gt;\n            &lt;/select&gt;\n          &lt;/div&gt;\n          &lt;div class=\"control\" title=\"Current fixed uses the existing 84-byte NodeMessage. Compact models a dedicated variable-length position packet.\"&gt;\n            &lt;label class=\"tool-label\" for=\"wireEnvelopeControl\"&gt;Envelope&lt;/label&gt;\n            &lt;select id=\"wireEnvelopeControl\" title=\"Choose fixed existing transport size or experimental compact position envelope.\"&gt;\n              &lt;option value=\"fixed\" title=\"Use the existing fixed-size NodeMessage transport cost, including unused payload capacity.\"&gt;Current fixed&lt;/option&gt;\n              &lt;option value=\"compact\" selected title=\"Model a dedicated variable-size positioning envelope with only the selected fields.\"&gt;Compact&lt;/option&gt;\n            &lt;/select&gt;\n          &lt;/div&gt;\n          &lt;div class=\"control\" title=\"Nominal interval between each device&#39;s positioning broadcasts, with a small randomized phase jitter.\"&gt;\n            &lt;label class=\"tool-label\" for=\"positionPeriodControl\"&gt;Position ping&lt;/label&gt;\n            &lt;output id=\"positionPeriodOutput\"&gt;1.0 s&lt;/output&gt;\n            &lt;input id=\"positionPeriodControl\" type=\"range\" min=\"0.25\" max=\"5\" step=\"0.25\" value=\"1\" title=\"Set positioning broadcast interval from 0.25 to 5 simulated seconds.\"&gt;\n          &lt;/div&gt;\n        &lt;/div&gt;\n      &lt;/div&gt;\n\n    &lt;/nav&gt;\n\n    &lt;main class=\"workbench\"&gt;\n      &lt;section class=\"space\" id=\"space\" aria-label=\"Simulation space\"&gt;\n        &lt;canvas id=\"spaceCanvas\" tabindex=\"0\" aria-describedby=\"canvasHelp\"&gt;&lt;/canvas&gt;\n        &lt;div class=\"space-hint\" id=\"canvasHelp\"&gt;\n          &lt;span&gt;&lt;b&gt;Drag&lt;/b&gt; a device to move it&lt;/span&gt;\n          &lt;span&gt;&lt;b&gt;Drag empty space&lt;/b&gt; to pan&lt;/span&gt;\n          &lt;span&gt;&lt;b&gt;Wheel&lt;/b&gt; to zoom&lt;/span&gt;\n          &lt;span&gt;&lt;b&gt;Click&lt;/b&gt; a device to inspect it&lt;/span&gt;\n          &lt;span&gt;&lt;b&gt;Delete / Backspace&lt;/b&gt; removes the selected device&lt;/span&gt;\n          &lt;span&gt;&lt;b&gt;Double-click&lt;/b&gt; empty space to add a tube&lt;/span&gt;\n        &lt;/div&gt;\n      &lt;/section&gt;\n\n      &lt;aside class=\"inspector\" aria-live=\"polite\"&gt;\n        &lt;div class=\"inspector-head\"&gt;\n          &lt;div&gt;\n            &lt;div class=\"eyebrow\" id=\"selectedKind\"&gt;Selected tube&lt;/div&gt;\n            &lt;h2 class=\"inspector-title\" id=\"selectedId\"&gt;---&lt;/h2&gt;\n          &lt;/div&gt;\n          &lt;div class=\"role-badge\" id=\"selectedRole\"&gt;Leading&lt;/div&gt;\n        &lt;/div&gt;\n\n        &lt;div class=\"dna-card\" id=\"dnaCard\"&gt;\n          &lt;div class=\"dna-strip\" id=\"dnaStrip\"&gt;&lt;/div&gt;\n          &lt;div class=\"section-title\"&gt;What to do now&lt;/div&gt;\n          &lt;div class=\"dna-code\" id=\"dnaCode\"&gt;P0 · C0&lt;/div&gt;\n          &lt;div class=\"dna-name\" id=\"dnaName\"&gt;Wave · Aurora&lt;/div&gt;\n        &lt;/div&gt;\n\n        &lt;div class=\"warning-note\" id=\"topologyWarning\" hidden&gt;&lt;/div&gt;\n\n        &lt;section class=\"section\"&gt;\n          &lt;h3 class=\"section-title\"&gt;Device-local knowledge &lt;em&gt;protocol-visible only&lt;/em&gt;&lt;/h3&gt;\n          &lt;div class=\"facts\"&gt;\n            &lt;div class=\"fact\"&gt;&lt;span&gt;Own identifier&lt;/span&gt;&lt;strong id=\"factId\"&gt;---&lt;/strong&gt;&lt;/div&gt;\n            &lt;div class=\"fact\"&gt;&lt;span id=\"leaderFactLabel\"&gt;Chosen uplink&lt;/span&gt;&lt;strong id=\"factUplink\"&gt;none&lt;/strong&gt;&lt;/div&gt;\n            &lt;div class=\"fact\"&gt;&lt;span&gt;Leader path&lt;/span&gt;&lt;strong id=\"factLeaderPath\"&gt;self&lt;/strong&gt;&lt;/div&gt;\n            &lt;div class=\"fact\"&gt;&lt;span&gt;Network state&lt;/span&gt;&lt;strong id=\"factState\"&gt;receiving&lt;/strong&gt;&lt;/div&gt;\n            &lt;div class=\"fact\"&gt;&lt;span&gt;Relay duty&lt;/span&gt;&lt;strong id=\"factRelay\"&gt;inactive&lt;/strong&gt;&lt;/div&gt;\n            &lt;div class=\"fact\"&gt;&lt;span&gt;Leader state last heard&lt;/span&gt;&lt;strong id=\"factLastHeard\"&gt;never&lt;/strong&gt;&lt;/div&gt;\n            &lt;div class=\"fact\"&gt;&lt;span&gt;Estimated position&lt;/span&gt;&lt;strong id=\"factEstimate\"&gt;0, 0&lt;/strong&gt;&lt;/div&gt;\n            &lt;div class=\"fact\"&gt;&lt;span&gt;Position frame&lt;/span&gt;&lt;strong id=\"factEstimateFrame\"&gt;self&lt;/strong&gt;&lt;/div&gt;\n            &lt;div class=\"fact\"&gt;&lt;span&gt;Position solver&lt;/span&gt;&lt;strong id=\"factPositionMode\"&gt;waiting for peer&lt;/strong&gt;&lt;/div&gt;\n            &lt;div class=\"fact\"&gt;&lt;span&gt;Position peer table&lt;/span&gt;&lt;strong id=\"factPeerTable\"&gt;0 / 12&lt;/strong&gt;&lt;/div&gt;\n            &lt;div class=\"fact\"&gt;&lt;span&gt;Beat / phrase&lt;/span&gt;&lt;strong id=\"factClock\"&gt;0.00 / 0&lt;/strong&gt;&lt;/div&gt;\n            &lt;div class=\"fact\"&gt;&lt;span&gt;Protocol version&lt;/span&gt;&lt;strong&gt;2&lt;/strong&gt;&lt;/div&gt;\n          &lt;/div&gt;\n          &lt;div class=\"note\" id=\"relayExplanation\"&gt;With relay duty active, current-code mode rebroadcasts an accepted uplink packet after replacing its header with the relay’s own ID and uplink ID.&lt;/div&gt;\n        &lt;/section&gt;\n\n        &lt;section class=\"section\" id=\"lightingScheduleSection\"&gt;\n          &lt;h3 class=\"section-title\"&gt;What to do next &lt;em&gt;last known schedule&lt;/em&gt;&lt;/h3&gt;\n          &lt;div class=\"facts\"&gt;\n            &lt;div class=\"fact\"&gt;&lt;span&gt;Pattern change&lt;/span&gt;&lt;strong id=\"factNextPattern\"&gt;---&lt;/strong&gt;&lt;/div&gt;\n            &lt;div class=\"fact\"&gt;&lt;span&gt;Palette change&lt;/span&gt;&lt;strong id=\"factNextPalette\"&gt;---&lt;/strong&gt;&lt;/div&gt;\n            &lt;div class=\"fact\"&gt;&lt;span&gt;Tempo&lt;/span&gt;&lt;strong id=\"factBpm\"&gt;120 BPM&lt;/strong&gt;&lt;/div&gt;\n          &lt;/div&gt;\n          &lt;div class=\"schedule-progress\"&gt;\n            &lt;div class=\"progress-row\"&gt;\n              &lt;div class=\"progress-heading\"&gt;&lt;span id=\"patternProgressLabel\"&gt;Pattern&lt;/span&gt;&lt;output id=\"patternProgressValue\"&gt;100%&lt;/output&gt;&lt;/div&gt;\n              &lt;div class=\"progress-track\" role=\"progressbar\" aria-label=\"Time remaining until pattern change\" aria-valuemin=\"0\" aria-valuemax=\"100\" aria-valuenow=\"100\" id=\"patternProgressTrack\"&gt;\n                &lt;div class=\"progress-fill\" id=\"patternProgressFill\" style=\"--progress-color:#8ef0d0\"&gt;&lt;/div&gt;\n              &lt;/div&gt;\n            &lt;/div&gt;\n            &lt;div class=\"progress-row\"&gt;\n              &lt;div class=\"progress-heading\"&gt;&lt;span id=\"paletteProgressLabel\"&gt;Palette&lt;/span&gt;&lt;output id=\"paletteProgressValue\"&gt;100%&lt;/output&gt;&lt;/div&gt;\n              &lt;div class=\"progress-track\" role=\"progressbar\" aria-label=\"Time remaining until palette change\" aria-valuemin=\"0\" aria-valuemax=\"100\" aria-valuenow=\"100\" id=\"paletteProgressTrack\"&gt;\n                &lt;div class=\"progress-fill\" id=\"paletteProgressFill\"&gt;&lt;/div&gt;\n              &lt;/div&gt;\n            &lt;/div&gt;\n          &lt;/div&gt;\n          &lt;div class=\"note\"&gt;Pattern and palette have independent phrase deadlines. This tube advances them from its own beat clock whether or not another packet arrives.&lt;/div&gt;\n        &lt;/section&gt;\n\n        &lt;section class=\"section\"&gt;\n          &lt;h3 class=\"section-title\"&gt;Position knowledge &lt;em&gt;direct observations&lt;/em&gt;&lt;/h3&gt;\n          &lt;ul class=\"traffic-list\" id=\"positionKnowledgeList\"&gt;&lt;/ul&gt;\n          &lt;div class=\"note\"&gt;Each entry combines the peer’s advertised estimate with this device’s own range measurement to that immediate radio sender.&lt;/div&gt;\n        &lt;/section&gt;\n\n        &lt;section class=\"section\"&gt;\n          &lt;h3 class=\"section-title\"&gt;Simulator view &lt;em&gt;not visible to device&lt;/em&gt;&lt;/h3&gt;\n          &lt;div class=\"facts\"&gt;\n            &lt;div class=\"fact\"&gt;&lt;span&gt;Physical position&lt;/span&gt;&lt;strong id=\"factPosition\"&gt;0, 0&lt;/strong&gt;&lt;/div&gt;\n            &lt;div class=\"fact\"&gt;&lt;span&gt;Inside hard range&lt;/span&gt;&lt;strong id=\"factNeighbors\"&gt;0&lt;/strong&gt;&lt;/div&gt;\n            &lt;div class=\"fact\"&gt;&lt;span&gt;Strongest received signal&lt;/span&gt;&lt;strong id=\"factSignal\"&gt;none&lt;/strong&gt;&lt;/div&gt;\n          &lt;/div&gt;\n          &lt;div class=\"note\"&gt;Position, neighbor count, and the global map belong only to the simulator. They are never supplied to the node’s network stack.&lt;/div&gt;\n        &lt;/section&gt;\n\n        &lt;section class=\"section\"&gt;\n          &lt;h3 class=\"section-title\"&gt;Evaluation history &lt;em&gt;simulator truth comparison&lt;/em&gt;&lt;/h3&gt;\n          &lt;div class=\"evaluation-controls\"&gt;\n            &lt;div class=\"control\" title=\"Error distance a uniquely positioned tube must exceed before it can become a persistent outlier.\"&gt;\n              &lt;label class=\"tool-label\" for=\"outlierErrorControl\"&gt;Outlier error&lt;/label&gt;\n              &lt;output id=\"outlierErrorOutput\"&gt;120 px&lt;/output&gt;\n              &lt;input id=\"outlierErrorControl\" type=\"range\" min=\"25\" max=\"400\" step=\"5\" value=\"120\" title=\"Set persistent-outlier error threshold in pixels.\"&gt;\n            &lt;/div&gt;\n            &lt;div class=\"control\" title=\"How long a tube must remain beyond the error threshold before the evaluator records an outlier event.\"&gt;\n              &lt;label class=\"tool-label\" for=\"outlierTimeControl\"&gt;Outlier time&lt;/label&gt;\n              &lt;output id=\"outlierTimeOutput\"&gt;8 s&lt;/output&gt;\n              &lt;input id=\"outlierTimeControl\" type=\"range\" min=\"1\" max=\"30\" step=\"1\" value=\"8\" title=\"Set persistent-outlier duration in simulated seconds.\"&gt;\n            &lt;/div&gt;\n          &lt;/div&gt;\n          &lt;canvas class=\"quality-chart\" id=\"qualityChart\" aria-label=\"Location quality score over simulation time\"&gt;&lt;/canvas&gt;\n          &lt;div class=\"facts evaluation-facts\"&gt;\n            &lt;div class=\"fact\"&gt;&lt;span&gt;Uniquely positioned&lt;/span&gt;&lt;strong id=\"factEvaluationCoverage\"&gt;0 / 0&lt;/strong&gt;&lt;/div&gt;\n            &lt;div class=\"fact\"&gt;&lt;span&gt;Worst current error&lt;/span&gt;&lt;strong id=\"factWorstError\"&gt;—&lt;/strong&gt;&lt;/div&gt;\n            &lt;div class=\"fact\"&gt;&lt;span&gt;Peer-table evictions&lt;/span&gt;&lt;strong id=\"factPeerEvictions\"&gt;0&lt;/strong&gt;&lt;/div&gt;\n            &lt;div class=\"fact\"&gt;&lt;span&gt;Admission drops&lt;/span&gt;&lt;strong id=\"factPeerDrops\"&gt;0&lt;/strong&gt;&lt;/div&gt;\n            &lt;div class=\"fact\"&gt;&lt;span&gt;Location block / packet&lt;/span&gt;&lt;strong id=\"factWireBytes\"&gt;—&lt;/strong&gt;&lt;/div&gt;\n            &lt;div class=\"fact\"&gt;&lt;span&gt;Coordinate range&lt;/span&gt;&lt;strong id=\"factCoordinateRange\"&gt;—&lt;/strong&gt;&lt;/div&gt;\n            &lt;div class=\"fact\"&gt;&lt;span&gt;Modeled table allocation&lt;/span&gt;&lt;strong id=\"factTableBytes\"&gt;—&lt;/strong&gt;&lt;/div&gt;\n          &lt;/div&gt;\n          &lt;ul class=\"traffic-list evaluation-outliers\" id=\"outlierList\"&gt;&lt;/ul&gt;\n          &lt;div class=\"note\" id=\"evaluationNote\"&gt;Quality registers floating frames to physical truth for scoring only, choosing rotation and optional reflection by best fit. A tube never receives that registration or any true position. An outlier is reported after remaining more than 120 px wrong for 8 simulated seconds.&lt;/div&gt;\n        &lt;/section&gt;\n\n        &lt;section class=\"section\"&gt;\n          &lt;h3 class=\"section-title\"&gt;Agent diagnostics &lt;em&gt;serializable live state&lt;/em&gt;&lt;/h3&gt;\n          &lt;div class=\"diagnostic-actions\"&gt;\n            &lt;button id=\"copySnapshot\" title=\"Copy the current simulator snapshot, excluding the potentially large complete message audit.\"&gt;Copy full JSON&lt;/button&gt;\n            &lt;label class=\"check\" title=\"Continuously encode a compact diagnostic snapshot in the page URL fragment for external observation.\"&gt;&lt;input id=\"mirrorSnapshot\" type=\"checkbox\" title=\"Toggle compact live-state mirroring in the URL.\"&gt; Mirror compact state in URL&lt;/label&gt;\n            &lt;span class=\"copy-status\" id=\"copyStatus\"&gt;&lt;/span&gt;\n          &lt;/div&gt;\n          &lt;pre class=\"snapshot\" id=\"debugSnapshot\" data-testid=\"agent-snapshot\"&gt;&lt;/pre&gt;\n          &lt;div class=\"note\"&gt;The full snapshot is also available as &lt;code&gt;TubesMeshSimulator.getSnapshot()&lt;/code&gt;. URL mirroring is useful when this page remains open directly as a local file.&lt;/div&gt;\n        &lt;/section&gt;\n\n        &lt;section class=\"section\"&gt;\n          &lt;h3 class=\"section-title\"&gt;Recent traffic&lt;/h3&gt;\n          &lt;ul class=\"traffic-list\" id=\"trafficList\"&gt;&lt;/ul&gt;\n        &lt;/section&gt;\n\n        &lt;section class=\"section\"&gt;\n          &lt;h3 class=\"section-title\"&gt;Message audit &lt;em&gt;complete current run&lt;/em&gt;&lt;/h3&gt;\n          &lt;div class=\"diagnostic-actions\"&gt;\n            &lt;button id=\"copySelectedAudit\" title=\"Copy every audit event associated with the selected device, including packet payloads and before/after state.\"&gt;Copy selected device&lt;/button&gt;\n            &lt;button id=\"copyRunAudit\" title=\"Copy the complete current-run audit for all devices. Large or dense runs may produce substantial JSON.\"&gt;Copy entire run&lt;/button&gt;\n            &lt;span class=\"copy-status\" id=\"auditCopyStatus\"&gt;&lt;/span&gt;\n          &lt;/div&gt;\n          &lt;div class=\"facts\"&gt;\n            &lt;div class=\"fact\"&gt;&lt;span&gt;Events for device&lt;/span&gt;&lt;strong id=\"factAuditEvents\"&gt;0&lt;/strong&gt;&lt;/div&gt;\n            &lt;div class=\"fact\"&gt;&lt;span&gt;Sent / received&lt;/span&gt;&lt;strong id=\"factAuditTraffic\"&gt;0 / 0&lt;/strong&gt;&lt;/div&gt;\n            &lt;div class=\"fact\"&gt;&lt;span&gt;Accepted / ignored&lt;/span&gt;&lt;strong id=\"factAuditDecisions\"&gt;0 / 0&lt;/strong&gt;&lt;/div&gt;\n            &lt;div class=\"fact\"&gt;&lt;span&gt;Radio non-deliveries&lt;/span&gt;&lt;strong id=\"factAuditDrops\"&gt;0&lt;/strong&gt;&lt;/div&gt;\n            &lt;div class=\"fact\"&gt;&lt;span&gt;Lighting states applied&lt;/span&gt;&lt;strong id=\"factAuditApplied\"&gt;0&lt;/strong&gt;&lt;/div&gt;\n            &lt;div class=\"fact\"&gt;&lt;span&gt;Relays / local changes&lt;/span&gt;&lt;strong id=\"factAuditRelays\"&gt;0 / 0&lt;/strong&gt;&lt;/div&gt;\n          &lt;/div&gt;\n          &lt;ul class=\"traffic-list evaluation-outliers\" id=\"messageAuditList\"&gt;&lt;/ul&gt;\n          &lt;div class=\"note\"&gt;Every outgoing broadcast is recorded once. Every other device receives either a delivered-packet decision or an explicit non-delivery reason, including hard-range exclusion. Receive records retain the packet payload plus the device’s routing, DNA, schedule, and position state before and after handling it.&lt;/div&gt;\n        &lt;/section&gt;\n\n        &lt;section class=\"section\"&gt;\n          &lt;h3 class=\"section-title\"&gt;Visual key&lt;/h3&gt;\n          &lt;div class=\"legend\"&gt;\n            &lt;div class=\"legend-item\"&gt;&lt;span class=\"legend-mark\" style=\"--mark:#8ef0d0\"&gt;&lt;/span&gt;broadcast wave&lt;/div&gt;\n            &lt;div class=\"legend-item\"&gt;&lt;span class=\"legend-mark\" style=\"--mark:#f6d365\"&gt;&lt;/span&gt;rebroadcast wave&lt;/div&gt;\n            &lt;div class=\"legend-item\"&gt;&lt;span class=\"legend-mark\" style=\"--mark:#ff7f91\"&gt;&lt;/span&gt;dropped packet&lt;/div&gt;\n            &lt;div class=\"legend-item\"&gt;&lt;span class=\"legend-mark\" style=\"--mark:#70b7ff\"&gt;&lt;/span&gt;selected signal&lt;/div&gt;\n            &lt;div class=\"legend-item\"&gt;&lt;span class=\"legend-mark\" style=\"--mark:#aab4c8\"&gt;&lt;/span&gt;uplink&lt;/div&gt;\n            &lt;div class=\"legend-item\"&gt;&lt;span style=\"color:#f4f7ff;font:800 14px/1 ui-monospace,monospace\"&gt;⊕&lt;/span&gt;physical X,Y center&lt;/div&gt;\n            &lt;div class=\"legend-item\"&gt;&lt;span style=\"color:#f6d365;font:800 14px/1 ui-monospace,monospace\"&gt;◈&lt;/span&gt;fixed no-light anchor&lt;/div&gt;\n            &lt;div class=\"legend-item\"&gt;&lt;span style=\"color:#8ef0d0;font:800 14px/1 ui-monospace,monospace\"&gt;◇&lt;/span&gt;device-estimated position&lt;/div&gt;\n            &lt;div class=\"legend-item\"&gt;&lt;span style=\"color:#ff8fb8;font:800 14px/1 ui-monospace,monospace\"&gt;◯&lt;/span&gt;possible-position circle&lt;/div&gt;\n            &lt;div class=\"legend-item\"&gt;&lt;span style=\"color:#f6d365;font:800 14px/1 ui-monospace,monospace\"&gt;◆&lt;/span&gt;mirror candidates&lt;/div&gt;\n          &lt;/div&gt;\n          &lt;div class=\"note\"&gt;Packets are processed in the simulation instant they are sent. The illustrative wavefront continues outward for one simulated second, with opacity following the selected power-decay function.&lt;/div&gt;\n        &lt;/section&gt;\n      &lt;/aside&gt;\n    &lt;/main&gt;\n  &lt;/div&gt;\n\n  &lt;script&gt;\n    (() =&gt; {\n      \"use strict\";\n\n      const PROTOCOL_VERSION = 2;\n      const RECIPIENTS = Object.freeze({ ALL: 0, ROOT: 1, INFO: 2 });\n      const COMMAND = Object.freeze({ STATE: 0x20, ACTION: 0x30, INFO: 0x40, POSITION: 0x50 });\n      const STATUS = Object.freeze({ RECEIVING: \"receiving\", STARTED: \"started\" });\n      const STATUS_TIMEOUT_BASE = 3000;\n      const UPLINK_TIMEOUT = 10000;\n      const REBROADCAST_TIME = 30000;\n      const STATUS_UPDATE_PERIOD = 2000;\n      const POSITION_PROTOCOL_VERSION = 2;\n      const ANCHORED_FRAME_ID = 0xFFFF;\n      const POSITION_UPDATE_PERIOD = 1000;\n      const POSITION_CONVERGENCE_RATE = 0.28;\n      const POSITION_CONFIDENCE_RATE = 0.22;\n      const POSITION_SETTLED_EPSILON = 0.5;\n      const MIRROR_RESIDUAL_MARGIN = 3;\n      const MIRROR_CONFIRMATIONS_REQUIRED = 3;\n      const RECENT_LIGHTING_MESSAGE_LIMIT = 16;\n      const DISPLAY_REFLECTION_HYSTERESIS = 5;\n      const POSITION_GEOMETRY_MIN_SCORE = 0.002;\n      const POSITION_RANGE_FILTER_RATE = 0.18;\n      const POSITION_RANGE_VARIANCE_RATE = 0.12;\n      const POSITION_RANGE_MIN_SIGMA = 2;\n      const POSITION_RANGE_OUTLIER_SIGMAS = 3;\n      const POSITION_ROBUST_RESIDUAL_SCALE = 15;\n      const POSITION_SOLUTION = Object.freeze({\n        ANCHOR: \"anchor\",\n        ORIGIN: \"origin\",\n        AXIS: \"axis\",\n        ORIENTATION: \"orientation\",\n        RADIAL: \"radial\",\n        MIRRORED: \"mirrored\",\n        POSITIONED: \"positioned\",\n        ADJUSTING: \"adjusting\",\n        UNPLACED: \"unplaced\"\n      });\n      const RADIO_WAVE_TIME = 1000;\n      const MAX_RADIO_STANDARD_SCORE = 3;\n      const DEFAULT_BPM = 120;\n      const BEAT_UNITS = 256;\n      const PHRASE_BEATS = 16;\n      const PHRASE_UNITS = BEAT_UNITS * PHRASE_BEATS;\n      const MIN_COLOR_CHANGE_PHRASES = 4;\n      const MAX_COLOR_CHANGE_PHRASES = 10;\n      const MIN_VISUAL_BRIGHTNESS = 0.32;\n      const CURRENT_NODE_MESSAGE_BYTES = 84;\n      const COMPACT_POSITION_ENVELOPE_BYTES = 8;\n      const LEADER_VIA_ID_BYTES = 2;\n      const QUALITY_SAMPLE_PERIOD = 500;\n      const QUALITY_HISTORY_LIMIT = 240;\n      const QUALITY_ERROR_SCALE = 75;\n      const PERSISTENT_OUTLIER_ERROR = 120;\n      const PERSISTENT_OUTLIER_TIME = 8000;\n\n      const POSITION_PAYLOAD_PROFILES = Object.freeze({\n        tiny: Object.freeze({\n          label: \"Tiny\",\n          fixedPayloadBytes: 16,\n          fixedPeerBytes: 28,\n          includeQuality: false,\n          includeTxCalibration: false\n        }),\n        balanced: Object.freeze({\n          label: \"Balanced\",\n          fixedPayloadBytes: 22,\n          fixedPeerBytes: 36,\n          includeQuality: true,\n          includeTxCalibration: true\n        }),\n        full: Object.freeze({\n          label: \"Full\",\n          fixedPayloadBytes: 30,\n          fixedPeerBytes: 44,\n          includeQuality: true,\n          includeTxCalibration: true\n        })\n      });\n\n      const COORDINATE_ENCODINGS = Object.freeze({\n        int8: Object.freeze({ label: \"2 × int8\", bits: 8, bytes: 2 }),\n        int12: Object.freeze({ label: \"2 × int12\", bits: 12, bytes: 3 }),\n        int16: Object.freeze({ label: \"2 × int16\", bits: 16, bytes: 4 })\n      });\n\n      const DEVICE_COUNT_PRESETS = Object.freeze([1, 2, 3, 4, 8, 16, 32, 64]);\n      const ANCHOR_COUNT_PRESETS = Object.freeze([0, 1, 2, 3, 4, 5]);\n\n      const PATTERNS = [\n        { name: \"Wave\", duration: [15, 25] },\n        { name: \"Chase\", duration: [5, 15] },\n        { name: \"Breath\", duration: [20, 40] },\n        { name: \"Bands\", duration: [15, 25] },\n        { name: \"Spark\", duration: [2, 6] },\n        { name: \"Scanner\", duration: [5, 15] }\n      ];\n\n      const PALETTES = [\n        { name: \"Aurora\", colors: [\"#55efc4\", \"#45aaf2\", \"#a55eea\"] },\n        { name: \"Ember\", colors: [\"#ff4757\", \"#ff7f50\", \"#ffd32a\"] },\n        { name: \"Lagoon\", colors: [\"#00d2d3\", \"#2e86de\", \"#54a0ff\"] },\n        { name: \"Orchid\", colors: [\"#ff6bcb\", \"#be2edd\", \"#686de0\"] },\n        { name: \"Citrus\", colors: [\"#f9ca24\", \"#badc58\", \"#6ab04c\"] },\n        { name: \"Ice\", colors: [\"#f5f6fa\", \"#7ed6df\", \"#22a6b3\"] },\n        { name: \"Voltage\", colors: [\"#f6e58d\", \"#ffbe76\", \"#7d5fff\"] },\n        { name: \"Ruby\", colors: [\"#ff7979\", \"#eb4d4b\", \"#6d214f\"] }\n      ];\n\n      const clamp = (value, min, max) =&gt; Math.max(min, Math.min(max, value));\n      const dbToPowerRatio = decibels =&gt; 10 ** (decibels / 10);\n      const formatDecibels = decibels =&gt; `${Number(decibels.toFixed(2))} dB`;\n      const formatId = id =&gt; id ? id.toString(16).toUpperCase().padStart(3, \"0\") : \"---\";\n      const formatFrameId = id =&gt; id === ANCHORED_FRAME_ID ? \"ANCHORED\" : formatId(id);\n      const dnaKey = dna =&gt; `${dna.pattern}:${dna.palette}`;\n      const scheduleRemainingRatio = (lastChangePhrase, nextChangePhrase, beatFrame) =&gt; {\n        const startBeat = lastChangePhrase * PHRASE_BEATS;\n        const deadlineBeat = nextChangePhrase * PHRASE_BEATS;\n        const currentBeat = beatFrame / BEAT_UNITS;\n        const totalBeats = deadlineBeat - startBeat;\n        if (totalBeats &lt;= 0) return 0;\n        return clamp((deadlineBeat - currentBeat) / totalBeats, 0, 1);\n      };\n      const cloneTubeState = state =&gt; ({\n        bpm: state.bpm,\n        beatFrame: state.beatFrame,\n        patternPhrase: state.patternPhrase,\n        patternId: state.patternId,\n        palettePhrase: state.palettePhrase,\n        paletteId: state.paletteId\n      });\n      const cloneTubeStates = states =&gt; ({\n        current: cloneTubeState(states.current),\n        next: cloneTubeState(states.next)\n      });\n      const cloneData = data =&gt; data &amp;&amp; data.states\n        ? { states: cloneTubeStates(data.states) }\n        : { action: data ? data.action : null };\n\n      function mulberry32(seed) {\n        let value = seed &gt;&gt;&gt; 0;\n        return () =&gt; {\n          value += 0x6D2B79F5;\n          let t = value;\n          t = Math.imul(t ^ (t &gt;&gt;&gt; 15), t | 1);\n          t ^= t + Math.imul(t ^ (t &gt;&gt;&gt; 7), t | 61);\n          return ((t ^ (t &gt;&gt;&gt; 14)) &gt;&gt;&gt; 0) / 4294967296;\n        };\n      }\n\n      function hexToRgb(hex) {\n        const value = Number.parseInt(hex.slice(1), 16);\n        return { r: value &gt;&gt; 16, g: (value &gt;&gt; 8) &amp; 255, b: value &amp; 255 };\n      }\n\n      function mixColor(a, b, amount) {\n        const first = hexToRgb(a);\n        const second = hexToRgb(b);\n        return {\n          r: Math.round(first.r + (second.r - first.r) * amount),\n          g: Math.round(first.g + (second.g - first.g) * amount),\n          b: Math.round(first.b + (second.b - first.b) * amount)\n        };\n      }\n\n      function scaleColor(color, amount) {\n        const peak = Math.max(color.r, color.g, color.b);\n        if (peak &lt;= 0) return \"rgb(0, 0, 0)\";\n        const normalizedScale = 255 / peak;\n        const visibleAmount = clamp(amount, MIN_VISUAL_BRIGHTNESS, 1);\n        return `rgb(${Math.round(color.r * normalizedScale * visibleAmount)}, ${Math.round(color.g * normalizedScale * visibleAmount)}, ${Math.round(color.b * normalizedScale * visibleAmount)})`;\n      }\n\n      function paletteColor(palette, position, brightness = 1) {\n        const colors = palette.colors;\n        const normalized = ((position % 1) + 1) % 1;\n        const scaled = normalized * colors.length;\n        const index = Math.floor(scaled) % colors.length;\n        const next = (index + 1) % colors.length;\n        return scaleColor(mixColor(colors[index], colors[next], scaled - Math.floor(scaled)), brightness);\n      }\n\n      function deterministicNoise(a, b) {\n        let value = (a * 374761393 + b * 668265263) &gt;&gt;&gt; 0;\n        value = (value ^ (value &gt;&gt; 13)) * 1274126177;\n        return ((value ^ (value &gt;&gt; 16)) &gt;&gt;&gt; 0) / 4294967295;\n      }\n\n      function animationColor(dna, ledIndex, ledCount, clockMs) {\n        const palette = PALETTES[dna.palette];\n        const seconds = clockMs / 1000;\n        const position = ledIndex / ledCount;\n\n        switch (dna.pattern) {\n          case 0:\n            return paletteColor(palette, position + seconds * 0.16, 0.95);\n          case 1: {\n            const chase = ((ledIndex - Math.floor(seconds * 7)) % 6 + 6) % 6;\n            return paletteColor(palette, position + seconds * 0.12, chase &lt; 2 ? 1 : MIN_VISUAL_BRIGHTNESS);\n          }\n          case 2: {\n            const breath = MIN_VISUAL_BRIGHTNESS + (1 - MIN_VISUAL_BRIGHTNESS) * (0.5 + 0.5 * Math.sin(seconds * 2.2));\n            return paletteColor(palette, 0.12 + position * 0.12, breath);\n          }\n          case 3: {\n            const band = Math.floor(ledIndex / 3 + seconds * 1.6) % palette.colors.length;\n            return paletteColor(palette, band / palette.colors.length, 0.9);\n          }\n          case 4: {\n            const tick = Math.floor(seconds * 8);\n            const noise = deterministicNoise(tick + dna.palette * 71, ledIndex + dna.pattern * 19);\n            return paletteColor(palette, noise, noise &gt; 0.76 ? 1 : MIN_VISUAL_BRIGHTNESS);\n          }\n          case 5: {\n            const scanner = (Math.sin(seconds * 2.8) * 0.5 + 0.5) * (ledCount - 1);\n            const distance = Math.abs(scanner - ledIndex);\n            return paletteColor(palette, position + seconds * 0.08, clamp(1 - distance / 4, MIN_VISUAL_BRIGHTNESS, 1));\n          }\n          default:\n            return paletteColor(palette, position, 1);\n        }\n      }\n\n      class TubeNode {\n        constructor(simulation, bornAt, options = {}) {\n          this.simulation = simulation;\n          this.auditDeviceKey = ++simulation.auditDeviceSequence;\n          this.id = simulation.randomMeshId();\n          this.isAnchor = options.isAnchor === true;\n          this.positionEstimate = {\n            frameId: this.isAnchor ? ANCHORED_FRAME_ID : this.id,\n            axisId: null,\n            orientationId: null,\n            solution: this.isAnchor ? POSITION_SOLUTION.ANCHOR : POSITION_SOLUTION.ORIGIN,\n            x: this.isAnchor ? options.x : 0,\n            y: this.isAnchor ? options.y : 0,\n            confidence: 1,\n            settled: true,\n            sequence: 0,\n            updatedAt: bornAt,\n            observations: 0,\n            targetDistance: null,\n            constraintCount: 0,\n            residualError: null,\n            radialConstraint: null,\n            mirrorCandidates: []\n          };\n          this.knownPeers = new Map();\n          this.resetMirrorDecision();\n          this.recentLightingMessages = [];\n          this.lastPositionLogAt = -Infinity;\n          this.uplinkId = 0;\n          this.leaderId = this.id;\n          this.leaderViaId = this.id;\n          this.version = PROTOCOL_VERSION;\n          this.bornAt = bornAt;\n          this.clockRate = 1 + ((simulation.random() - 0.5) * 70) / 1000000;\n          this.timebase = (simulation.random() - 0.5) * 80;\n          this.activeAt = bornAt + Math.max(700, STATUS_TIMEOUT_BASE - this.id / 2);\n          this.nextBroadcastAt = this.activeAt + simulation.random() * STATUS_UPDATE_PERIOD;\n          this.nextPositionBroadcastAt = this.activeAt + simulation.random() * simulation.positionBroadcastPeriod;\n          this.uplinkDeadline = 0;\n          this.lastUplinkSeenAt = null;\n          this.rebroadcastUntil = -1;\n          const initialDNA = simulation.randomDNA();\n          this.current = {\n            bpm: simulation.leaderBpm,\n            beatFrame: 0,\n            patternPhrase: 0,\n            patternId: initialDNA.pattern,\n            palettePhrase: 0,\n            paletteId: initialDNA.palette\n          };\n          this.next = cloneTubeState(this.current);\n          this.scheduleNextPattern(0);\n          this.scheduleNextPalette(0);\n          if (this.next.patternPhrase === this.next.palettePhrase) {\n            this.next.palettePhrase += simulation.randomInt(1, 3);\n          }\n          this.receivedCount = 0;\n          this.executedCount = 0;\n          this.ignoredCount = 0;\n        }\n\n        get status() {\n          return this.simulation.time &gt;= this.activeAt ? STATUS.STARTED : STATUS.RECEIVING;\n        }\n\n        get dna() {\n          return { pattern: this.current.patternId, palette: this.current.paletteId };\n        }\n\n        isFollowing() { return this.uplinkId !== 0; }\n        isRelayActive() { return this.simulation.time &lt;= this.rebroadcastUntil; }\n\n        role() {\n          return this.isFollowing() ? \"Following\" : \"Leading\";\n        }\n\n        localMillis(atTime = this.simulation.time) {\n          return Math.max(0, atTime - this.bornAt) * this.clockRate;\n        }\n\n        visualTime(atTime = this.simulation.time) {\n          return this.timebase + this.localMillis(atTime);\n        }\n\n        patternTime() {\n          const elapsedBeats = this.current.beatFrame / BEAT_UNITS;\n          return elapsedBeats * 60000 / Math.max(1, this.current.bpm);\n        }\n\n        currentPhrase() {\n          return Math.floor(this.current.beatFrame / PHRASE_UNITS);\n        }\n\n        snapshotStates() {\n          return cloneTubeStates({ current: this.current, next: this.next });\n        }\n\n        announcePosition() {\n          const simulation = this.simulation;\n          const profile = simulation.payloadProfile();\n          const entity = simulation.entityForNode(this);\n          const announcement = {\n            version: POSITION_PROTOCOL_VERSION,\n            isAnchor: this.isAnchor,\n            frameId: this.positionEstimate.frameId,\n            axisId: this.positionEstimate.axisId,\n            orientationId: this.positionEstimate.orientationId,\n            solution: this.positionEstimate.solution,\n            x: simulation.quantizeCoordinate(this.positionEstimate.x),\n            y: simulation.quantizeCoordinate(this.positionEstimate.y),\n            confidence: this.positionEstimate.confidence,\n            settled: this.positionEstimate.settled,\n            sequence: this.positionEstimate.sequence,\n            leaderViaId: this.isFollowing() ? this.leaderViaId : this.id\n          };\n          if (profile.includeQuality) {\n            announcement.constraintCount = this.positionEstimate.constraintCount;\n            announcement.residualError = this.positionEstimate.residualError;\n          }\n          if (profile.includeTxCalibration &amp;&amp; entity) {\n            announcement.txCalibrationDb = entity.radioPowerStandardScore * simulation.txPowerSigmaDb;\n          }\n          return announcement;\n        }\n\n        resetPositionEstimate() {\n          const entity = this.simulation.entityForNode(this);\n          this.positionEstimate = {\n            frameId: this.isAnchor ? ANCHORED_FRAME_ID : this.id,\n            axisId: null,\n            orientationId: null,\n            solution: this.isAnchor ? POSITION_SOLUTION.ANCHOR : POSITION_SOLUTION.ORIGIN,\n            x: this.isAnchor ? entity?.x ?? 0 : 0,\n            y: this.isAnchor ? entity?.y ?? 0 : 0,\n            confidence: 1,\n            settled: true,\n            sequence: 0,\n            updatedAt: this.simulation.time,\n            observations: 0,\n            targetDistance: null,\n            constraintCount: 0,\n            residualError: null,\n            radialConstraint: null,\n            mirrorCandidates: []\n          };\n          this.knownPeers = new Map();\n          this.resetMirrorDecision();\n          this.lastPositionLogAt = -Infinity;\n        }\n\n        resetMirrorDecision() {\n          this.mirrorDecision = {\n            baselineKey: null,\n            selectedIndex: null,\n            pendingIndex: null,\n            confirmations: 0,\n            scores: [null, null],\n            discriminatingPeers: 0\n          };\n        }\n\n        peerUtility(peer) {\n          const age = Math.max(0, this.simulation.time - peer.lastHeardAt);\n          const freshness = clamp(1 - age / this.simulation.positionPeerMaxAge(), 0, 1);\n          const anchorValue = peer.isAnchor ? 3 : 0;\n          const frameReferenceValue = [\n            POSITION_SOLUTION.ORIGIN,\n            POSITION_SOLUTION.AXIS,\n            POSITION_SOLUTION.ORIENTATION\n          ].includes(peer.solution) ? 1.2 : 0;\n          const maturity = clamp(peer.rangeSamples / 5, 0, 1);\n          return anchorValue + frameReferenceValue + freshness + peer.confidence + maturity + peer.strength;\n        }\n\n        incomingPeerUtility(remote, strength) {\n          const anchorValue = remote.isAnchor === true ? 3 : 0;\n          const frameReferenceValue = [\n            POSITION_SOLUTION.ORIGIN,\n            POSITION_SOLUTION.AXIS,\n            POSITION_SOLUTION.ORIENTATION\n          ].includes(remote.solution) ? 1.2 : 0;\n          return anchorValue\n            + frameReferenceValue\n            + 1\n            + clamp(remote.confidence, 0, 1)\n            + clamp(strength, 0, 1);\n        }\n\n        protectedPeerIds() {\n          const protectedIds = new Set(\n            [...this.knownPeers.values()]\n              .filter(peer =&gt; peer.isAnchor &amp;&amp; this.isFreshPositionPeer(peer))\n              .sort((a, b) =&gt; this.peerUtility(b) - this.peerUtility(a))\n              .slice(0, this.simulation.anchorReserve)\n              .map(peer =&gt; peer.id)\n          );\n          const frameReferences = [\n            this.positionEstimate.frameId,\n            this.positionEstimate.axisId,\n            this.positionEstimate.orientationId\n          ];\n          for (const referenceId of frameReferences) {\n            const peer = referenceId ? this.knownPeers.get(referenceId) : null;\n            if (peer &amp;&amp; this.isFreshPositionPeer(peer)) protectedIds.add(referenceId);\n          }\n          return protectedIds;\n        }\n\n        admitPeer(senderId, remote, strength) {\n          if (this.knownPeers.has(senderId)) return true;\n          if (this.knownPeers.size &lt; this.simulation.peerCapacity) return true;\n\n          const protectedPeers = this.protectedPeerIds();\n          let candidates = [...this.knownPeers.values()].filter(peer =&gt; !protectedPeers.has(peer.id));\n          if (!candidates.length &amp;&amp; remote.isAnchor === true) candidates = [...this.knownPeers.values()];\n          if (!candidates.length) {\n            this.simulation.stats.peerAdmissionDrops += 1;\n            return false;\n          }\n\n          candidates.sort((a, b) =&gt; this.peerUtility(a) - this.peerUtility(b));\n          const victim = candidates[0];\n          if (this.incomingPeerUtility(remote, strength) &lt;= this.peerUtility(victim)) {\n            this.simulation.stats.peerAdmissionDrops += 1;\n            return false;\n          }\n          this.knownPeers.delete(victim.id);\n          this.simulation.stats.peerEvictions += 1;\n          return true;\n        }\n\n        enforcePeerCapacity() {\n          while (this.knownPeers.size &gt; this.simulation.peerCapacity) {\n            const protectedPeers = this.protectedPeerIds();\n            const allPeers = [...this.knownPeers.values()];\n            const candidates = allPeers.filter(peer =&gt; !protectedPeers.has(peer.id));\n            const evictable = candidates.length ? candidates : allPeers;\n            evictable.sort((a, b) =&gt; this.peerUtility(a) - this.peerUtility(b));\n            this.knownPeers.delete(evictable[0].id);\n            this.simulation.stats.peerEvictions += 1;\n          }\n        }\n\n        rememberPeerPosition(remote, strength, senderId) {\n          if (!this.admitPeer(senderId, remote, strength)) return null;\n          const previous = this.knownPeers.get(senderId) || null;\n          const calibratedStrength = Number.isFinite(remote.txCalibrationDb)\n            ? clamp(strength / dbToPowerRatio(remote.txCalibrationDb), 0, 1)\n            : strength;\n          const rawDistance = this.simulation.distanceFromSignalStrength(calibratedStrength);\n          const rangeSamples = previous ? previous.rangeSamples + 1 : 1;\n          const previousDistance = previous ? previous.directDistance : rawDistance;\n          const previousVariance = previous ? previous.rangeVariance : 0;\n          const innovation = rawDistance - previousDistance;\n          const innovationSigma = Math.sqrt(Math.max(previousVariance, POSITION_RANGE_MIN_SIGMA ** 2));\n          const innovationLimit = POSITION_RANGE_OUTLIER_SIGMAS * innovationSigma;\n          const acceptedInnovation = rangeSamples &gt; 4\n            ? clamp(innovation, -innovationLimit, innovationLimit)\n            : innovation;\n          const filterRate = rangeSamples &lt;= 5 ? 1 / rangeSamples : POSITION_RANGE_FILTER_RATE;\n          const directDistance = previousDistance + acceptedInnovation * filterRate;\n          const rangeVariance = previous\n            ? previousVariance * (1 - POSITION_RANGE_VARIANCE_RATE)\n              + innovation * innovation * POSITION_RANGE_VARIANCE_RATE\n            : 0;\n          const filteredStrength = previous\n            ? previous.strength + (calibratedStrength - previous.strength) * filterRate\n            : calibratedStrength;\n\n          // Each peer keeps fixed-size filter state; no historical RSSI samples or physical coordinates are retained.\n          const peer = {\n            id: senderId,\n            isAnchor: remote.isAnchor === true,\n            frameId: remote.frameId,\n            axisId: Number.isFinite(remote.axisId) ? remote.axisId : null,\n            orientationId: Number.isFinite(remote.orientationId) ? remote.orientationId : null,\n            solution: Object.values(POSITION_SOLUTION).includes(remote.solution)\n              ? remote.solution\n              : POSITION_SOLUTION.UNPLACED,\n            x: remote.x,\n            y: remote.y,\n            confidence: clamp(remote.confidence, 0, 1),\n            settled: remote.settled === true,\n            sequence: Number.isFinite(remote.sequence) ? remote.sequence : 0,\n            advertisedConstraintCount: Number.isFinite(remote.constraintCount) ? remote.constraintCount : null,\n            advertisedResidual: Number.isFinite(remote.residualError) ? remote.residualError : null,\n            txCalibrationDb: Number.isFinite(remote.txCalibrationDb) ? remote.txCalibrationDb : null,\n            rawDistance,\n            directDistance,\n            rangeVariance,\n            rangeSigma: Math.sqrt(rangeVariance),\n            rangeSamples,\n            outlierLimited: acceptedInnovation !== innovation,\n            rawStrength: strength,\n            strength: filteredStrength,\n            lastHeardAt: this.simulation.time\n          };\n          this.knownPeers.set(senderId, peer);\n          return peer;\n        }\n\n        adoptPositionFrame(frameId, senderId) {\n          const local = this.positionEstimate;\n          if (this.isAnchor) return;\n          if (frameId &lt;= local.frameId) return;\n\n          const previousFrameId = local.frameId;\n          local.frameId = frameId;\n          local.axisId = null;\n          local.orientationId = null;\n          local.solution = frameId === this.id ? POSITION_SOLUTION.ORIGIN : POSITION_SOLUTION.UNPLACED;\n          local.x = 0;\n          local.y = 0;\n          local.confidence = frameId === this.id ? 1 : 0;\n          local.settled = frameId === this.id;\n          local.observations = 0;\n          local.targetDistance = null;\n          local.constraintCount = 0;\n          local.residualError = null;\n          local.radialConstraint = null;\n          local.mirrorCandidates = [];\n          this.resetMirrorDecision();\n          local.sequence += 1;\n          local.updatedAt = this.simulation.time;\n          this.simulation.log(\n            this,\n            \"position\",\n            `adopted frame ${formatFrameId(frameId)} from ${formatId(senderId)}; previous frame ${formatFrameId(previousFrameId)}`\n          );\n        }\n\n        lockAnchorPosition() {\n          if (!this.isAnchor) return;\n          const entity = this.simulation.entityForNode(this);\n          if (!entity) return;\n          const local = this.positionEstimate;\n          const moved = Math.hypot(local.x - entity.x, local.y - entity.y) &gt; 0.01;\n          local.frameId = ANCHORED_FRAME_ID;\n          local.axisId = null;\n          local.orientationId = null;\n          local.solution = POSITION_SOLUTION.ANCHOR;\n          local.x = entity.x;\n          local.y = entity.y;\n          local.confidence = 1;\n          local.settled = true;\n          local.targetDistance = null;\n          local.constraintCount = 0;\n          local.residualError = 0;\n          local.radialConstraint = null;\n          local.mirrorCandidates = [];\n          if (moved) local.sequence += 1;\n          local.updatedAt = this.simulation.time;\n        }\n\n        seedAnchoredPosition(multilateration) {\n          const local = this.positionEstimate;\n          local.x = multilateration.target.x;\n          local.y = multilateration.target.y;\n          local.solution = POSITION_SOLUTION.ADJUSTING;\n          local.confidence = multilateration.confidence;\n          local.settled = false;\n          local.constraintCount = multilateration.constraintCount;\n          local.residualError = multilateration.residualError;\n          local.radialConstraint = null;\n          local.mirrorCandidates = [];\n          local.updatedAt = this.simulation.time;\n        }\n\n        determineAxisId(originObservation) {\n          const frameId = this.positionEstimate.frameId;\n          if (this.id === frameId) {\n            // The first elected axis defines the frame&#39;s rotation and must survive later joins.\n            if (this.positionEstimate.axisId) return this.positionEstimate.axisId;\n            const directlyHeardFollowers = [...this.knownPeers.keys()].filter(peerId =&gt; peerId !== frameId);\n            return directlyHeardFollowers.length ? Math.max(...directlyHeardFollowers) : null;\n          }\n\n          if (originObservation &amp;&amp; originObservation.axisId) return originObservation.axisId;\n          if (this.positionEstimate.axisId) return this.positionEstimate.axisId;\n\n          const candidates = [];\n          for (const peer of this.knownPeers.values()) {\n            if (peer.frameId !== frameId) continue;\n            if (peer.axisId &amp;&amp; peer.axisId !== frameId) candidates.push(peer.axisId);\n          }\n          return candidates.length ? Math.max(...candidates) : null;\n        }\n\n        determineOrientationId(originObservation) {\n          const local = this.positionEstimate;\n          const frameId = local.frameId;\n          if (this.id === frameId) {\n            // The orientation member fixes reflection by remaining on the frame&#39;s positive-y side.\n            if (local.orientationId &amp;&amp; local.orientationId !== local.axisId) return local.orientationId;\n            const candidates = [...this.knownPeers.keys()].filter(peerId =&gt;\n              peerId !== frameId &amp;&amp; peerId !== local.axisId\n            );\n            return candidates.length ? Math.max(...candidates) : null;\n          }\n\n          if (originObservation &amp;&amp; originObservation.orientationId) return originObservation.orientationId;\n          if (local.orientationId &amp;&amp; local.orientationId !== local.axisId) return local.orientationId;\n\n          const candidates = [];\n          for (const peer of this.knownPeers.values()) {\n            if (peer.frameId !== frameId) continue;\n            if (peer.orientationId &amp;&amp; peer.orientationId !== local.axisId) candidates.push(peer.orientationId);\n          }\n          return candidates.length ? Math.max(...candidates) : null;\n        }\n\n        convergePosition(target, solution, confidence, details = {}) {\n          const local = this.positionEstimate;\n          const previousX = local.x;\n          const previousY = local.y;\n          local.x += (target.x - local.x) * POSITION_CONVERGENCE_RATE;\n          local.y += (target.y - local.y) * POSITION_CONVERGENCE_RATE;\n          local.solution = solution;\n          local.targetDistance = details.targetDistance ?? null;\n          local.constraintCount = details.constraintCount ?? 0;\n          local.residualError = details.residualError ?? null;\n          local.radialConstraint = null;\n          local.mirrorCandidates = details.mirrorCandidates || [];\n          local.observations += 1;\n          local.confidence += (clamp(confidence, 0, 1) - local.confidence) * POSITION_CONFIDENCE_RATE;\n          local.settled = Math.hypot(target.x - local.x, target.y - local.y) &lt;= POSITION_SETTLED_EPSILON;\n          local.sequence += 1;\n          local.updatedAt = this.simulation.time;\n\n          const movement = Math.hypot(local.x - previousX, local.y - previousY);\n          if (movement &gt; 0.2 &amp;&amp; this.simulation.time - this.lastPositionLogAt &gt;= this.simulation.positionBroadcastPeriod) {\n            this.lastPositionLogAt = this.simulation.time;\n            this.simulation.log(this, \"position\", `${solution} → (${target.x.toFixed(1)}, ${target.y.toFixed(1)})`);\n          }\n        }\n\n        setRadialBelief(peer) {\n          const local = this.positionEstimate;\n          local.solution = POSITION_SOLUTION.RADIAL;\n          local.x = peer.x + peer.directDistance;\n          local.y = peer.y;\n          local.confidence = clamp(peer.confidence * peer.strength * 0.5, 0, 1);\n          local.settled = false;\n          local.targetDistance = peer.directDistance;\n          local.constraintCount = 1;\n          local.residualError = null;\n          local.radialConstraint = {\n            centerId: peer.id,\n            x: peer.x,\n            y: peer.y,\n            radius: peer.directDistance\n          };\n          local.mirrorCandidates = [];\n          local.observations += 1;\n          local.sequence += 1;\n          local.updatedAt = this.simulation.time;\n        }\n\n        circleIntersectionsWithAxis(originObservation, axisObservation) {\n          const baseline = Math.hypot(axisObservation.x, axisObservation.y);\n          if (baseline &lt;= POSITION_SETTLED_EPSILON) return null;\n\n          const radiusFromOrigin = originObservation.directDistance;\n          const radiusFromAxis = axisObservation.directDistance;\n          const x = (\n            radiusFromOrigin ** 2\n            - radiusFromAxis ** 2\n            + baseline ** 2\n          ) / (2 * baseline);\n          const ySquared = radiusFromOrigin ** 2 - x ** 2;\n          // Noisy circles may miss each other; their closest axis solution is still a useful provisional estimate.\n          const y = Math.sqrt(Math.max(0, ySquared));\n          return [{ x, y }, { x, y: -y }];\n        }\n\n        circleIntersections(first, second) {\n          const dx = second.x - first.x;\n          const dy = second.y - first.y;\n          const baseline = Math.hypot(dx, dy);\n          if (baseline &lt;= POSITION_SETTLED_EPSILON) return null;\n\n          const along = (\n            first.directDistance ** 2\n            - second.directDistance ** 2\n            + baseline ** 2\n          ) / (2 * baseline);\n          const perpendicular = Math.sqrt(Math.max(0, first.directDistance ** 2 - along ** 2));\n          const unitX = dx / baseline;\n          const unitY = dy / baseline;\n          const centerX = first.x + along * unitX;\n          const centerY = first.y + along * unitY;\n          return [\n            { x: centerX - perpendicular * unitY, y: centerY + perpendicular * unitX },\n            { x: centerX + perpendicular * unitY, y: centerY - perpendicular * unitX }\n          ];\n        }\n\n        rangeResidualAt(point, peers) {\n          const squaredError = peers.reduce((sum, peer) =&gt; {\n            const residual = Math.hypot(point.x - peer.x, point.y - peer.y) - peer.directDistance;\n            return sum + residual * residual;\n          }, 0);\n          return Math.sqrt(squaredError / Math.max(peers.length, 1));\n        }\n\n        mirrorCandidateScores(candidates, peers) {\n          const evidenceSolutions = new Set([\n            POSITION_SOLUTION.ANCHOR,\n            POSITION_SOLUTION.ORIGIN,\n            POSITION_SOLUTION.AXIS,\n            POSITION_SOLUTION.ORIENTATION,\n            POSITION_SOLUTION.POSITIONED,\n            POSITION_SOLUTION.ADJUSTING\n          ]);\n          const evidencePeers = peers.filter(peer =&gt; evidenceSolutions.has(peer.solution));\n          let discriminatingPeers = 0;\n          const weightedSquaredErrors = [0, 0];\n          let totalWeight = 0;\n\n          for (const peer of evidencePeers) {\n            const residuals = candidates.map(candidate =&gt; Math.abs(\n              Math.hypot(candidate.x - peer.x, candidate.y - peer.y) - peer.directDistance\n            ));\n            if (Math.abs(residuals[0] - residuals[1]) &gt;= MIRROR_RESIDUAL_MARGIN) {\n              discriminatingPeers += 1;\n            }\n            const weight = this.positionPeerWeight(peer);\n            weightedSquaredErrors[0] += weight * residuals[0] ** 2;\n            weightedSquaredErrors[1] += weight * residuals[1] ** 2;\n            totalWeight += weight;\n          }\n\n          return {\n            scores: weightedSquaredErrors.map(error =&gt; (\n              totalWeight &gt; 0 ? Math.sqrt(error / totalWeight) : null\n            )),\n            discriminatingPeers\n          };\n        }\n\n        updateMirrorDecision(candidates, peers, baselineIds = []) {\n          const baselineKey = baselineIds.slice().sort((a, b) =&gt; a - b).join(\":\");\n          if (this.mirrorDecision.baselineKey !== baselineKey) {\n            this.resetMirrorDecision();\n            this.mirrorDecision.baselineKey = baselineKey;\n          }\n          const evidence = this.mirrorCandidateScores(candidates, peers);\n          const decision = this.mirrorDecision;\n          decision.scores = evidence.scores;\n          decision.discriminatingPeers = evidence.discriminatingPeers;\n          const [firstScore, secondScore] = evidence.scores;\n          const hasDecision = evidence.discriminatingPeers &gt; 0\n            &amp;&amp; Number.isFinite(firstScore)\n            &amp;&amp; Number.isFinite(secondScore)\n            &amp;&amp; Math.abs(firstScore - secondScore) &gt;= MIRROR_RESIDUAL_MARGIN;\n\n          if (!hasDecision) {\n            decision.pendingIndex = null;\n            decision.confirmations = 0;\n          } else {\n            const winningIndex = firstScore &lt; secondScore ? 0 : 1;\n            if (decision.pendingIndex === winningIndex) decision.confirmations += 1;\n            else {\n              decision.pendingIndex = winningIndex;\n              decision.confirmations = 1;\n            }\n            if (decision.confirmations &gt;= MIRROR_CONFIRMATIONS_REQUIRED) {\n              decision.selectedIndex = winningIndex;\n            }\n          }\n\n          return {\n            confirmed: decision.selectedIndex !== null,\n            selectedIndex: decision.selectedIndex,\n            target: decision.selectedIndex === null ? null : candidates[decision.selectedIndex],\n            scores: decision.scores,\n            confirmations: decision.confirmations,\n            discriminatingPeers: decision.discriminatingPeers\n          };\n        }\n\n        isFreshPositionPeer(peer) {\n          return Boolean(peer) &amp;&amp; this.simulation.time - peer.lastHeardAt &lt;= this.simulation.positionPeerMaxAge();\n        }\n\n        usablePositionPeers(frameId = this.positionEstimate.frameId) {\n          const usableSolutions = new Set([\n            POSITION_SOLUTION.ANCHOR,\n            POSITION_SOLUTION.ORIGIN,\n            POSITION_SOLUTION.AXIS,\n            POSITION_SOLUTION.ORIENTATION,\n            POSITION_SOLUTION.POSITIONED,\n            POSITION_SOLUTION.ADJUSTING\n          ]);\n          return [...this.knownPeers.values()].filter(peer =&gt;\n            peer.frameId === frameId\n            &amp;&amp; usableSolutions.has(peer.solution)\n            &amp;&amp; peer.confidence &gt; 0.02\n            &amp;&amp; Number.isFinite(peer.directDistance)\n            &amp;&amp; this.isFreshPositionPeer(peer)\n          )\n            .sort((a, b) =&gt; this.positionPeerWeight(b) - this.positionPeerWeight(a))\n            .slice(0, this.simulation.solveCapacity);\n        }\n\n        positionPeerWeight(peer) {\n          const age = Math.max(0, this.simulation.time - peer.lastHeardAt);\n          const freshness = clamp(1 - age / this.simulation.positionPeerMaxAge(), 0.1, 1);\n          const isFrameReference = [\n            POSITION_SOLUTION.ANCHOR,\n            POSITION_SOLUTION.ORIGIN,\n            POSITION_SOLUTION.AXIS,\n            POSITION_SOLUTION.ORIENTATION\n          ].includes(peer.solution);\n          const stability = peer.settled ? 1 : isFrameReference ? 0.75 : 0.35;\n          const uncertainty = 1 / (1 + peer.rangeSigma / POSITION_ROBUST_RESIDUAL_SCALE);\n          const advertisedQuality = peer.advertisedResidual === null\n            ? 1\n            : 1 / (1 + peer.advertisedResidual / POSITION_ROBUST_RESIDUAL_SCALE);\n          const maturity = clamp(peer.rangeSamples / 5, 0.2, 1);\n          return clamp(\n            peer.confidence\n              * (0.25 + peer.strength * 0.75)\n              * freshness\n              * stability\n              * uncertainty\n              * advertisedQuality\n              * maturity,\n            0.01,\n            1\n          );\n        }\n\n        multilaterationPass(peers, residualReference = null) {\n          const robustWeight = peer =&gt; {\n            const baseWeight = this.positionPeerWeight(peer);\n            if (!residualReference) return baseWeight;\n            const residual = Math.abs(\n              Math.hypot(residualReference.x - peer.x, residualReference.y - peer.y) - peer.directDistance\n            );\n            return baseWeight / (1 + (residual / POSITION_ROBUST_RESIDUAL_SCALE) ** 2);\n          };\n          const ordered = peers.slice().sort((a, b) =&gt; robustWeight(b) - robustWeight(a));\n          const pivot = ordered[0];\n          const pivotWeight = robustWeight(pivot);\n          let normalXX = 0;\n          let normalXY = 0;\n          let normalYY = 0;\n          let normalXValue = 0;\n          let normalYValue = 0;\n\n          for (const peer of ordered.slice(1)) {\n            const rowX = 2 * (peer.x - pivot.x);\n            const rowY = 2 * (peer.y - pivot.y);\n            const value = (\n              pivot.directDistance ** 2\n              - peer.directDistance ** 2\n              + peer.x ** 2\n              + peer.y ** 2\n              - pivot.x ** 2\n              - pivot.y ** 2\n            );\n            const weight = Math.min(pivotWeight, robustWeight(peer));\n            normalXX += weight * rowX * rowX;\n            normalXY += weight * rowX * rowY;\n            normalYY += weight * rowY * rowY;\n            normalXValue += weight * rowX * value;\n            normalYValue += weight * rowY * value;\n          }\n\n          // A near-zero score means the observed peer positions are effectively collinear.\n          const determinant = normalXX * normalYY - normalXY * normalXY;\n          const trace = normalXX + normalYY;\n          const geometryScore = trace &gt; 0 ? clamp(4 * determinant / (trace * trace), 0, 1) : 0;\n          if (determinant &lt;= 0 || geometryScore &lt; POSITION_GEOMETRY_MIN_SCORE) return null;\n\n          const x = (normalXValue * normalYY - normalYValue * normalXY) / determinant;\n          const y = (normalYValue * normalXX - normalXValue * normalXY) / determinant;\n          if (!Number.isFinite(x) || !Number.isFinite(y)) return null;\n\n          return { target: { x, y }, geometryScore };\n        }\n\n        refineMultilaterationTarget(initialTarget, peers) {\n          let x = initialTarget.x;\n          let y = initialTarget.y;\n          for (let iteration = 0; iteration &lt; 3; iteration += 1) {\n            let normalXX = 0;\n            let normalXY = 0;\n            let normalYY = 0;\n            let gradientX = 0;\n            let gradientY = 0;\n\n            for (const peer of peers) {\n              const deltaX = x - peer.x;\n              const deltaY = y - peer.y;\n              const predictedDistance = Math.max(Math.hypot(deltaX, deltaY), 0.001);\n              const residual = predictedDistance - peer.directDistance;\n              const robustWeight = this.positionPeerWeight(peer)\n                / (1 + (residual / POSITION_ROBUST_RESIDUAL_SCALE) ** 2);\n              const directionX = deltaX / predictedDistance;\n              const directionY = deltaY / predictedDistance;\n              normalXX += robustWeight * directionX * directionX;\n              normalXY += robustWeight * directionX * directionY;\n              normalYY += robustWeight * directionY * directionY;\n              gradientX += robustWeight * directionX * residual;\n              gradientY += robustWeight * directionY * residual;\n            }\n\n            const determinant = normalXX * normalYY - normalXY * normalXY;\n            if (determinant &lt;= Number.EPSILON) break;\n            const stepX = (-gradientX * normalYY + gradientY * normalXY) / determinant;\n            const stepY = (-gradientY * normalXX + gradientX * normalXY) / determinant;\n            const stepLength = Math.hypot(stepX, stepY);\n            const stepScale = stepLength &gt; POSITION_ROBUST_RESIDUAL_SCALE * 2\n              ? POSITION_ROBUST_RESIDUAL_SCALE * 2 / stepLength\n              : 1;\n            x += stepX * stepScale;\n            y += stepY * stepScale;\n            if (stepLength &lt;= POSITION_SETTLED_EPSILON) break;\n          }\n          return { x, y };\n        }\n\n        multilaterationSolution(peers) {\n          if (peers.length &lt; 3) return null;\n\n          // The first fit exposes inconsistent links; the second fit limits their leverage without discarding them.\n          const initial = this.multilaterationPass(peers);\n          if (!initial) return null;\n          const refined = this.multilaterationPass(peers, initial.target) || initial;\n          const { x, y } = this.refineMultilaterationTarget(refined.target, peers);\n\n          let weightedSquaredError = 0;\n          let totalWeight = 0;\n          for (const peer of peers) {\n            const weight = this.positionPeerWeight(peer);\n            const residual = Math.hypot(x - peer.x, y - peer.y) - peer.directDistance;\n            weightedSquaredError += weight * residual * residual;\n            totalWeight += weight;\n          }\n          const residualError = Math.sqrt(weightedSquaredError / Math.max(totalWeight, 0.01));\n          const averagePeerConfidence = peers.reduce((sum, peer) =&gt; sum + peer.confidence, 0) / peers.length;\n          const geometryConfidence = 0.45 + Math.sqrt(refined.geometryScore) * 0.55;\n          const residualConfidence = 1 / (1 + residualError / POSITION_ROBUST_RESIDUAL_SCALE);\n          return {\n            target: { x, y },\n            confidence: clamp(averagePeerConfidence * geometryConfidence * residualConfidence, 0, 1),\n            constraintCount: peers.length,\n            residualError\n          };\n        }\n\n        bestDirectPeerBaseline(peers) {\n          let best = null;\n          for (let firstIndex = 0; firstIndex &lt; peers.length - 1; firstIndex += 1) {\n            for (let secondIndex = firstIndex + 1; secondIndex &lt; peers.length; secondIndex += 1) {\n              const first = peers[firstIndex];\n              const second = peers[secondIndex];\n              const candidates = this.circleIntersections(first, second);\n              if (!candidates) continue;\n\n              const candidateSeparation = Math.hypot(\n                candidates[0].x - candidates[1].x,\n                candidates[0].y - candidates[1].y\n              );\n              if (candidateSeparation &lt;= POSITION_SETTLED_EPSILON) continue;\n\n              const rangeScale = Math.max(first.directDistance + second.directDistance, 1);\n              const intersectionGeometry = clamp(candidateSeparation / rangeScale, 0.05, 1);\n              const weight = Math.min(this.positionPeerWeight(first), this.positionPeerWeight(second));\n              const score = weight * (0.25 + intersectionGeometry * 0.75);\n              if (!best || score &gt; best.score) {\n                best = { first, second, candidates, intersectionGeometry, score };\n              }\n            }\n          }\n          return best;\n        }\n\n        solveFromDirectPeers(peers) {\n          // Frame references define coordinates; only these directly received peers define local range constraints.\n          const multilateration = this.multilaterationSolution(peers);\n          if (multilateration) {\n            this.convergePosition(\n              multilateration.target,\n              POSITION_SOLUTION.POSITIONED,\n              multilateration.confidence,\n              {\n                constraintCount: multilateration.constraintCount,\n                residualError: multilateration.residualError\n              }\n            );\n            return true;\n          }\n\n          const baseline = this.bestDirectPeerBaseline(peers);\n          if (baseline) {\n            const baselineIds = [baseline.first.id, baseline.second.id];\n            const independentPeers = peers.filter(peer =&gt; !baselineIds.includes(peer.id));\n            const branch = this.updateMirrorDecision(\n              baseline.candidates,\n              independentPeers,\n              baselineIds\n            );\n            const previous = { x: this.positionEstimate.x, y: this.positionEstimate.y };\n            const target = branch.confirmed\n              ? branch.target\n              : baseline.candidates.slice().sort((first, second) =&gt; (\n                Math.hypot(first.x - previous.x, first.y - previous.y)\n                - Math.hypot(second.x - previous.x, second.y - previous.y)\n              ))[0];\n            const baselineConfidence = Math.min(\n              baseline.first.confidence,\n              baseline.second.confidence\n            ) * Math.sqrt(baseline.intersectionGeometry);\n            this.convergePosition(\n              target,\n              branch.confirmed ? POSITION_SOLUTION.POSITIONED : POSITION_SOLUTION.MIRRORED,\n              branch.confirmed ? baselineConfidence : baselineConfidence * 0.65,\n              {\n                mirrorCandidates: baseline.candidates,\n                constraintCount: 2 + branch.discriminatingPeers,\n                residualError: branch.confirmed\n                  ? branch.scores[branch.selectedIndex]\n                  : this.rangeResidualAt(target, [baseline.first, baseline.second])\n              }\n            );\n            return true;\n          }\n\n          if (peers.length) {\n            this.setRadialBelief(peers[0]);\n            return true;\n          }\n          return false;\n        }\n\n        anchoredFrameEvidence() {\n          const peers = this.usablePositionPeers(ANCHORED_FRAME_ID);\n          const multilateration = this.multilaterationSolution(peers);\n          const strongestPeers = peers\n            .slice()\n            .sort((a, b) =&gt; this.positionPeerWeight(b) - this.positionPeerWeight(a));\n          const mirrorCandidates = strongestPeers.length &gt;= 2\n            ? this.circleIntersections(strongestPeers[0], strongestPeers[1])\n            : null;\n          return { peers, multilateration, mirrorCandidates };\n        }\n\n        solveAnchoredPosition() {\n          const peers = this.usablePositionPeers();\n          const multilateration = this.multilaterationSolution(peers);\n          if (multilateration) {\n            this.convergePosition(\n              multilateration.target,\n              POSITION_SOLUTION.ADJUSTING,\n              multilateration.confidence,\n              {\n                constraintCount: multilateration.constraintCount,\n                residualError: multilateration.residualError\n              }\n            );\n            return;\n          }\n\n          const ordered = peers.slice().sort((a, b) =&gt; this.positionPeerWeight(b) - this.positionPeerWeight(a));\n          if (ordered.length &gt;= 2) {\n            const mirrorCandidates = this.circleIntersections(ordered[0], ordered[1]);\n            if (mirrorCandidates) {\n              const previous = { x: this.positionEstimate.x, y: this.positionEstimate.y };\n              const target = mirrorCandidates.slice().sort((a, b) =&gt; (\n                Math.hypot(a.x - previous.x, a.y - previous.y)\n                - Math.hypot(b.x - previous.x, b.y - previous.y)\n              ))[0];\n              this.convergePosition(\n                target,\n                POSITION_SOLUTION.MIRRORED,\n                Math.min(ordered[0].confidence, ordered[1].confidence) * 0.65,\n                {\n                  mirrorCandidates,\n                  constraintCount: 2,\n                  residualError: this.rangeResidualAt(target, ordered.slice(0, 2))\n                }\n              );\n              return;\n            }\n          }\n\n          if (ordered.length === 1) this.setRadialBelief(ordered[0]);\n        }\n\n        solvePositionFromKnowledge() {\n          const local = this.positionEstimate;\n          const frameId = local.frameId;\n          if (this.isAnchor) {\n            this.lockAnchorPosition();\n            return;\n          }\n          if (frameId === ANCHORED_FRAME_ID) {\n            local.axisId = null;\n            local.orientationId = null;\n            this.solveAnchoredPosition();\n            return;\n          }\n          const originPeer = this.knownPeers.get(frameId) || null;\n          const originObservation = this.isFreshPositionPeer(originPeer) &amp;&amp; originPeer.frameId === frameId\n            &amp;&amp; originPeer.solution === POSITION_SOLUTION.ORIGIN\n            ? originPeer\n            : null;\n          local.axisId = this.determineAxisId(originObservation);\n          local.orientationId = this.determineOrientationId(originObservation);\n\n          // These three roles bootstrap a common frame. Every other node solves from any usable local peers.\n          if (this.id === frameId) {\n            local.solution = POSITION_SOLUTION.ORIGIN;\n            local.x = 0;\n            local.y = 0;\n            local.confidence = 1;\n            local.settled = true;\n            local.constraintCount = 0;\n            local.residualError = 0;\n            local.radialConstraint = null;\n            local.mirrorCandidates = [];\n            return;\n          }\n\n          if (local.axisId === this.id &amp;&amp; originObservation) {\n            this.convergePosition(\n              { x: originObservation.directDistance, y: 0 },\n              POSITION_SOLUTION.AXIS,\n              originObservation.strength,\n              { targetDistance: originObservation.directDistance, constraintCount: 1, residualError: 0 }\n            );\n            return;\n          }\n\n          const axisObservation = local.axisId ? this.knownPeers.get(local.axisId) : null;\n          const usableAxis = axisObservation\n            &amp;&amp; this.isFreshPositionPeer(axisObservation)\n            &amp;&amp; axisObservation.frameId === frameId\n            &amp;&amp; axisObservation.solution === POSITION_SOLUTION.AXIS\n            &amp;&amp; axisObservation.rangeSamples &gt;= 2;\n\n          const mirrorCandidates = originObservation &amp;&amp; usableAxis\n            ? this.circleIntersectionsWithAxis(originObservation, axisObservation)\n            : null;\n\n          if (local.orientationId === this.id &amp;&amp; mirrorCandidates) {\n            const residualError = this.rangeResidualAt(mirrorCandidates[0], [originObservation, axisObservation]);\n            this.convergePosition(\n              mirrorCandidates[0],\n              POSITION_SOLUTION.ORIENTATION,\n              Math.min(originObservation.strength, axisObservation.strength, axisObservation.confidence),\n              { mirrorCandidates, constraintCount: 2, residualError }\n            );\n            return;\n          }\n\n          this.solveFromDirectPeers(this.usablePositionPeers());\n        }\n\n        receivePosition(remote, strength, senderId, advertisedLeaderId) {\n          if (!remote || remote.version !== POSITION_PROTOCOL_VERSION) return \"unsupported-position-payload\";\n          if (!Number.isFinite(remote.frameId) || !Number.isFinite(remote.x) || !Number.isFinite(remote.y)) {\n            return \"invalid-position-coordinates\";\n          }\n          if (!Number.isFinite(remote.confidence) || senderId === this.id) return \"invalid-position-source\";\n\n          // Relay leases react to this one advertisement; they do not depend on position-table admission.\n          this.observeNeighborLeaderPath(advertisedLeaderId, remote.leaderViaId);\n          const rememberedPeer = this.rememberPeerPosition(remote, strength, senderId);\n          if (!rememberedPeer) return \"peer-table-rejected\";\n          const discoveredLeaderId = remote.isAnchor || remote.frameId === ANCHORED_FRAME_ID\n            ? ANCHORED_FRAME_ID\n            : Math.max(senderId, remote.frameId);\n          let initialAnchoredSolution = null;\n\n          if (\n            !this.isAnchor\n            &amp;&amp; discoveredLeaderId === ANCHORED_FRAME_ID\n            &amp;&amp; this.positionEstimate.frameId !== ANCHORED_FRAME_ID\n          ) {\n            const evidence = this.anchoredFrameEvidence();\n            if (!evidence.multilateration) return \"anchored-evidence-pending\";\n            initialAnchoredSolution = evidence.multilateration;\n          }\n\n          this.adoptPositionFrame(discoveredLeaderId, senderId);\n          if (initialAnchoredSolution) this.seedAnchoredPosition(initialAnchoredSolution);\n          this.solvePositionFromKnowledge();\n          return \"position-updated\";\n        }\n\n        scheduleNextPattern(phrase) {\n          let patternId = this.simulation.randomInt(0, PATTERNS.length);\n          while (patternId === this.current.patternId) patternId = this.simulation.randomInt(0, PATTERNS.length);\n          const [minimum, maximum] = PATTERNS[patternId].duration;\n          this.next.patternId = patternId;\n          this.next.patternPhrase = phrase + this.simulation.randomInt(minimum, maximum);\n        }\n\n        scheduleNextPalette(phrase) {\n          let paletteId = this.simulation.randomInt(0, PALETTES.length);\n          while (paletteId === this.current.paletteId) paletteId = this.simulation.randomInt(0, PALETTES.length);\n          this.next.paletteId = paletteId;\n          this.next.palettePhrase = phrase + this.simulation.randomInt(MIN_COLOR_CHANGE_PHRASES, MAX_COLOR_CHANGE_PHRASES);\n        }\n\n        applyDueSchedule() {\n          const phrase = this.currentPhrase();\n          const patternDue = phrase &gt;= this.next.patternPhrase;\n          const paletteDue = phrase &gt;= this.next.palettePhrase;\n          if (!patternDue &amp;&amp; !paletteDue) return;\n\n          const auditBefore = this.simulation.auditNodeState(this);\n          const changes = [];\n\n          if (patternDue) {\n            this.current.patternPhrase = this.next.patternPhrase;\n            this.current.patternId = this.next.patternId;\n            changes.push(`pattern P${this.current.patternId}`);\n            this.scheduleNextPattern(phrase);\n            while (this.next.patternPhrase === this.next.palettePhrase) {\n              this.next.patternPhrase += this.simulation.randomInt(1, 3);\n            }\n          }\n\n          if (paletteDue) {\n            this.current.palettePhrase = this.next.palettePhrase;\n            this.current.paletteId = this.next.paletteId;\n            changes.push(`palette C${this.current.paletteId}`);\n            this.scheduleNextPalette(phrase);\n            while (this.next.palettePhrase === this.next.patternPhrase) {\n              this.next.palettePhrase += this.simulation.randomInt(1, 3);\n            }\n          }\n\n          if (changes.length) {\n            this.simulation.log(this, \"schedule\", `phrase ${phrase}: changed ${changes.join(\" + \")}`);\n            this.simulation.auditLocalTransition(\n              this,\n              \"scheduled-lighting-change\",\n              auditBefore,\n              { phrase, changes }\n            );\n          }\n        }\n\n        follow(header) {\n          if (!header) {\n            const lostUplinkId = this.uplinkId;\n            this.uplinkId = 0;\n            this.leaderId = this.id;\n            this.leaderViaId = this.id;\n            this.uplinkDeadline = 0;\n            this.lastUplinkSeenAt = null;\n            if (lostUplinkId !== 0) {\n              const relationship = this.simulation.fixedRelay ? \"leader state\" : \"uplink\";\n              this.simulation.log(this, \"route\", `${relationship} ${formatId(lostUplinkId)} timed out; became leader`);\n              if (!this.isAnchor) {\n                this.resetPositionEstimate();\n                this.simulation.log(this, \"position\", \"discarded lost leader frame; restarted at local origin (0,0)\");\n              }\n            }\n            return;\n          }\n\n          const advertisedLeaderId = this.simulation.fixedRelay\n            ? Math.max(header.id, header.uplinkId || 0)\n            : header.id;\n          if (this.uplinkId === advertisedLeaderId) return;\n          this.uplinkId = advertisedLeaderId;\n          this.leaderId = advertisedLeaderId;\n          this.leaderViaId = 0;\n          this.uplinkDeadline = this.simulation.time + UPLINK_TIMEOUT;\n          this.lastUplinkSeenAt = null;\n          this.simulation.log(\n            this,\n            \"route\",\n            `${this.simulation.fixedRelay ? \"following logical leader\" : \"following\"} ${formatId(advertisedLeaderId)}`\n          );\n        }\n\n        lightingMessageFingerprint(message) {\n          return `${message.header.id}:${message.command}:${Math.round(message.timebase * 1000)}`;\n        }\n\n        hasSeenLightingMessage(message) {\n          return this.recentLightingMessages.includes(this.lightingMessageFingerprint(message));\n        }\n\n        rememberLightingMessage(message) {\n          if (message.recipients === RECIPIENTS.INFO) return;\n          const fingerprint = this.lightingMessageFingerprint(message);\n          if (this.recentLightingMessages.includes(fingerprint)) return;\n          this.recentLightingMessages.push(fingerprint);\n          if (this.recentLightingMessages.length &gt; RECENT_LIGHTING_MESSAGE_LIMIT) {\n            this.recentLightingMessages.shift();\n          }\n        }\n\n        resetForIdConflict() {\n          const previous = this.id;\n          this.id = this.simulation.randomMeshId();\n          this.uplinkId = 0;\n          this.leaderId = this.id;\n          this.leaderViaId = this.id;\n          this.uplinkDeadline = 0;\n          this.lastUplinkSeenAt = null;\n          this.rebroadcastUntil = -1;\n          this.recentLightingMessages = [];\n          this.activeAt = this.simulation.time + Math.max(700, STATUS_TIMEOUT_BASE - this.id / 2);\n          this.nextBroadcastAt = this.activeAt + this.simulation.random() * STATUS_UPDATE_PERIOD;\n          this.nextPositionBroadcastAt = this.activeAt + this.simulation.random() * this.simulation.positionBroadcastPeriod;\n          this.resetPositionEstimate();\n          this.simulation.log(this, \"conflict\", `ID collision ${formatId(previous)} → ${formatId(this.id)}`);\n        }\n\n        hasFreshLeaderState() {\n          return !this.isFollowing()\n            || (this.leaderViaId !== 0 &amp;&amp; this.simulation.time &lt;= this.uplinkDeadline);\n        }\n\n        recordLeaderPath(physicalSenderId) {\n          if (!this.isFollowing() || !Number.isFinite(physicalSenderId)) return;\n          this.leaderViaId = physicalSenderId;\n          this.uplinkDeadline = this.simulation.time + UPLINK_TIMEOUT;\n          this.lastUplinkSeenAt = this.simulation.time;\n        }\n\n        observeNeighborLeaderPath(advertisedLeaderId, neighborLeaderViaId) {\n          if (!this.simulation.fixedRelay || !this.isFollowing() || !this.hasFreshLeaderState()) return;\n          if (!Number.isFinite(advertisedLeaderId) || !Number.isFinite(neighborLeaderViaId)) return;\n\n          const neighborHasWeakerLeader = advertisedLeaderId &lt; this.leaderId;\n          const neighborNeedsAnyRelay = advertisedLeaderId === this.leaderId\n            &amp;&amp; neighborLeaderViaId === 0;\n          const neighborUsesThisRelay = advertisedLeaderId === this.leaderId\n            &amp;&amp; neighborLeaderViaId === this.id;\n          if (neighborHasWeakerLeader || neighborNeedsAnyRelay || neighborUsesThisRelay) {\n            this.rebroadcastUntil = this.simulation.time + REBROADCAST_TIME;\n          }\n        }\n\n        onPeerPing(header, refreshUplink = true) {\n          if (header.id === this.id) {\n            this.resetForIdConflict();\n            return;\n          }\n\n          if (this.simulation.fixedRelay) {\n            const advertisedLeaderId = Math.max(header.id, header.uplinkId || 0);\n            if (advertisedLeaderId &gt; this.leaderId) this.follow(header);\n          } else if (header.id &gt; this.uplinkId &amp;&amp; header.id &gt; this.id) {\n            this.follow(header);\n          }\n\n          const heardLeaderId = this.simulation.fixedRelay\n            ? Math.max(header.id, header.uplinkId || 0)\n            : header.id;\n          if (refreshUplink &amp;&amp; heardLeaderId === this.uplinkId) {\n            this.uplinkDeadline = this.simulation.time + UPLINK_TIMEOUT;\n            this.lastUplinkSeenAt = this.simulation.time;\n          }\n\n          const neighborNeedsOurLeader = this.simulation.fixedRelay\n            &amp;&amp; this.isFollowing()\n            &amp;&amp; Math.max(header.id, header.uplinkId || 0) &lt; this.leaderId;\n          const legacyRelayTrigger = !this.simulation.fixedRelay\n            &amp;&amp; (header.uplinkId === this.id || (header.uplinkId === 0 &amp;&amp; header.id &lt; this.id));\n          if (neighborNeedsOurLeader || legacyRelayTrigger) {\n            this.rebroadcastUntil = this.simulation.time + REBROADCAST_TIME;\n          }\n        }\n\n        recipientDecision(message) {\n          switch (message.recipients) {\n            case RECIPIENTS.ALL:\n              return message.header.id === this.uplinkId\n                ? { accept: true, reason: \"chosen-uplink\" }\n                : { accept: false, reason: `sender-${formatId(message.header.id)}-is-not-uplink-${formatId(this.uplinkId)}` };\n            case RECIPIENTS.ROOT:\n              if (this.simulation.fixedRelay &amp;&amp; this.isRelayActive()) {\n                return { accept: true, reason: \"transparent-root-forward\" };\n              }\n              return message.header.uplinkId === this.id\n                ? { accept: true, reason: \"addressed-to-this-root\" }\n                : { accept: false, reason: `root-target-${formatId(message.header.uplinkId)}-does-not-match` };\n            case RECIPIENTS.INFO:\n              return { accept: true, reason: \"information-packet\" };\n            default:\n              return { accept: false, reason: \"unknown-recipient-class\" };\n          }\n        }\n\n        receive(message, strength, traceId, hop = 0, auditMeta = {}) {\n          const audit = this.simulation.beginReceiveAudit(this, message, strength, traceId, hop, auditMeta);\n          if (!message || !message.header) {\n            this.simulation.finishReceiveAudit(this, audit, {\n              outcome: \"rejected\",\n              reason: \"malformed-message\",\n              positionOutcome: null\n            });\n            return;\n          }\n          if (message.header.version !== this.version) {\n            this.simulation.finishReceiveAudit(this, audit, {\n              outcome: \"rejected\",\n              reason: `protocol-version-${message.header.version}-unsupported`,\n              positionOutcome: null\n            });\n            return;\n          }\n\n          if (\n            this.simulation.fixedRelay\n            &amp;&amp; message.recipients !== RECIPIENTS.INFO\n            &amp;&amp; this.hasSeenLightingMessage(message)\n          ) {\n            this.simulation.finishReceiveAudit(this, audit, {\n              outcome: \"ignored\",\n              reason: \"duplicate-transparent-relay-packet\",\n              positionOutcome: \"relayed-position-not-ranged\"\n            });\n            return;\n          }\n          if (this.simulation.fixedRelay) this.rememberLightingMessage(message);\n\n          this.receivedCount += 1;\n          const hadIdConflict = message.header.id === this.id;\n          this.onPeerPing(message.header, !this.simulation.fixedRelay);\n          const advertisedLeaderId = this.simulation.fixedRelay\n            ? Math.max(message.header.id, message.header.uplinkId || 0)\n            : message.header.id;\n          const positionOutcome = this.simulation.fixedRelay &amp;&amp; auditMeta.rebroadcast\n            ? \"relayed-position-not-ranged\"\n            : hadIdConflict\n            ? \"skipped-id-conflict\"\n            : this.receivePosition(message.position, strength, message.header.id, advertisedLeaderId);\n          const decision = this.recipientDecision(message);\n\n          if (!decision.accept) {\n            this.ignoredCount += 1;\n            this.simulation.finishReceiveAudit(this, audit, {\n              outcome: \"ignored\",\n              reason: decision.reason,\n              positionOutcome\n            });\n            return;\n          }\n\n          let appliedState = false;\n          if (message.recipients !== RECIPIENTS.ROOT || !this.isFollowing()) {\n            const isClockSource = message.header.id === this.uplinkId\n              &amp;&amp; message.command !== COMMAND.POSITION;\n            if (isClockSource) {\n              const sentAt = Number.isFinite(auditMeta.sentAt) ? auditMeta.sentAt : this.simulation.time;\n              const transitTime = Math.max(0, this.simulation.time - sentAt);\n              const corrected = message.timebase + transitTime - this.localMillis();\n              if (Math.abs(corrected - this.timebase) &gt; 10) this.timebase = corrected;\n            }\n\n            if (message.command === COMMAND.STATE &amp;&amp; message.data &amp;&amp; message.data.states) {\n              const beforeDNA = dnaKey(this.dna);\n              this.current = cloneTubeState(message.data.states.current);\n              this.next = cloneTubeState(message.data.states.next);\n              this.executedCount += 1;\n              appliedState = true;\n              if (this.simulation.fixedRelay &amp;&amp; message.header.id === this.uplinkId) {\n                this.recordLeaderPath(auditMeta.senderMeshId ?? message.header.id);\n              }\n              if (beforeDNA !== dnaKey(this.dna)) {\n                this.simulation.log(this, \"state\", `adopted now ${this.simulation.describeDNA(this.dna)}`);\n              }\n              this.simulation.log(\n                this,\n                \"schedule\",\n                `knows P${this.next.patternId}@${this.next.patternPhrase}, C${this.next.paletteId}@${this.next.palettePhrase}`\n              );\n            }\n          }\n\n          const shouldRelay = this.isRelayActive() &amp;&amp; message.recipients !== RECIPIENTS.INFO;\n          const receiveRecord = this.simulation.finishReceiveAudit(this, audit, {\n            outcome: \"accepted\",\n            reason: decision.reason,\n            positionOutcome,\n            appliedState,\n            relayed: false\n          });\n          if (shouldRelay) {\n            const relayMessage = {\n              logicalHeader: this.simulation.fixedRelay ? { ...message.header } : null,\n              logicalTimebase: this.simulation.fixedRelay ? message.timebase : null,\n              recipients: this.isFollowing() ? message.recipients : RECIPIENTS.ALL,\n              command: message.command,\n              data: cloneData(message.data)\n            };\n            const didRelay = this.simulation.broadcast(\n              this,\n              relayMessage,\n              traceId,\n              true,\n              hop + 1,\n              message.header.id\n            );\n            this.simulation.markAuditRelayed(receiveRecord, didRelay);\n          }\n        }\n\n        sendState() {\n          this.simulation.broadcast(this, {\n            recipients: RECIPIENTS.ALL,\n            command: COMMAND.STATE,\n            data: { states: this.snapshotStates() }\n          });\n        }\n\n        sendPosition() {\n          const sent = this.simulation.broadcast(this, {\n            recipients: RECIPIENTS.INFO,\n            command: COMMAND.POSITION,\n            data: null\n          });\n          if (sent) {\n            this.simulation.stats.positionTransmissions += 1;\n            this.simulation.stats.positionApplicationBytes += this.simulation.positionPacketBytes();\n          }\n        }\n\n        forceNext() {\n          const phrase = this.currentPhrase();\n          const nextPhrase = Math.min(this.next.patternPhrase, this.next.palettePhrase) - phrase;\n          this.next.patternPhrase -= nextPhrase;\n          this.next.palettePhrase -= nextPhrase;\n          this.sendState();\n        }\n\n        update(deltaMs) {\n          this.lockAnchorPosition();\n          this.current.beatFrame += deltaMs * this.current.bpm * BEAT_UNITS / 60000;\n          this.next.bpm = this.current.bpm;\n          this.next.beatFrame = this.current.beatFrame;\n          this.applyDueSchedule();\n\n          if (this.isFollowing() &amp;&amp; this.uplinkDeadline &amp;&amp; this.simulation.time &gt; this.uplinkDeadline) {\n            const auditBefore = this.simulation.auditNodeState(this);\n            this.follow(null);\n            this.simulation.auditLocalTransition(\n              this,\n              this.simulation.fixedRelay ? \"leader-state-timeout\" : \"uplink-timeout\",\n              auditBefore\n            );\n          }\n\n          while (this.simulation.time &gt;= this.nextBroadcastAt) {\n            this.nextBroadcastAt += STATUS_UPDATE_PERIOD;\n            if (this.status === STATUS.STARTED &amp;&amp; (!this.isFollowing() || this.simulation.random() &lt; 0.25)) {\n              this.sendState();\n            }\n          }\n\n          while (this.simulation.time &gt;= this.nextPositionBroadcastAt) {\n            this.nextPositionBroadcastAt += this.simulation.nextPositionInterval();\n            if (this.status === STATUS.STARTED) this.sendPosition();\n          }\n        }\n      }\n\n      class Simulation {\n        constructor() {\n          this.seed = 0x7A8E5;\n          this.rng = mulberry32(this.seed);\n          this.entities = [];\n          this.time = 0;\n          this.paused = false;\n          this.speed = 0.5;\n          this.range = 600;\n          this.dropoff = \"linear\";\n          this.deliveryModel = \"hard\";\n          this.fixedRelay = false;\n          this.rssiJitterSigmaDb = 0;\n          this.txPowerSigmaDb = 0;\n          this.linkShadowSigmaDb = 0;\n          this.leaderBpm = DEFAULT_BPM;\n          this.peerCapacity = 4;\n          this.solveCapacity = 4;\n          this.anchorReserve = 2;\n          this.positionStalePeriods = 6;\n          this.payloadProfileKey = \"balanced\";\n          this.coordinateEncodingKey = \"int12\";\n          this.coordinateQuantum = 5;\n          this.wireEnvelope = \"compact\";\n          this.positionBroadcastPeriod = POSITION_UPDATE_PERIOD;\n          this.positionBroadcastJitter = 0.12;\n          this.outlierErrorThreshold = PERSISTENT_OUTLIER_ERROR;\n          this.outlierDuration = PERSISTENT_OUTLIER_TIME;\n          this.currentTubeCount = 2;\n          this.currentAnchorCount = 0;\n          this.deliveryQueue = [];\n          this.waves = [];\n          this.pulses = [];\n          this.logs = [];\n          this.trace = 0;\n          this.messageAudit = [];\n          this.auditCountsByDeviceKey = new Map();\n          this.auditStatsByDeviceKey = new Map();\n          this.auditSequence = 0;\n          this.auditDeviceSequence = 0;\n          this.stats = this.emptyStats();\n          this.width = 900;\n          this.height = 600;\n        }\n\n        emptyStats() {\n          return {\n            eligible: 0,\n            delivered: 0,\n            dropped: 0,\n            rebroadcasts: 0,\n            peerEvictions: 0,\n            peerAdmissionDrops: 0,\n            positionTransmissions: 0,\n            positionApplicationBytes: 0,\n            coordinateSaturations: 0\n          };\n        }\n\n        payloadProfile() { return POSITION_PAYLOAD_PROFILES[this.payloadProfileKey]; }\n        coordinateEncoding() { return COORDINATE_ENCODINGS[this.coordinateEncodingKey]; }\n        positionPeerMaxAge() { return this.positionBroadcastPeriod * this.positionStalePeriods; }\n\n        positionPayloadBytes() {\n          return this.payloadProfile().fixedPayloadBytes\n            + this.coordinateEncoding().bytes\n            + LEADER_VIA_ID_BYTES;\n        }\n\n        positionPacketBytes() {\n          return this.wireEnvelope === \"fixed\"\n            ? CURRENT_NODE_MESSAGE_BYTES\n            : COMPACT_POSITION_ENVELOPE_BYTES + this.positionPayloadBytes();\n        }\n\n        peerEntryBytes() {\n          return this.payloadProfile().fixedPeerBytes + this.coordinateEncoding().bytes;\n        }\n\n        peerTableBytes() { return this.peerCapacity * this.peerEntryBytes(); }\n\n        coordinateMaximum() {\n          return ((2 ** (this.coordinateEncoding().bits - 1)) - 1) * this.coordinateQuantum;\n        }\n\n        positionTrafficBytesPerSecond() {\n          if (this.positionBroadcastPeriod &lt;= 0) return 0;\n          return this.entities.length * this.positionPacketBytes() * 1000 / this.positionBroadcastPeriod;\n        }\n\n        quantizeCoordinate(value) {\n          const encoding = this.coordinateEncoding();\n          const maximum = (2 ** (encoding.bits - 1)) - 1;\n          const minimum = -(2 ** (encoding.bits - 1));\n          const unbounded = Math.round(value / this.coordinateQuantum);\n          const encoded = clamp(unbounded, minimum, maximum);\n          if (encoded !== unbounded) this.stats.coordinateSaturations += 1;\n          return encoded * this.coordinateQuantum;\n        }\n\n        nextPositionInterval() {\n          const jitter = (this.random() * 2 - 1) * this.positionBroadcastJitter;\n          return this.positionBroadcastPeriod * (1 + jitter);\n        }\n\n        random() { return this.rng(); }\n        randomNormal() {\n          const firstUniform = Math.max(this.random(), Number.EPSILON);\n          const secondUniform = this.random();\n          return Math.sqrt(-2 * Math.log(firstUniform)) * Math.cos(2 * Math.PI * secondUniform);\n        }\n        randomInt(minimum, maximum) { return Math.floor(minimum + this.random() * (maximum - minimum)); }\n        randomMeshId() { return Math.floor(256 + this.random() * (4000 - 256)); }\n        randomDNA() {\n          return {\n            pattern: Math.floor(this.random() * PATTERNS.length),\n            palette: Math.floor(this.random() * PALETTES.length)\n          };\n        }\n\n        describeDNA(dna) { return `${PATTERNS[dna.pattern].name} / ${PALETTES[dna.palette].name}`; }\n\n        setBounds(width, height) {\n          this.width = Math.max(320, width);\n          this.height = Math.max(280, height);\n          for (const entity of this.entities) {\n            entity.x = clamp(entity.x, 45, this.width - 45);\n            entity.y = clamp(entity.y, 78, this.height - 72);\n          }\n        }\n\n        addDevice(x = this.width / 2, y = this.height / 2, options = {}) {\n          const entityX = clamp(x, 45, this.width - 45);\n          const entityY = clamp(y, 78, this.height - 72);\n          const entity = {\n            x: entityX,\n            y: entityY,\n            network: new TubeNode(this, this.time, {\n              isAnchor: options.isAnchor === true,\n              x: entityX,\n              y: entityY\n            }),\n            radioPowerStandardScore: clamp(\n              this.randomNormal(),\n              -MAX_RADIO_STANDARD_SCORE,\n              MAX_RADIO_STANDARD_SCORE\n            ),\n            radioEnvironmentKey: Math.floor(this.random() * 0xFFFFFFFF)\n          };\n          this.entities.push(entity);\n          const description = entity.network.isAnchor\n            ? `joined as fixed anchor at (${entityX.toFixed(0)}, ${entityY.toFixed(0)})`\n            : `joined simulation with ${this.describeDNA(entity.network.dna)}`;\n          this.log(entity.network, \"system\", description);\n          return entity;\n        }\n\n        addAnchor(x = this.width / 2, y = this.height / 2) {\n          return this.addDevice(x, y, { isAnchor: true });\n        }\n\n        removeEntity(entity) {\n          const index = this.entities.indexOf(entity);\n          if (index === -1) return false;\n\n          const node = entity.network;\n          this.log(node, \"system\", \"removed from simulation\");\n          this.entities.splice(index, 1);\n          this.deliveryQueue = this.deliveryQueue.filter(delivery =&gt; delivery.target !== node);\n          this.waves = this.waves.filter(wave =&gt; wave.sender !== entity);\n          this.pulses = this.pulses.filter(pulse =&gt; pulse.sender !== entity &amp;&amp; pulse.target !== entity);\n          return true;\n        }\n\n        clearNetwork(seed) {\n          this.seed = seed &gt;&gt;&gt; 0;\n          this.rng = mulberry32(this.seed);\n          this.entities = [];\n          this.time = 0;\n          this.deliveryQueue = [];\n          this.waves = [];\n          this.pulses = [];\n          this.logs = [];\n          this.trace = 0;\n          this.messageAudit = [];\n          this.auditCountsByDeviceKey = new Map();\n          this.auditStatsByDeviceKey = new Map();\n          this.auditSequence = 0;\n          this.auditDeviceSequence = 0;\n          this.stats = this.emptyStats();\n        }\n\n        loadScenario(tubeCount = this.currentTubeCount, anchorCount = this.currentAnchorCount) {\n          const tubes = clamp(Math.round(Number(tubeCount) || 1), 1, 128);\n          const anchors = clamp(Math.round(Number(anchorCount) || 0), 0, 16);\n          this.currentTubeCount = tubes;\n          this.currentAnchorCount = anchors;\n          const scenarioSeed = (\n            0x51A7E\n            ^ Math.imul(tubes, 0x45D9F3B)\n          ) &gt;&gt;&gt; 0;\n          this.clearNetwork(scenarioSeed);\n\n          const centerX = this.width / 2;\n          const centerY = this.height / 2;\n          let firstTube = null;\n          if (tubes === 1) {\n            firstTube = this.addDevice(centerX, centerY);\n          } else {\n            const goldenAngle = Math.PI * (3 - Math.sqrt(5));\n            const fieldRadius = Math.max(75, Math.min(this.width * 0.36, this.height * 0.36));\n            for (let index = 0; index &lt; tubes; index += 1) {\n              const radius = Math.sqrt((index + 0.5) / tubes) * fieldRadius;\n              const angle = index * goldenAngle;\n              const tube = this.addDevice(\n                centerX + Math.cos(angle) * radius,\n                centerY + Math.sin(angle) * radius\n              );\n              if (!firstTube) firstTube = tube;\n            }\n          }\n\n          const anchorRadiusX = Math.max(100, this.width * 0.4);\n          const anchorRadiusY = Math.max(90, this.height * 0.37);\n          for (let index = 0; index &lt; anchors; index += 1) {\n            const angle = -Math.PI / 2 + (index / anchors) * Math.PI * 2;\n            this.addAnchor(\n              centerX + Math.cos(angle) * anchorRadiusX,\n              centerY + Math.sin(angle) * anchorRadiusY\n            );\n          }\n          return firstTube || this.entities[0] || null;\n        }\n\n        reset() {\n          return this.loadScenario(this.currentTubeCount, this.currentAnchorCount);\n        }\n\n        clearField() {\n          this.clearNetwork(this.seed);\n        }\n\n        entityForNode(node) { return this.entities.find(entity =&gt; entity.network === node); }\n\n        distance(a, b) { return Math.hypot(a.x - b.x, a.y - b.y); }\n\n        localMaximumWarning(entity) {\n          if (this.fixedRelay) return null;\n          const node = entity.network;\n          if (node.isFollowing() || node.status !== STATUS.STARTED) return null;\n\n          const inRange = this.entities.filter(candidate =&gt;\n            candidate !== entity &amp;&amp; this.distance(entity, candidate) &lt; this.range\n          );\n          if (inRange.some(candidate =&gt; candidate.network.id &gt; node.id)) return null;\n\n          const bridges = inRange.filter(candidate =&gt;\n            candidate.network.id &lt; node.id &amp;&amp; candidate.network.uplinkId &gt; node.id\n          );\n          if (!bridges.length) return null;\n\n          const best = bridges.sort((a, b) =&gt; b.network.uplinkId - a.network.uplinkId)[0];\n          return {\n            type: \"local-maximum\",\n            nodeId: node.id,\n            relayId: best.network.id,\n            advertisedUplinkId: best.network.uplinkId,\n            distance: this.distance(entity, best),\n            explanation: `${formatId(node.id)} hears lower-ID ${formatId(best.network.id)}, which advertises higher uplink ${formatId(best.network.uplinkId)}. Current node.h compares only the immediate sender ID, so ${formatId(node.id)} remains leading.`\n          };\n        }\n\n        signalForNormalizedDistance(normalizedDistance, dropoff = this.dropoff) {\n          const n = clamp(normalizedDistance, 0, 1);\n          switch (dropoff) {\n            case \"quadratic\":\n              return (1 - n) ** 2;\n            case \"smooth\":\n              return 1 - (n * n * (3 - 2 * n));\n            case \"inverseSquare\": {\n              const raw = 1 / (1 + 8 * n * n);\n              const edge = 1 / 9;\n              return clamp((raw - edge) / (1 - edge), 0, 1);\n            }\n            case \"linear\":\n            default:\n              return 1 - n;\n          }\n        }\n\n        signalAtDistance(distance, range = this.range, dropoff = this.dropoff) {\n          if (distance &gt;= range) return 0;\n          return this.signalForNormalizedDistance(distance / range, dropoff);\n        }\n\n        packetDeliveryProbability(meanStrength) {\n          if (meanStrength &lt;= 0) return 0;\n          if (this.deliveryModel === \"hard\") return 1;\n          if (this.deliveryModel === \"proportional\") return meanStrength;\n\n          const thresholdProgress = clamp((meanStrength - 0.08) / 0.24, 0, 1);\n          return thresholdProgress * thresholdProgress * (3 - 2 * thresholdProgress);\n        }\n\n        stableUnitInterval(senderKey, targetKey, salt) {\n          const lowKey = Math.min(senderKey, targetKey);\n          const highKey = Math.max(senderKey, targetKey);\n          let hash = Math.imul(lowKey, 0x45D9F3B) ^ Math.imul(highKey, 0x119DE1F3) ^ salt;\n          hash ^= hash &gt;&gt;&gt; 16;\n          hash = Math.imul(hash, 0x45D9F3B);\n          hash ^= hash &gt;&gt;&gt; 16;\n          return ((hash &gt;&gt;&gt; 0) + 1) / 0x100000001;\n        }\n\n        linkEnvironmentStandardScore(senderKey, targetKey) {\n          const firstUniform = this.stableUnitInterval(senderKey, targetKey, 0x51ED270B);\n          const secondUniform = this.stableUnitInterval(senderKey, targetKey, 0x1B873593);\n          const standardScore = Math.sqrt(-2 * Math.log(firstUniform))\n            * Math.cos(2 * Math.PI * secondUniform);\n          return clamp(standardScore, -MAX_RADIO_STANDARD_SCORE, MAX_RADIO_STANDARD_SCORE);\n        }\n\n        meanSignalBetween(senderEntity, targetEntity, distance) {\n          const distanceStrength = this.signalAtDistance(distance, this.range, this.dropoff);\n          if (distanceStrength &lt;= 0) return 0;\n\n          // Device and link biases stay fixed while RSSI measurement noise is sampled for every received packet.\n          const transmitterBiasDb = senderEntity.radioPowerStandardScore * this.txPowerSigmaDb;\n          const linkStandardScore = this.linkEnvironmentStandardScore(\n            senderEntity.radioEnvironmentKey,\n            targetEntity.radioEnvironmentKey\n          );\n          const linkBiasDb = linkStandardScore * this.linkShadowSigmaDb;\n          return clamp(distanceStrength * dbToPowerRatio(transmitterBiasDb + linkBiasDb), 0, 1);\n        }\n\n        measuredSignalStrength(meanStrength) {\n          const sampleNoiseDb = this.randomNormal() * this.rssiJitterSigmaDb;\n          return clamp(meanStrength * dbToPowerRatio(sampleNoiseDb), 0, 1);\n        }\n\n        distanceFromSignalStrength(strength) {\n          const targetStrength = clamp(strength, 0, 1);\n          let near = 0;\n          let far = this.range;\n          for (let iteration = 0; iteration &lt; 24; iteration += 1) {\n            const candidate = (near + far) / 2;\n            const candidateStrength = this.signalAtDistance(candidate, this.range, this.dropoff);\n            if (candidateStrength &gt; targetStrength) near = candidate;\n            else far = candidate;\n          }\n          return (near + far) / 2;\n        }\n\n        commandName(command) {\n          if (command === COMMAND.STATE) return \"STATE\";\n          if (command === COMMAND.POSITION) return \"POSITION\";\n          if (command === COMMAND.INFO) return \"INFO\";\n          return \"ACTION\";\n        }\n\n        auditNodeState(node) {\n          const logicalLeaderId = this.fixedRelay\n            ? (node.uplinkId || node.id)\n            : node.leaderId;\n          return {\n            meshId: node.id,\n            uplinkId: this.fixedRelay ? null : node.uplinkId,\n            leaderId: logicalLeaderId,\n            leaderViaId: this.fixedRelay ? node.leaderViaId : null,\n            leaderPath: this.fixedRelay\n              ? !node.isFollowing()\n                ? \"self\"\n                : node.leaderViaId === 0\n                ? \"waiting\"\n                : node.leaderViaId === logicalLeaderId ? \"direct\" : \"relayed\"\n              : \"legacy-uplink\",\n            role: node.role(),\n            transportStatus: node.status,\n            relayActive: node.isRelayActive(),\n            dna: {\n              pattern: node.current.patternId,\n              patternName: PATTERNS[node.current.patternId]?.name || null,\n              palette: node.current.paletteId,\n              paletteName: PALETTES[node.current.paletteId]?.name || null\n            },\n            current: cloneTubeState(node.current),\n            next: cloneTubeState(node.next),\n            position: {\n              frameId: node.positionEstimate.frameId,\n              solution: node.positionEstimate.solution,\n              x: +node.positionEstimate.x.toFixed(3),\n              y: +node.positionEstimate.y.toFixed(3),\n              confidence: +node.positionEstimate.confidence.toFixed(4)\n            },\n            clock: {\n              timebase: +node.timebase.toFixed(3),\n              visualTime: +node.visualTime().toFixed(3),\n              beatFrame: +node.current.beatFrame.toFixed(3)\n            }\n          };\n        }\n\n        auditMessage(message) {\n          if (!message || !message.header) return null;\n          return {\n            header: { ...message.header },\n            recipients: message.recipients,\n            recipientsName: this.recipientName(message.recipients),\n            command: message.command,\n            commandName: this.commandName(message.command),\n            timebase: message.timebase,\n            data: cloneData(message.data),\n            position: message.position ? { ...message.position } : null\n          };\n        }\n\n        appendAudit(event) {\n          const record = {\n            sequence: ++this.auditSequence,\n            atMs: Math.round(this.time),\n            ...event\n          };\n          this.messageAudit.push(record);\n          const count = this.auditCountsByDeviceKey.get(record.deviceKey) || 0;\n          this.auditCountsByDeviceKey.set(record.deviceKey, count + 1);\n          const stats = this.auditStatsByDeviceKey.get(record.deviceKey) || {\n            total: 0,\n            sent: 0,\n            received: 0,\n            accepted: 0,\n            ignored: 0,\n            rejected: 0,\n            radioMisses: 0,\n            appliedStates: 0,\n            relayed: 0,\n            localTransitions: 0\n          };\n          stats.total += 1;\n          if (record.kind === \"send\") stats.sent += 1;\n          if (record.kind === \"receive\") stats.received += 1;\n          if (record.kind === \"radio-drop\") stats.radioMisses += 1;\n          if (record.kind === \"local-transition\") stats.localTransitions += 1;\n          if (record.outcome === \"accepted\") stats.accepted += 1;\n          if (record.outcome === \"ignored\") stats.ignored += 1;\n          if (record.outcome === \"rejected\") stats.rejected += 1;\n          if (record.appliedState) stats.appliedStates += 1;\n          if (record.relayed) stats.relayed += 1;\n          this.auditStatsByDeviceKey.set(record.deviceKey, stats);\n          return record;\n        }\n\n        markAuditRelayed(record, relayed) {\n          record.relayed = relayed;\n          if (!relayed) return;\n          const stats = this.auditStatsByDeviceKey.get(record.deviceKey);\n          if (stats) stats.relayed += 1;\n        }\n\n        auditSend(sender, messageSnapshot, traceId, hop, rebroadcast, behalfOfId) {\n          return this.appendAudit({\n            kind: \"send\",\n            deviceKey: sender.auditDeviceKey,\n            deviceId: sender.id,\n            peerKey: null,\n            peerId: null,\n            traceId,\n            hop,\n            rebroadcast,\n            behalfOfId,\n            outcome: \"broadcast\",\n            reason: rebroadcast ? \"relay-on-behalf\" : \"originated\",\n            message: messageSnapshot,\n            before: this.auditNodeState(sender),\n            after: null,\n            radio: null\n          });\n        }\n\n        auditRadioDrop(\n          sender,\n          target,\n          messageSnapshot,\n          traceId,\n          hop,\n          distance,\n          meanStrength,\n          rebroadcast,\n          behalfOfId,\n          reason = \"radio-probability-drop\"\n        ) {\n          return this.appendAudit({\n            kind: \"radio-drop\",\n            deviceKey: target.auditDeviceKey,\n            deviceId: target.id,\n            peerKey: sender.auditDeviceKey,\n            peerId: sender.id,\n            traceId,\n            hop,\n            rebroadcast,\n            behalfOfId,\n            outcome: \"not-received\",\n            reason,\n            message: messageSnapshot,\n            before: this.auditNodeState(target),\n            after: null,\n            radio: {\n              distance: +distance.toFixed(3),\n              meanStrength: +meanStrength.toFixed(5),\n              deliveryProbability: +this.packetDeliveryProbability(meanStrength).toFixed(5),\n              measuredStrength: null\n            }\n          });\n        }\n\n        beginReceiveAudit(target, message, strength, traceId, hop, auditMeta = {}) {\n          return {\n            kind: \"receive\",\n            deviceKey: target.auditDeviceKey,\n            deviceId: target.id,\n            peerKey: auditMeta.senderDeviceKey ?? null,\n            peerId: message?.header?.id ?? null,\n            physicalPeerId: auditMeta.senderMeshId ?? null,\n            traceId,\n            hop,\n            rebroadcast: auditMeta.rebroadcast === true,\n            behalfOfId: auditMeta.behalfOfId ?? null,\n            message: auditMeta.messageSnapshot || this.auditMessage(message),\n            before: this.auditNodeState(target),\n            radio: {\n              transmitterId: auditMeta.senderMeshId ?? null,\n              distance: Number.isFinite(auditMeta.distance) ? +auditMeta.distance.toFixed(3) : null,\n              meanStrength: Number.isFinite(auditMeta.meanStrength) ? +auditMeta.meanStrength.toFixed(5) : null,\n              deliveryProbability: Number.isFinite(auditMeta.deliveryProbability)\n                ? +auditMeta.deliveryProbability.toFixed(5)\n                : null,\n              measuredStrength: Number.isFinite(strength) ? +strength.toFixed(5) : null\n            }\n          };\n        }\n\n        finishReceiveAudit(target, audit, result) {\n          return this.appendAudit({\n            ...audit,\n            outcome: result.outcome,\n            reason: result.reason,\n            positionOutcome: result.positionOutcome || null,\n            appliedState: result.appliedState === true,\n            relayed: result.relayed === true,\n            after: this.auditNodeState(target)\n          });\n        }\n\n        auditLocalTransition(node, reason, before, details = null) {\n          return this.appendAudit({\n            kind: \"local-transition\",\n            deviceKey: node.auditDeviceKey,\n            deviceId: node.id,\n            peerKey: null,\n            peerId: null,\n            traceId: null,\n            hop: 0,\n            rebroadcast: false,\n            behalfOfId: null,\n            outcome: \"local-state-change\",\n            reason,\n            positionOutcome: null,\n            appliedState: false,\n            relayed: false,\n            message: null,\n            before,\n            after: this.auditNodeState(node),\n            radio: null,\n            details\n          });\n        }\n\n        recentAuditForNode(node, limit = 12) {\n          const records = [];\n          for (let index = this.messageAudit.length - 1; index &gt;= 0 &amp;&amp; records.length &lt; limit; index -= 1) {\n            const event = this.messageAudit[index];\n            if (event.deviceKey === node.auditDeviceKey) records.push(event);\n          }\n          return records;\n        }\n\n        auditForNode(node) {\n          return this.messageAudit.filter(event =&gt; event.deviceKey === node.auditDeviceKey);\n        }\n\n        auditCountForNode(node) {\n          return this.auditCountsByDeviceKey.get(node.auditDeviceKey) || 0;\n        }\n\n        auditStatsForNode(node) {\n          return this.auditStatsByDeviceKey.get(node.auditDeviceKey) || {\n            total: 0,\n            sent: 0,\n            received: 0,\n            accepted: 0,\n            ignored: 0,\n            rejected: 0,\n            radioMisses: 0,\n            appliedStates: 0,\n            relayed: 0,\n            localTransitions: 0\n          };\n        }\n\n        queryMessageAudit(filters = {}) {\n          const requestedDeviceId = typeof filters.deviceId === \"string\"\n            ? Number.parseInt(filters.deviceId, 16)\n            : filters.deviceId;\n          let events = this.messageAudit.filter(event =&gt; {\n            if (Number.isFinite(filters.deviceKey) &amp;&amp; event.deviceKey !== filters.deviceKey) return false;\n            if (Number.isFinite(requestedDeviceId) &amp;&amp; event.deviceId !== requestedDeviceId) return false;\n            if (Number.isFinite(filters.traceId) &amp;&amp; event.traceId !== filters.traceId) return false;\n            if (filters.kind &amp;&amp; event.kind !== filters.kind) return false;\n            if (filters.outcome &amp;&amp; event.outcome !== filters.outcome) return false;\n            if (filters.command &amp;&amp; event.message?.commandName !== filters.command) return false;\n            return true;\n          });\n          if (Number.isFinite(filters.limit) &amp;&amp; filters.limit &gt;= 0) {\n            events = events.slice(-Math.floor(filters.limit));\n          }\n          return events;\n        }\n\n        broadcast(sender, partialMessage, inheritedTrace = null, rebroadcast = false, hop = 0, behalfOfId = null) {\n          if (sender.status !== STATUS.STARTED) return false;\n          const senderEntity = this.entityForNode(sender);\n          if (!senderEntity) return false;\n\n          const traceId = inheritedTrace || ++this.trace;\n          const transparentRelay = this.fixedRelay\n            &amp;&amp; rebroadcast\n            &amp;&amp; partialMessage.logicalHeader;\n          const message = {\n            header: transparentRelay ? { ...partialMessage.logicalHeader } : {\n              id: sender.id,\n              uplinkId: sender.uplinkId,\n              version: sender.version\n            },\n            recipients: partialMessage.recipients,\n            timebase: transparentRelay ? partialMessage.logicalTimebase : sender.visualTime(),\n            command: partialMessage.command,\n            data: cloneData(partialMessage.data),\n            position: transparentRelay ? null : sender.announcePosition()\n          };\n          if (this.fixedRelay) sender.rememberLightingMessage(message);\n          const auditedMessage = this.auditMessage(message);\n          this.auditSend(sender, auditedMessage, traceId, hop, rebroadcast, behalfOfId);\n\n          if (!rebroadcast) {\n            const commandName = this.commandName(message.command);\n            const detail = message.command === COMMAND.STATE\n              ? ` now ${this.describeDNA(sender.dna)}; next P${sender.next.patternId}@${sender.next.patternPhrase}, C${sender.next.paletteId}@${sender.next.palettePhrase}`\n              : \"\";\n            this.log(sender, \"tx\", `broadcast ${commandName}:${this.recipientName(message.recipients)}${detail}`);\n          } else {\n            this.stats.rebroadcasts += 1;\n            const commandName = this.commandName(message.command);\n            this.log(\n              sender,\n              \"relay\",\n              `rebroadcast ${commandName}:${this.recipientName(message.recipients)} from logical leader ${formatId(message.header.id)} via physical ${formatId(sender.id)} · hop ${hop} · trace #${traceId}`\n            );\n          }\n\n          this.waves.push({\n            sender: senderEntity,\n            start: this.time,\n            end: this.time + RADIO_WAVE_TIME,\n            range: this.range,\n            dropoff: this.dropoff,\n            traceId,\n            rebroadcast,\n            hop,\n            behalfOfId\n          });\n\n          for (const targetEntity of this.entities) {\n            if (targetEntity.network === sender) continue;\n            const distance = this.distance(senderEntity, targetEntity);\n            const meanStrength = this.meanSignalBetween(senderEntity, targetEntity, distance);\n            if (meanStrength &lt;= 0) {\n              this.auditRadioDrop(\n                sender,\n                targetEntity.network,\n                auditedMessage,\n                traceId,\n                hop,\n                distance,\n                0,\n                rebroadcast,\n                behalfOfId,\n                \"outside-hard-range\"\n              );\n              continue;\n            }\n\n            this.stats.eligible += 1;\n            const deliveryProbability = this.packetDeliveryProbability(meanStrength);\n            const success = this.random() &lt; deliveryProbability;\n            const start = this.time + (distance / this.range) * RADIO_WAVE_TIME;\n            const end = start + 260;\n            this.pulses.push({ sender: senderEntity, target: targetEntity, success, strength: meanStrength, start, end, traceId, rebroadcast, hop, behalfOfId });\n\n            if (!success) {\n              this.stats.dropped += 1;\n              this.auditRadioDrop(\n                sender,\n                targetEntity.network,\n                auditedMessage,\n                traceId,\n                hop,\n                distance,\n                meanStrength,\n                rebroadcast,\n                behalfOfId\n              );\n              continue;\n            }\n\n            this.stats.delivered += 1;\n            const measuredStrength = this.measuredSignalStrength(meanStrength);\n            this.deliveryQueue.push({\n              at: this.time,\n              target: targetEntity.network,\n              message: {\n                header: { ...message.header },\n                recipients: message.recipients,\n                timebase: message.timebase,\n                command: message.command,\n                data: cloneData(message.data),\n                position: message.position ? { ...message.position } : null\n              },\n              strength: measuredStrength,\n              traceId,\n              hop,\n              auditMeta: {\n                senderDeviceKey: sender.auditDeviceKey,\n                senderMeshId: sender.id,\n                rebroadcast,\n                behalfOfId,\n                distance,\n                meanStrength,\n                deliveryProbability,\n                sentAt: this.time,\n                messageSnapshot: auditedMessage\n              }\n            });\n          }\n          return true;\n        }\n\n        recipientName(value) {\n          return value === RECIPIENTS.ROOT ? \"ROOT\" : value === RECIPIENTS.INFO ? \"INFO\" : \"ALL\";\n        }\n\n        log(node, type, message) {\n          this.logs.unshift({ at: this.time, node, type, message });\n          if (this.logs.length &gt; 100) this.logs.length = 100;\n        }\n\n        deliverReadyPackets() {\n          this.deliveryQueue.sort((a, b) =&gt; a.at - b.at);\n          while (this.deliveryQueue.length &amp;&amp; this.deliveryQueue[0].at &lt;= this.time) {\n            const delivery = this.deliveryQueue.shift();\n            delivery.target.receive(\n              delivery.message,\n              delivery.strength,\n              delivery.traceId,\n              delivery.hop,\n              delivery.auditMeta\n            );\n          }\n        }\n\n        update(realDeltaMs) {\n          if (this.paused) return;\n          const delta = Math.min(realDeltaMs, 80) * this.speed;\n          this.time += delta;\n\n          this.deliverReadyPackets();\n          for (const entity of this.entities) entity.network.update(delta);\n          this.deliverReadyPackets();\n          this.waves = this.waves.filter(wave =&gt; wave.end &gt; this.time);\n          this.pulses = this.pulses.filter(pulse =&gt; pulse.end &gt; this.time);\n        }\n      }\n\n      const canvas = document.getElementById(\"spaceCanvas\");\n      const context = canvas.getContext(\"2d\");\n      const space = document.getElementById(\"space\");\n      const simulation = new Simulation();\n      let evaluator = null;\n      let selected = null;\n      let dragging = null;\n      let panning = null;\n      let dragOffset = { x: 0, y: 0 };\n      let canvasPixelRatio = 1;\n      const camera = { x: 0, y: 0, zoom: 1 };\n      const displayRegistrationByFrame = new Map();\n      let lastFrame = performance.now();\n      let inspectorLastUpdated = 0;\n      let diagnosticsLastUpdated = 0;\n\n      const ui = {\n        addDevice: document.getElementById(\"addDevice\"),\n        addAnchor: document.getElementById(\"addAnchor\"),\n        addEight: document.getElementById(\"addEight\"),\n        pauseToggle: document.getElementById(\"pauseToggle\"),\n        resetSimulation: document.getElementById(\"resetSimulation\"),\n        clearSimulation: document.getElementById(\"clearSimulation\"),\n        rangeControl: document.getElementById(\"rangeControl\"),\n        rangeOutput: document.getElementById(\"rangeOutput\"),\n        dropoffControl: document.getElementById(\"dropoffControl\"),\n        deliveryModelControl: document.getElementById(\"deliveryModelControl\"),\n        rssiJitterControl: document.getElementById(\"rssiJitterControl\"),\n        rssiJitterOutput: document.getElementById(\"rssiJitterOutput\"),\n        rssiJitterPreset: document.getElementById(\"rssiJitterPreset\"),\n        txSpreadControl: document.getElementById(\"txSpreadControl\"),\n        txSpreadOutput: document.getElementById(\"txSpreadOutput\"),\n        txSpreadPreset: document.getElementById(\"txSpreadPreset\"),\n        linkBiasControl: document.getElementById(\"linkBiasControl\"),\n        linkBiasOutput: document.getElementById(\"linkBiasOutput\"),\n        linkBiasPreset: document.getElementById(\"linkBiasPreset\"),\n        speedControl: document.getElementById(\"speedControl\"),\n        speedOutput: document.getElementById(\"speedOutput\"),\n        bpmControl: document.getElementById(\"bpmControl\"),\n        bpmOutput: document.getElementById(\"bpmOutput\"),\n        forceNext: document.getElementById(\"forceNext\"),\n        showTopology: document.getElementById(\"showTopology\"),\n        showRadio: document.getElementById(\"showRadio\"),\n        showSignalWaves: document.getElementById(\"showSignalWaves\"),\n        showEstimates: document.getElementById(\"showEstimates\"),\n        fixedRelay: document.getElementById(\"fixedRelay\"),\n        scenarioDeviceCount: document.getElementById(\"scenarioDeviceCount\"),\n        scenarioAnchorCount: document.getElementById(\"scenarioAnchorCount\"),\n        runScenario: document.getElementById(\"runScenario\"),\n        peerCapacityControl: document.getElementById(\"peerCapacityControl\"),\n        peerCapacityOutput: document.getElementById(\"peerCapacityOutput\"),\n        solveCapacityControl: document.getElementById(\"solveCapacityControl\"),\n        solveCapacityOutput: document.getElementById(\"solveCapacityOutput\"),\n        anchorReserveControl: document.getElementById(\"anchorReserveControl\"),\n        anchorReserveOutput: document.getElementById(\"anchorReserveOutput\"),\n        payloadProfileControl: document.getElementById(\"payloadProfileControl\"),\n        coordinateEncodingControl: document.getElementById(\"coordinateEncodingControl\"),\n        coordinateQuantumControl: document.getElementById(\"coordinateQuantumControl\"),\n        wireEnvelopeControl: document.getElementById(\"wireEnvelopeControl\"),\n        positionPeriodControl: document.getElementById(\"positionPeriodControl\"),\n        positionPeriodOutput: document.getElementById(\"positionPeriodOutput\"),\n        outlierErrorControl: document.getElementById(\"outlierErrorControl\"),\n        outlierErrorOutput: document.getElementById(\"outlierErrorOutput\"),\n        outlierTimeControl: document.getElementById(\"outlierTimeControl\"),\n        outlierTimeOutput: document.getElementById(\"outlierTimeOutput\"),\n        evaluationNote: document.getElementById(\"evaluationNote\"),\n        selectedId: document.getElementById(\"selectedId\"),\n        selectedKind: document.getElementById(\"selectedKind\"),\n        selectedRole: document.getElementById(\"selectedRole\"),\n        dnaCard: document.getElementById(\"dnaCard\"),\n        lightingScheduleSection: document.getElementById(\"lightingScheduleSection\"),\n        dnaStrip: document.getElementById(\"dnaStrip\"),\n        dnaCode: document.getElementById(\"dnaCode\"),\n        dnaName: document.getElementById(\"dnaName\"),\n        topologyWarning: document.getElementById(\"topologyWarning\"),\n        factId: document.getElementById(\"factId\"),\n        leaderFactLabel: document.getElementById(\"leaderFactLabel\"),\n        factUplink: document.getElementById(\"factUplink\"),\n        factLeaderPath: document.getElementById(\"factLeaderPath\"),\n        factState: document.getElementById(\"factState\"),\n        factRelay: document.getElementById(\"factRelay\"),\n        factLastHeard: document.getElementById(\"factLastHeard\"),\n        factEstimate: document.getElementById(\"factEstimate\"),\n        factEstimateFrame: document.getElementById(\"factEstimateFrame\"),\n        factPositionMode: document.getElementById(\"factPositionMode\"),\n        factPeerTable: document.getElementById(\"factPeerTable\"),\n        factClock: document.getElementById(\"factClock\"),\n        factNextPattern: document.getElementById(\"factNextPattern\"),\n        factNextPalette: document.getElementById(\"factNextPalette\"),\n        factBpm: document.getElementById(\"factBpm\"),\n        relayExplanation: document.getElementById(\"relayExplanation\"),\n        patternProgressLabel: document.getElementById(\"patternProgressLabel\"),\n        patternProgressValue: document.getElementById(\"patternProgressValue\"),\n        patternProgressTrack: document.getElementById(\"patternProgressTrack\"),\n        patternProgressFill: document.getElementById(\"patternProgressFill\"),\n        paletteProgressLabel: document.getElementById(\"paletteProgressLabel\"),\n        paletteProgressValue: document.getElementById(\"paletteProgressValue\"),\n        paletteProgressTrack: document.getElementById(\"paletteProgressTrack\"),\n        paletteProgressFill: document.getElementById(\"paletteProgressFill\"),\n        factPosition: document.getElementById(\"factPosition\"),\n        factNeighbors: document.getElementById(\"factNeighbors\"),\n        factSignal: document.getElementById(\"factSignal\"),\n        qualityChart: document.getElementById(\"qualityChart\"),\n        factEvaluationCoverage: document.getElementById(\"factEvaluationCoverage\"),\n        factWorstError: document.getElementById(\"factWorstError\"),\n        factPeerEvictions: document.getElementById(\"factPeerEvictions\"),\n        factPeerDrops: document.getElementById(\"factPeerDrops\"),\n        factWireBytes: document.getElementById(\"factWireBytes\"),\n        factCoordinateRange: document.getElementById(\"factCoordinateRange\"),\n        factTableBytes: document.getElementById(\"factTableBytes\"),\n        outlierList: document.getElementById(\"outlierList\"),\n        copySelectedAudit: document.getElementById(\"copySelectedAudit\"),\n        copyRunAudit: document.getElementById(\"copyRunAudit\"),\n        auditCopyStatus: document.getElementById(\"auditCopyStatus\"),\n        factAuditEvents: document.getElementById(\"factAuditEvents\"),\n        factAuditTraffic: document.getElementById(\"factAuditTraffic\"),\n        factAuditDecisions: document.getElementById(\"factAuditDecisions\"),\n        factAuditDrops: document.getElementById(\"factAuditDrops\"),\n        factAuditApplied: document.getElementById(\"factAuditApplied\"),\n        factAuditRelays: document.getElementById(\"factAuditRelays\"),\n        messageAuditList: document.getElementById(\"messageAuditList\"),\n        copySnapshot: document.getElementById(\"copySnapshot\"),\n        mirrorSnapshot: document.getElementById(\"mirrorSnapshot\"),\n        copyStatus: document.getElementById(\"copyStatus\"),\n        debugSnapshot: document.getElementById(\"debugSnapshot\"),\n        positionKnowledgeList: document.getElementById(\"positionKnowledgeList\"),\n        trafficList: document.getElementById(\"trafficList\")\n      };\n\n      function resizeCanvas() {\n        const rect = space.getBoundingClientRect();\n        canvasPixelRatio = Math.min(window.devicePixelRatio || 1, 2);\n        canvas.width = Math.max(1, Math.floor(rect.width * canvasPixelRatio));\n        canvas.height = Math.max(1, Math.floor(rect.height * canvasPixelRatio));\n        canvas.style.width = `${rect.width}px`;\n        canvas.style.height = `${rect.height}px`;\n        context.setTransform(canvasPixelRatio, 0, 0, canvasPixelRatio, 0, 0);\n        simulation.setBounds(rect.width, rect.height);\n      }\n\n      function addDeviceAt(x, y) {\n        selected = simulation.addDevice(x, y);\n        updateInspector(true);\n      }\n\n      function addAnchorAt(x, y) {\n        selected = simulation.addAnchor(x, y);\n        updateInspector(true);\n      }\n\n      function addNearCenter(count) {\n        const centerX = simulation.width / 2;\n        const centerY = simulation.height / 2;\n        for (let index = 0; index &lt; count; index += 1) {\n          const angle = (index / Math.max(count, 1)) * Math.PI * 2 + simulation.random() * 0.35;\n          const radius = 85 + simulation.random() * Math.min(230, simulation.width * 0.28);\n          addDeviceAt(centerX + Math.cos(angle) * radius, centerY + Math.sin(angle) * radius);\n        }\n      }\n\n      function screenPoint(event) {\n        const rect = canvas.getBoundingClientRect();\n        return { x: event.clientX - rect.left, y: event.clientY - rect.top };\n      }\n\n      function worldPoint(screen) {\n        return {\n          x: (screen.x - camera.x) / camera.zoom,\n          y: (screen.y - camera.y) / camera.zoom\n        };\n      }\n\n      function resetCamera() {\n        camera.x = 0;\n        camera.y = 0;\n        camera.zoom = 1;\n      }\n\n      function resetDisplayRegistration() {\n        displayRegistrationByFrame.clear();\n      }\n\n      function hitTest(point) {\n        for (let index = simulation.entities.length - 1; index &gt;= 0; index -= 1) {\n          const entity = simulation.entities[index];\n          const halfWidth = entity.network.isAnchor ? 25 : 27;\n          const halfHeight = entity.network.isAnchor ? 25 : 68;\n          if (Math.abs(point.x - entity.x) &lt;= halfWidth &amp;&amp; Math.abs(point.y - entity.y) &lt;= halfHeight) return entity;\n        }\n        return null;\n      }\n\n      function bindDecibelControl(control, output, preset, simulationProperty) {\n        const applyValue = () =&gt; {\n          const decibels = Number(control.value);\n          simulation[simulationProperty] = decibels;\n          output.value = formatDecibels(decibels);\n        };\n        control.addEventListener(\"input\", applyValue);\n        preset.addEventListener(\"click\", () =&gt; {\n          control.value = preset.dataset.value;\n          applyValue();\n        });\n        applyValue();\n      }\n\n      async function copyJSON(value, successLabel) {\n        const text = JSON.stringify(value, null, 2);\n        try {\n          if (navigator.clipboard &amp;&amp; navigator.clipboard.writeText) {\n            await navigator.clipboard.writeText(text);\n          } else {\n            const textarea = document.createElement(\"textarea\");\n            textarea.value = text;\n            textarea.style.position = \"fixed\";\n            textarea.style.opacity = \"0\";\n            document.body.appendChild(textarea);\n            textarea.select();\n            document.execCommand(\"copy\");\n            textarea.remove();\n          }\n          ui.copyStatus.textContent = successLabel;\n          ui.auditCopyStatus.textContent = successLabel;\n        } catch (error) {\n          ui.copyStatus.textContent = \"Copy unavailable\";\n          ui.auditCopyStatus.textContent = \"Copy unavailable\";\n        }\n        setTimeout(() =&gt; {\n          ui.copyStatus.textContent = \"\";\n          ui.auditCopyStatus.textContent = \"\";\n        }, 1600);\n      }\n\n      function resetEvaluation() {\n        if (!evaluator) return;\n        evaluator.reset();\n        evaluator.update();\n        updateEvaluationUI();\n      }\n\n      function showEmptyField() {\n        ui.selectedKind.textContent = \"Field empty\";\n        ui.selectedId.textContent = \"---\";\n        ui.selectedRole.textContent = \"No device\";\n        ui.dnaCard.hidden = true;\n        ui.lightingScheduleSection.hidden = true;\n        ui.topologyWarning.hidden = true;\n        ui.factId.textContent = \"---\";\n        ui.factUplink.textContent = \"none\";\n        ui.factLeaderPath.textContent = \"—\";\n        ui.factState.textContent = \"no device\";\n        ui.factRelay.textContent = \"inactive\";\n        ui.factLastHeard.textContent = \"never\";\n        ui.factEstimate.textContent = \"—\";\n        ui.factEstimateFrame.textContent = \"—\";\n        ui.factPositionMode.textContent = \"—\";\n        ui.factPeerTable.textContent = `0 / ${simulation.peerCapacity}`;\n        ui.factClock.textContent = \"—\";\n        ui.factPosition.textContent = \"—\";\n        ui.factNeighbors.textContent = \"0\";\n        ui.factSignal.textContent = \"none\";\n        for (const list of [ui.positionKnowledgeList, ui.trafficList, ui.messageAuditList]) {\n          list.replaceChildren();\n          const item = document.createElement(\"li\");\n          item.className = \"empty-state\";\n          item.textContent = \"The field is empty.\";\n          list.appendChild(item);\n        }\n        ui.factAuditEvents.textContent = \"0\";\n        ui.factAuditTraffic.textContent = \"0 / 0\";\n        ui.factAuditDecisions.textContent = \"0 / 0\";\n        ui.factAuditDrops.textContent = \"0\";\n        ui.factAuditApplied.textContent = \"0\";\n        ui.factAuditRelays.textContent = \"0 / 0\";\n      }\n\n      function runSelectedScenario() {\n        resetCamera();\n        resetDisplayRegistration();\n        selected = simulation.loadScenario(\n          Number(ui.scenarioDeviceCount.value),\n          Number(ui.scenarioAnchorCount.value)\n        );\n        resetEvaluation();\n        updateInspector(true);\n        updateDiagnostics(performance.now(), true);\n      }\n\n      function clearCurrentField() {\n        resetCamera();\n        resetDisplayRegistration();\n        simulation.clearField();\n        selected = null;\n        resetEvaluation();\n        showEmptyField();\n        updateDiagnostics(performance.now(), true);\n      }\n\n      function deleteSelectedDevice() {\n        if (!selected) return;\n        const removedIndex = simulation.entities.indexOf(selected);\n        if (!simulation.removeEntity(selected)) return;\n\n        selected = simulation.entities[removedIndex]\n          || simulation.entities[removedIndex - 1]\n          || null;\n        if (selected) updateInspector(true);\n        else showEmptyField();\n        if (evaluator) updateEvaluationUI();\n        updateDiagnostics(performance.now(), true);\n      }\n\n      function applyPeerCapacity() {\n        simulation.peerCapacity = Number(ui.peerCapacityControl.value);\n        simulation.solveCapacity = Math.min(simulation.solveCapacity, simulation.peerCapacity);\n        simulation.anchorReserve = Math.min(simulation.anchorReserve, simulation.peerCapacity);\n        ui.solveCapacityControl.value = String(simulation.solveCapacity);\n        ui.anchorReserveControl.value = String(simulation.anchorReserve);\n        ui.peerCapacityOutput.value = String(simulation.peerCapacity);\n        ui.solveCapacityOutput.value = String(simulation.solveCapacity);\n        ui.anchorReserveOutput.value = String(simulation.anchorReserve);\n        for (const entity of simulation.entities) entity.network.enforcePeerCapacity();\n        if (evaluator) updateEvaluationUI();\n      }\n\n      canvas.addEventListener(\"pointerdown\", event =&gt; {\n        if (event.button !== 0) return;\n        canvas.focus({ preventScroll: true });\n        const screen = screenPoint(event);\n        const point = worldPoint(screen);\n        const hit = hitTest(point);\n        if (hit) {\n          selected = hit;\n          dragging = hit;\n          dragOffset = { x: hit.x - point.x, y: hit.y - point.y };\n          updateInspector(true);\n        } else {\n          panning = {\n            pointerX: screen.x,\n            pointerY: screen.y,\n            cameraX: camera.x,\n            cameraY: camera.y\n          };\n        }\n        canvas.classList.add(\"dragging\");\n        canvas.setPointerCapture(event.pointerId);\n      });\n\n      canvas.addEventListener(\"pointermove\", event =&gt; {\n        const screen = screenPoint(event);\n        if (dragging) {\n          const point = worldPoint(screen);\n          dragging.x = clamp(point.x + dragOffset.x, 45, simulation.width - 45);\n          dragging.y = clamp(point.y + dragOffset.y, 78, simulation.height - 72);\n          dragging.network.lockAnchorPosition();\n        } else if (panning) {\n          camera.x = panning.cameraX + screen.x - panning.pointerX;\n          camera.y = panning.cameraY + screen.y - panning.pointerY;\n        }\n      });\n\n      function endDrag(event) {\n        dragging = null;\n        panning = null;\n        canvas.classList.remove(\"dragging\");\n        if (canvas.hasPointerCapture(event.pointerId)) canvas.releasePointerCapture(event.pointerId);\n      }\n\n      canvas.addEventListener(\"pointerup\", endDrag);\n      canvas.addEventListener(\"pointercancel\", endDrag);\n      canvas.addEventListener(\"keydown\", event =&gt; {\n        if (event.key !== \"Backspace\" &amp;&amp; event.key !== \"Delete\") return;\n        event.preventDefault();\n        deleteSelectedDevice();\n      });\n      canvas.addEventListener(\"wheel\", event =&gt; {\n        event.preventDefault();\n        const screen = screenPoint(event);\n        const beforeZoom = worldPoint(screen);\n        const zoomFactor = Math.exp(-event.deltaY * 0.0015);\n        camera.zoom = clamp(camera.zoom * zoomFactor, 0.25, 4);\n        camera.x = screen.x - beforeZoom.x * camera.zoom;\n        camera.y = screen.y - beforeZoom.y * camera.zoom;\n      }, { passive: false });\n      canvas.addEventListener(\"dblclick\", event =&gt; {\n        const point = worldPoint(screenPoint(event));\n        if (!hitTest(point)) addDeviceAt(point.x, point.y);\n      });\n\n      ui.addDevice.addEventListener(\"click\", () =&gt; {\n        const angle = simulation.random() * Math.PI * 2;\n        const radius = 55 + simulation.random() * 125;\n        addDeviceAt(simulation.width / 2 + Math.cos(angle) * radius, simulation.height / 2 + Math.sin(angle) * radius);\n      });\n      ui.addAnchor.addEventListener(\"click\", () =&gt; {\n        const angle = simulation.random() * Math.PI * 2;\n        const radius = 70 + simulation.random() * 145;\n        addAnchorAt(\n          simulation.width / 2 + Math.cos(angle) * radius,\n          simulation.height / 2 + Math.sin(angle) * radius\n        );\n      });\n      ui.addEight.addEventListener(\"click\", () =&gt; addNearCenter(8));\n      ui.runScenario.addEventListener(\"click\", runSelectedScenario);\n      ui.peerCapacityControl.addEventListener(\"input\", applyPeerCapacity);\n      ui.solveCapacityControl.addEventListener(\"input\", () =&gt; {\n        simulation.solveCapacity = Math.min(\n          Number(ui.solveCapacityControl.value),\n          simulation.peerCapacity\n        );\n        ui.solveCapacityControl.value = String(simulation.solveCapacity);\n        ui.solveCapacityOutput.value = String(simulation.solveCapacity);\n      });\n      ui.anchorReserveControl.addEventListener(\"input\", () =&gt; {\n        simulation.anchorReserve = Math.min(\n          Number(ui.anchorReserveControl.value),\n          simulation.peerCapacity\n        );\n        ui.anchorReserveControl.value = String(simulation.anchorReserve);\n        ui.anchorReserveOutput.value = String(simulation.anchorReserve);\n        for (const entity of simulation.entities) entity.network.enforcePeerCapacity();\n      });\n      ui.payloadProfileControl.addEventListener(\"change\", () =&gt; {\n        simulation.payloadProfileKey = ui.payloadProfileControl.value;\n        if (evaluator) updateEvaluationUI();\n      });\n      ui.coordinateEncodingControl.addEventListener(\"change\", () =&gt; {\n        simulation.coordinateEncodingKey = ui.coordinateEncodingControl.value;\n        if (evaluator) updateEvaluationUI();\n      });\n      ui.coordinateQuantumControl.addEventListener(\"change\", () =&gt; {\n        simulation.coordinateQuantum = Number(ui.coordinateQuantumControl.value);\n        if (evaluator) updateEvaluationUI();\n      });\n      ui.wireEnvelopeControl.addEventListener(\"change\", () =&gt; {\n        simulation.wireEnvelope = ui.wireEnvelopeControl.value;\n        if (evaluator) updateEvaluationUI();\n      });\n      ui.positionPeriodControl.addEventListener(\"input\", () =&gt; {\n        simulation.positionBroadcastPeriod = Number(ui.positionPeriodControl.value) * 1000;\n        ui.positionPeriodOutput.value = `${Number(ui.positionPeriodControl.value).toFixed(2).replace(/0$/, \"\").replace(/\\.0$/, \"\")} s`;\n        for (const entity of simulation.entities) {\n          entity.network.nextPositionBroadcastAt = Math.min(\n            entity.network.nextPositionBroadcastAt,\n            simulation.time + simulation.positionBroadcastPeriod\n          );\n        }\n        if (evaluator) updateEvaluationUI();\n      });\n      ui.outlierErrorControl.addEventListener(\"input\", () =&gt; {\n        simulation.outlierErrorThreshold = Number(ui.outlierErrorControl.value);\n        ui.outlierErrorOutput.value = `${simulation.outlierErrorThreshold} px`;\n        if (evaluator) updateEvaluationUI();\n      });\n      ui.outlierTimeControl.addEventListener(\"input\", () =&gt; {\n        simulation.outlierDuration = Number(ui.outlierTimeControl.value) * 1000;\n        ui.outlierTimeOutput.value = `${ui.outlierTimeControl.value} s`;\n        if (evaluator) updateEvaluationUI();\n      });\n      ui.pauseToggle.addEventListener(\"click\", () =&gt; {\n        simulation.paused = !simulation.paused;\n        ui.pauseToggle.textContent = simulation.paused ? \"▶\" : \"Ⅱ\";\n        ui.pauseToggle.title = simulation.paused ? \"Resume simulation\" : \"Pause simulation\";\n        ui.pauseToggle.setAttribute(\"aria-label\", ui.pauseToggle.title);\n      });\n      ui.resetSimulation.addEventListener(\"click\", () =&gt; {\n        resetCamera();\n        resetDisplayRegistration();\n        selected = simulation.reset();\n        resetEvaluation();\n        updateInspector(true);\n      });\n      ui.clearSimulation.addEventListener(\"click\", clearCurrentField);\n      ui.rangeControl.addEventListener(\"input\", () =&gt; {\n        simulation.range = Number(ui.rangeControl.value);\n        ui.rangeOutput.value = `${simulation.range} px`;\n      });\n      ui.dropoffControl.addEventListener(\"change\", () =&gt; { simulation.dropoff = ui.dropoffControl.value; });\n      ui.deliveryModelControl.addEventListener(\"change\", () =&gt; {\n        simulation.deliveryModel = ui.deliveryModelControl.value;\n      });\n      ui.fixedRelay.addEventListener(\"change\", () =&gt; {\n        simulation.fixedRelay = ui.fixedRelay.checked;\n        runSelectedScenario();\n      });\n      bindDecibelControl(ui.rssiJitterControl, ui.rssiJitterOutput, ui.rssiJitterPreset, \"rssiJitterSigmaDb\");\n      bindDecibelControl(ui.txSpreadControl, ui.txSpreadOutput, ui.txSpreadPreset, \"txPowerSigmaDb\");\n      bindDecibelControl(ui.linkBiasControl, ui.linkBiasOutput, ui.linkBiasPreset, \"linkShadowSigmaDb\");\n      ui.speedControl.addEventListener(\"input\", () =&gt; {\n        simulation.speed = Number(ui.speedControl.value);\n        ui.speedOutput.value = `${simulation.speed.toFixed(2).replace(/0$/, \"\")}×`;\n      });\n      ui.bpmControl.addEventListener(\"input\", () =&gt; {\n        simulation.leaderBpm = Number(ui.bpmControl.value);\n        ui.bpmOutput.value = `${simulation.leaderBpm} BPM`;\n        for (const entity of simulation.entities) {\n          if (!entity.network.isFollowing()) {\n            entity.network.current.bpm = simulation.leaderBpm;\n            entity.network.next.bpm = simulation.leaderBpm;\n          }\n        }\n      });\n      ui.forceNext.addEventListener(\"click\", () =&gt; {\n        for (const entity of simulation.entities) {\n          if (!entity.network.isFollowing()) entity.network.forceNext();\n        }\n      });\n      ui.copySnapshot.addEventListener(\"click\", () =&gt; copyJSON(createSnapshot(), \"Snapshot copied\"));\n      ui.copySelectedAudit.addEventListener(\"click\", () =&gt; {\n        if (selected) copyJSON(createDeviceAuditExport(selected.network), \"Device audit copied\");\n      });\n      ui.copyRunAudit.addEventListener(\"click\", () =&gt; copyJSON(createRunAuditExport(), \"Run audit copied\"));\n      ui.mirrorSnapshot.addEventListener(\"change\", () =&gt; {\n        if (!ui.mirrorSnapshot.checked &amp;&amp; location.hash.startsWith(\"#tubes=\")) {\n          history.replaceState(null, \"\", location.href.split(\"#\")[0]);\n        }\n        updateDiagnostics(performance.now(), true);\n      });\n\n      function drawGrid() {\n        const left = -camera.x / camera.zoom;\n        const top = -camera.y / camera.zoom;\n        const right = left + simulation.width / camera.zoom;\n        const bottom = top + simulation.height / camera.zoom;\n        const spacing = 32;\n        const firstX = Math.floor(left / spacing) * spacing + 0.5;\n        const firstY = Math.floor(top / spacing) * spacing + 0.5;\n        context.beginPath();\n        for (let x = firstX; x &lt;= right; x += spacing) { context.moveTo(x, top); context.lineTo(x, bottom); }\n        for (let y = firstY; y &lt;= bottom; y += spacing) { context.moveTo(left, y); context.lineTo(right, y); }\n        context.strokeStyle = \"rgba(133, 151, 184, 0.055)\";\n        context.lineWidth = 1 / camera.zoom;\n        context.stroke();\n      }\n\n      function drawRadioField() {\n        if (!selected || !ui.showRadio.checked) return;\n        const range = simulation.range;\n\n        const gradient = context.createRadialGradient(selected.x, selected.y, 0, selected.x, selected.y, range);\n        gradient.addColorStop(0, \"rgba(112, 183, 255, 0.10)\");\n        gradient.addColorStop(0.7, \"rgba(112, 183, 255, 0.025)\");\n        gradient.addColorStop(1, \"rgba(112, 183, 255, 0)\");\n        context.fillStyle = gradient;\n        context.beginPath();\n        context.arc(selected.x, selected.y, range, 0, Math.PI * 2);\n        context.fill();\n\n        context.setLineDash([5, 5]);\n        context.strokeStyle = \"rgba(112, 183, 255, 0.32)\";\n        context.lineWidth = 1;\n        context.beginPath();\n        context.arc(selected.x, selected.y, range, 0, Math.PI * 2);\n        context.stroke();\n        context.setLineDash([]);\n\n        for (const target of simulation.entities) {\n          if (target === selected) continue;\n          const distance = simulation.distance(selected, target);\n          const strength = simulation.signalAtDistance(distance);\n          if (strength &lt;= 0) continue;\n          context.strokeStyle = `rgba(112, 183, 255, ${0.05 + strength * 0.2})`;\n          context.lineWidth = 0.5 + strength * 1.5;\n          context.beginPath();\n          context.moveTo(selected.x, selected.y);\n          context.lineTo(target.x, target.y);\n          context.stroke();\n        }\n      }\n\n      function findUplinkEntity(entity) {\n        if (!entity.network.uplinkId) return null;\n        const candidates = simulation.entities.filter(candidate =&gt; candidate.network.id === entity.network.uplinkId);\n        if (!candidates.length) return null;\n        return candidates.sort((a, b) =&gt; simulation.distance(entity, a) - simulation.distance(entity, b))[0];\n      }\n\n      function drawTopology() {\n        if (!ui.showTopology.checked) return;\n        for (const entity of simulation.entities) {\n          const uplink = findUplinkEntity(entity);\n          if (!uplink) continue;\n          const color = entity === selected || uplink === selected\n            ? \"rgba(244, 247, 255, 0.62)\"\n            : \"rgba(170, 180, 200, 0.22)\";\n          const dx = uplink.x - entity.x;\n          const dy = uplink.y - entity.y;\n          const distance = Math.hypot(dx, dy);\n          if (distance &lt; 1) continue;\n          const ux = dx / distance;\n          const uy = dy / distance;\n          const startRadius = entity.network.isAnchor ? 21 : 31;\n          const endRadius = uplink.network.isAnchor ? 21 : 31;\n          const startX = entity.x + ux * startRadius;\n          const startY = entity.y + uy * startRadius;\n          const endX = uplink.x - ux * endRadius;\n          const endY = uplink.y - uy * endRadius;\n\n          context.setLineDash([4, 4]);\n          context.lineWidth = 1;\n          context.strokeStyle = color;\n          context.beginPath();\n          context.moveTo(startX, startY);\n          context.lineTo(endX, endY);\n          context.stroke();\n\n          const arrowLength = 9;\n          const arrowWidth = 5;\n          const baseX = endX - ux * arrowLength;\n          const baseY = endY - uy * arrowLength;\n          context.setLineDash([]);\n          context.fillStyle = color;\n          context.beginPath();\n          context.moveTo(endX, endY);\n          context.lineTo(baseX - uy * arrowWidth, baseY + ux * arrowWidth);\n          context.lineTo(baseX + uy * arrowWidth, baseY - ux * arrowWidth);\n          context.closePath();\n          context.fill();\n        }\n        context.setLineDash([]);\n      }\n\n      function drawRadioWaves() {\n        if (!ui.showSignalWaves.checked) return;\n        for (const wave of simulation.waves) {\n          const progress = (simulation.time - wave.start) / RADIO_WAVE_TIME;\n          if (progress &lt;= 0 || progress &gt; 1) continue;\n\n          const color = wave.rebroadcast ? \"246, 211, 101\" : \"142, 240, 208\";\n          const radius = progress * wave.range;\n          const strength = simulation.signalForNormalizedDistance(progress, wave.dropoff);\n          const alpha = 0.035 + strength * 0.42;\n\n          context.strokeStyle = `rgba(${color}, ${alpha})`;\n          context.lineWidth = 0.65 + strength * 2.2;\n          context.beginPath();\n          context.arc(wave.sender.x, wave.sender.y, radius, 0, Math.PI * 2);\n          context.stroke();\n\n          if (wave.rebroadcast &amp;&amp; strength &gt; 0.08) {\n            context.fillStyle = `rgba(${color}, ${Math.min(0.9, alpha + 0.25)})`;\n            context.font = \"800 8px ui-monospace, monospace\";\n            context.textAlign = \"center\";\n            context.fillText(`R${wave.hop}`, wave.sender.x, wave.sender.y - radius - 4);\n          }\n        }\n      }\n\n      function drawPulses() {\n        for (const pulse of simulation.pulses) {\n          if (simulation.time &lt; pulse.start) continue;\n          const span = Math.max(1, pulse.end - pulse.start);\n          const progress = clamp((simulation.time - pulse.start) / span, 0, 1);\n          const alpha = Math.sin(progress * Math.PI);\n          const color = !pulse.success\n            ? \"255, 127, 145\"\n            : pulse.rebroadcast ? \"246, 211, 101\" : \"142, 240, 208\";\n\n          context.strokeStyle = `rgba(${color}, ${alpha * (0.3 + pulse.strength * 0.5)})`;\n          context.lineWidth = pulse.success ? 1.4 : 1;\n          context.beginPath();\n          context.arc(pulse.target.x, pulse.target.y, 5 + progress * 7, 0, Math.PI * 2);\n          context.stroke();\n\n          if (!pulse.success &amp;&amp; alpha &gt; 0.25) {\n            const size = 3.5;\n            context.beginPath();\n            context.moveTo(pulse.target.x - size, pulse.target.y - size);\n            context.lineTo(pulse.target.x + size, pulse.target.y + size);\n            context.moveTo(pulse.target.x + size, pulse.target.y - size);\n            context.lineTo(pulse.target.x - size, pulse.target.y + size);\n            context.stroke();\n          }\n        }\n      }\n\n      function estimateCanvasOrigin(frameId) {\n        if (frameId === ANCHORED_FRAME_ID) return { x: 0, y: 0 };\n        const frameOwner = simulation.entities.find(entity =&gt; entity.network.id === frameId);\n        if (frameOwner) return { x: frameOwner.x, y: frameOwner.y };\n        return { x: simulation.width / 2, y: simulation.height / 2 };\n      }\n\n      function positionFrameRoleEntity(frameId, roleField) {\n        const frameOwner = simulation.entities.find(entity =&gt; entity.network.id === frameId);\n        const frameMember = frameOwner || simulation.entities.find(entity =&gt;\n          entity.network.positionEstimate.frameId === frameId\n        );\n        const roleId = frameMember ? frameMember.network.positionEstimate[roleField] : null;\n        return roleId ? simulation.entities.find(entity =&gt; entity.network.id === roleId) || null : null;\n      }\n\n      function displayRegistrationFit(frameId, transform) {\n        const ambiguousSolutions = new Set([\n          POSITION_SOLUTION.UNPLACED,\n          POSITION_SOLUTION.RADIAL,\n          POSITION_SOLUTION.MIRRORED\n        ]);\n        let squaredError = 0;\n        let sampleCount = 0;\n        for (const entity of simulation.entities) {\n          const estimate = entity.network.positionEstimate;\n          if (estimate.frameId !== frameId || ambiguousSolutions.has(estimate.solution)) continue;\n          if (!Number.isFinite(estimate.x) || !Number.isFinite(estimate.y)) continue;\n          const displayPoint = estimateCanvasCoordinates(transform, estimate.x, estimate.y);\n          squaredError += (displayPoint.x - entity.x) ** 2 + (displayPoint.y - entity.y) ** 2;\n          sampleCount += 1;\n        }\n        return {\n          sampleCount,\n          error: sampleCount ? Math.sqrt(squaredError / sampleCount) : null\n        };\n      }\n\n      function estimateDisplayTransform(frameId) {\n        const origin = estimateCanvasOrigin(frameId);\n        const identity = {\n          origin,\n          estimatedX: { x: 1, y: 0 },\n          physicalX: { x: 1, y: 0 },\n          reflection: 1,\n          rotation: 0,\n          registrationError: null,\n          alternativeError: null,\n          registrationSampleCount: 0,\n          reflectionSource: \"fixed\"\n        };\n        if (frameId === ANCHORED_FRAME_ID) {\n          return identity;\n        }\n        const axisEntity = positionFrameRoleEntity(frameId, \"axisId\");\n        if (!axisEntity || axisEntity.network.positionEstimate.frameId !== frameId) {\n          return identity;\n        }\n\n        const estimatedAxis = axisEntity.network.positionEstimate;\n        const physicalAxis = { x: axisEntity.x - origin.x, y: axisEntity.y - origin.y };\n        const estimatedLength = Math.hypot(estimatedAxis.x, estimatedAxis.y);\n        const physicalLength = Math.hypot(physicalAxis.x, physicalAxis.y);\n        if (estimatedLength &lt;= POSITION_SETTLED_EPSILON || physicalLength &lt;= POSITION_SETTLED_EPSILON) {\n          return identity;\n        }\n\n        const estimatedX = { x: estimatedAxis.x / estimatedLength, y: estimatedAxis.y / estimatedLength };\n        const physicalX = { x: physicalAxis.x / physicalLength, y: physicalAxis.y / physicalLength };\n        let orientationReflection = 1;\n        const orientationEntity = positionFrameRoleEntity(frameId, \"orientationId\");\n        if (orientationEntity &amp;&amp; orientationEntity.network.positionEstimate.frameId === frameId) {\n          const estimatedOrientation = orientationEntity.network.positionEstimate;\n          const physicalOrientation = {\n            x: orientationEntity.x - origin.x,\n            y: orientationEntity.y - origin.y\n          };\n          const estimatedSide = estimatedAxis.x * estimatedOrientation.y - estimatedAxis.y * estimatedOrientation.x;\n          const physicalSide = physicalAxis.x * physicalOrientation.y - physicalAxis.y * physicalOrientation.x;\n          if (Math.abs(estimatedSide) &gt; POSITION_SETTLED_EPSILON &amp;&amp; Math.abs(physicalSide) &gt; POSITION_SETTLED_EPSILON) {\n            orientationReflection = Math.sign(estimatedSide) === Math.sign(physicalSide) ? 1 : -1;\n          }\n        }\n\n        const baseTransform = {\n          origin,\n          estimatedX,\n          physicalX,\n          rotation: Math.atan2(physicalX.y, physicalX.x) - Math.atan2(estimatedX.y, estimatedX.x)\n        };\n        const normalFit = displayRegistrationFit(frameId, { ...baseTransform, reflection: 1 });\n        const reflectedFit = displayRegistrationFit(frameId, { ...baseTransform, reflection: -1 });\n        let reflection = displayRegistrationByFrame.get(frameId)?.reflection || orientationReflection;\n        let reflectionSource = \"orientation\";\n\n        if (normalFit.sampleCount &gt;= 3 &amp;&amp; reflectedFit.sampleCount &gt;= 3) {\n          const currentFit = reflection &gt; 0 ? normalFit : reflectedFit;\n          const alternateFit = reflection &gt; 0 ? reflectedFit : normalFit;\n          if (alternateFit.error + DISPLAY_REFLECTION_HYSTERESIS &lt; currentFit.error) reflection *= -1;\n          reflectionSource = \"best-fit\";\n          displayRegistrationByFrame.set(frameId, { reflection });\n        }\n\n        const selectedFit = reflection &gt; 0 ? normalFit : reflectedFit;\n        const alternateFit = reflection &gt; 0 ? reflectedFit : normalFit;\n\n        // Registration uses simulator-only truth for overlay and scoring; no device estimate is modified.\n        return {\n          ...baseTransform,\n          reflection,\n          registrationError: selectedFit.error,\n          alternativeError: alternateFit.error,\n          registrationSampleCount: selectedFit.sampleCount,\n          reflectionSource\n        };\n      }\n\n      function estimateCanvasCoordinates(transform, x, y) {\n        const estimatedY = { x: -transform.estimatedX.y, y: transform.estimatedX.x };\n        const physicalY = { x: -transform.physicalX.y, y: transform.physicalX.x };\n        const alongAxis = x * transform.estimatedX.x + y * transform.estimatedX.y;\n        const acrossAxis = (x * estimatedY.x + y * estimatedY.y) * transform.reflection;\n        return {\n          x: transform.origin.x + alongAxis * transform.physicalX.x + acrossAxis * physicalY.x,\n          y: transform.origin.y + alongAxis * transform.physicalX.y + acrossAxis * physicalY.y\n        };\n      }\n\n      function estimateCanvasPoint(node, transform) {\n        return estimateCanvasCoordinates(transform, node.positionEstimate.x, node.positionEstimate.y);\n      }\n\n      function estimateColor(node, alpha = 1) {\n        const hue = (node.id * 137.508) % 360;\n        return `hsla(${hue}, 82%, 72%, ${alpha})`;\n      }\n\n      class EvaluationTracker {\n        constructor(simulationModel) {\n          this.simulation = simulationModel;\n          this.reset();\n        }\n\n        reset() {\n          this.history = [];\n          this.outlierStates = new Map();\n          this.outlierEvents = [];\n          this.nextSampleAt = 0;\n          this.current = {\n            score: 0,\n            medianError: null,\n            p95Error: null,\n            worstError: null,\n            positioned: 0,\n            total: 0,\n            persistentOutliers: []\n          };\n        }\n\n        isUniqueSolution(node) {\n          return ![\n            POSITION_SOLUTION.UNPLACED,\n            POSITION_SOLUTION.RADIAL,\n            POSITION_SOLUTION.MIRRORED\n          ].includes(node.positionEstimate.solution);\n        }\n\n        referenceFrameId(tubes) {\n          const counts = new Map();\n          for (const entity of tubes) {\n            const node = entity.network;\n            if (!this.isUniqueSolution(node)) continue;\n            const frameId = node.positionEstimate.frameId;\n            counts.set(frameId, (counts.get(frameId) || 0) + 1);\n          }\n          if (counts.has(ANCHORED_FRAME_ID)) return ANCHORED_FRAME_ID;\n          const ordered = [...counts.entries()].sort((a, b) =&gt; b[1] - a[1] || b[0] - a[0]);\n          return ordered.length ? ordered[0][0] : null;\n        }\n\n        percentile(sortedValues, fraction) {\n          if (!sortedValues.length) return null;\n          const index = clamp(Math.ceil(sortedValues.length * fraction) - 1, 0, sortedValues.length - 1);\n          return sortedValues[index];\n        }\n\n        updateOutlier(node, error) {\n          const existing = this.outlierStates.get(node.id) || {\n            since: null,\n            maximumError: 0,\n            reported: false\n          };\n\n          if (error === null || error &lt;= this.simulation.outlierErrorThreshold) {\n            existing.since = null;\n            existing.maximumError = 0;\n            existing.reported = false;\n            this.outlierStates.set(node.id, existing);\n            return null;\n          }\n\n          if (existing.since === null) existing.since = this.simulation.time;\n          existing.maximumError = Math.max(existing.maximumError, error);\n          const duration = this.simulation.time - existing.since;\n          if (duration &gt;= this.simulation.outlierDuration &amp;&amp; !existing.reported) {\n            existing.reported = true;\n            this.outlierEvents.unshift({\n              nodeId: node.id,\n              detectedAt: this.simulation.time,\n              maximumError: existing.maximumError\n            });\n            if (this.outlierEvents.length &gt; 20) this.outlierEvents.length = 20;\n          }\n          this.outlierStates.set(node.id, existing);\n          return existing.reported\n            ? { nodeId: node.id, error, duration, maximumError: existing.maximumError }\n            : null;\n        }\n\n        sample() {\n          const tubes = this.simulation.entities.filter(entity =&gt;\n            !entity.network.isAnchor &amp;&amp; entity.network.status === STATUS.STARTED\n          );\n          const referenceFrameId = this.referenceFrameId(tubes);\n          const transform = referenceFrameId === null ? null : estimateDisplayTransform(referenceFrameId);\n          const errors = [];\n          const persistentOutliers = [];\n          let scoreTotal = 0;\n          let positioned = 0;\n\n          for (const entity of tubes) {\n            const node = entity.network;\n            const isPositioned = transform\n              &amp;&amp; node.positionEstimate.frameId === referenceFrameId\n              &amp;&amp; this.isUniqueSolution(node);\n            let error = null;\n            if (isPositioned) {\n              const estimate = estimateCanvasPoint(node, transform);\n              error = Math.hypot(estimate.x - entity.x, estimate.y - entity.y);\n              errors.push(error);\n              positioned += 1;\n              scoreTotal += 100 * Math.exp(-error / QUALITY_ERROR_SCALE);\n            }\n            const outlier = this.updateOutlier(node, error);\n            if (outlier) persistentOutliers.push(outlier);\n          }\n\n          errors.sort((a, b) =&gt; a - b);\n          this.current = {\n            score: tubes.length ? scoreTotal / tubes.length : 0,\n            medianError: this.percentile(errors, 0.5),\n            p95Error: this.percentile(errors, 0.95),\n            worstError: errors.length ? errors[errors.length - 1] : null,\n            positioned,\n            total: tubes.length,\n            persistentOutliers\n          };\n          this.history.push({\n            at: this.simulation.time,\n            score: this.current.score,\n            medianError: this.current.medianError,\n            p95Error: this.current.p95Error,\n            outlierCount: persistentOutliers.length\n          });\n          if (this.history.length &gt; QUALITY_HISTORY_LIMIT) this.history.shift();\n        }\n\n        update() {\n          if (this.simulation.time &lt; this.nextSampleAt) return false;\n          this.nextSampleAt = this.simulation.time + QUALITY_SAMPLE_PERIOD;\n          this.sample();\n          return true;\n        }\n      }\n\n      function drawEstimatedPositions() {\n        if (!ui.showEstimates.checked) return;\n\n        context.save();\n\n        // Frame origins are visually registered to their physical owners for comparison only.\n        const frameIds = new Set(simulation.entities.map(entity =&gt; entity.network.positionEstimate.frameId));\n        const frameTransforms = new Map([...frameIds].map(frameId =&gt; [frameId, estimateDisplayTransform(frameId)]));\n        for (const frameId of frameIds) {\n          const transform = frameTransforms.get(frameId);\n          const origin = transform.origin;\n          context.setLineDash([2, 4]);\n          context.strokeStyle = \"rgba(142, 240, 208, 0.22)\";\n          context.lineWidth = 1;\n          context.beginPath();\n          context.moveTo(origin.x - 15, origin.y);\n          context.lineTo(origin.x + 15, origin.y);\n          context.moveTo(origin.x, origin.y - 15);\n          context.lineTo(origin.x, origin.y + 15);\n          context.stroke();\n          context.setLineDash([]);\n          context.fillStyle = \"rgba(142, 240, 208, 0.42)\";\n          context.font = \"750 8px ui-monospace, monospace\";\n          context.textAlign = \"left\";\n          const rotationDegrees = Math.round(transform.rotation * 180 / Math.PI);\n          const reflectionLabel = transform.reflection &lt; 0 ? \" · MIRRORED\" : \"\";\n          const fitLabel = transform.registrationError === null\n            ? \"\"\n            : ` · FIT ${Math.round(transform.registrationError)}px · ${transform.reflection &lt; 0 ? \"NO-FLIP\" : \"FLIP\"} ${Math.round(transform.alternativeError)}px`;\n          const frameLabel = frameId === ANCHORED_FRAME_ID\n            ? \"ANCHORED FRAME · FIXED CANVAS COORDINATES\"\n            : `F ${formatId(frameId)} ORIGIN (0,0) · VIEW ${rotationDegrees}°${reflectionLabel}${fitLabel}`;\n          context.fillText(frameLabel, origin.x + 18, origin.y + 14);\n        }\n\n        if (selected) {\n          const belief = selected.network.positionEstimate;\n          const selectedTransform = frameTransforms.get(belief.frameId);\n          const pendingAnchoredEvidence = !selected.network.isAnchor\n            &amp;&amp; belief.frameId !== ANCHORED_FRAME_ID\n            ? selected.network.anchoredFrameEvidence()\n            : null;\n\n          if (pendingAnchoredEvidence?.peers.length) {\n            context.setLineDash([7, 6]);\n            context.strokeStyle = \"rgba(246, 211, 101, 0.48)\";\n            context.lineWidth = 1.3;\n            for (const peer of pendingAnchoredEvidence.peers) {\n              context.beginPath();\n              context.arc(peer.x, peer.y, peer.directDistance, 0, Math.PI * 2);\n              context.stroke();\n            }\n            context.setLineDash([]);\n            context.fillStyle = \"rgba(246, 211, 101, 0.9)\";\n            context.font = \"800 8px ui-monospace, monospace\";\n            context.textAlign = \"left\";\n            context.fillText(\n              `${pendingAnchoredEvidence.peers.length} ANCHORED RANGE${pendingAnchoredEvidence.peers.length === 1 ? \"\" : \"S\"} · FLOATING ESTIMATE PRESERVED`,\n              selected.x + 22,\n              selected.y - 8\n            );\n\n            for (const candidate of pendingAnchoredEvidence.mirrorCandidates || []) {\n              context.fillStyle = \"rgba(246, 211, 101, 0.72)\";\n              context.beginPath();\n              context.moveTo(candidate.x, candidate.y - 6);\n              context.lineTo(candidate.x + 6, candidate.y);\n              context.lineTo(candidate.x, candidate.y + 6);\n              context.lineTo(candidate.x - 6, candidate.y);\n              context.closePath();\n              context.fill();\n            }\n          }\n\n          const radial = belief.radialConstraint;\n          if (radial) {\n            const center = estimateCanvasCoordinates(selectedTransform, radial.x, radial.y);\n            context.setLineDash([7, 6]);\n            context.strokeStyle = \"rgba(255, 143, 184, 0.62)\";\n            context.lineWidth = 1.4;\n            context.beginPath();\n            context.arc(center.x, center.y, radial.radius, 0, Math.PI * 2);\n            context.stroke();\n            context.setLineDash([]);\n            context.fillStyle = \"rgba(255, 143, 184, 0.88)\";\n            context.font = \"800 8px ui-monospace, monospace\";\n            context.fillText(\n              `RANGE TO ${formatId(radial.centerId)} · ${radial.radius.toFixed(1)}`,\n              center.x + radial.radius + 6,\n              center.y - 5\n            );\n          }\n\n          for (let index = 0; index &lt; belief.mirrorCandidates.length; index += 1) {\n            const candidate = belief.mirrorCandidates[index];\n            const candidatePoint = estimateCanvasCoordinates(selectedTransform, candidate.x, candidate.y);\n            const size = index === 0 ? 6 : 5;\n            context.fillStyle = index === 0 ? \"rgba(246, 211, 101, 0.95)\" : \"rgba(246, 211, 101, 0.38)\";\n            context.beginPath();\n            context.moveTo(candidatePoint.x, candidatePoint.y - size);\n            context.lineTo(candidatePoint.x + size, candidatePoint.y);\n            context.lineTo(candidatePoint.x, candidatePoint.y + size);\n            context.lineTo(candidatePoint.x - size, candidatePoint.y);\n            context.closePath();\n            context.fill();\n          }\n        }\n\n        const groups = new Map();\n        for (const entity of simulation.entities) {\n          if (entity.network.isAnchor) continue;\n          const transform = frameTransforms.get(entity.network.positionEstimate.frameId);\n          const point = estimateCanvasPoint(entity.network, transform);\n          const key = `${point.x.toFixed(2)},${point.y.toFixed(2)}`;\n          if (!groups.has(key)) groups.set(key, { point, entities: [] });\n          groups.get(key).entities.push(entity);\n        }\n\n        for (const group of groups.values()) {\n          group.entities.sort((a, b) =&gt; a.network.id - b.network.id);\n          const maximumRadius = 8 + Math.max(0, group.entities.length - 1) * 4;\n\n          for (let index = 0; index &lt; group.entities.length; index += 1) {\n            const entity = group.entities[index];\n            const node = entity.network;\n            const point = group.point;\n            const radius = 8 + index * 4;\n            const isSelected = entity === selected;\n            const confidenceAlpha = 0.32 + clamp(node.positionEstimate.confidence, 0, 1) * 0.55;\n\n            if (isSelected &amp;&amp; Math.hypot(point.x - entity.x, point.y - entity.y) &gt; 2) {\n              context.setLineDash([3, 5]);\n              context.strokeStyle = estimateColor(node, 0.38);\n              context.lineWidth = 1;\n              context.beginPath();\n              context.moveTo(entity.x, entity.y);\n              context.lineTo(point.x, point.y);\n              context.stroke();\n              context.setLineDash([]);\n            }\n\n            if (isSelected) {\n              const ghostWidth = node.isAnchor ? 38 : 33;\n              const ghostHeight = node.isAnchor ? 38 : 100;\n              roundedRectPath(point.x - ghostWidth / 2, point.y - ghostHeight / 2, ghostWidth, ghostHeight, 10);\n              context.fillStyle = estimateColor(node, 0.035);\n              context.fill();\n              context.setLineDash([5, 4]);\n              context.strokeStyle = estimateColor(node, 0.7);\n              context.lineWidth = 1.4;\n              context.stroke();\n              context.setLineDash([]);\n            }\n\n            context.setLineDash([3, 3]);\n            context.strokeStyle = estimateColor(node, confidenceAlpha);\n            context.lineWidth = isSelected ? 1.8 : 1.2;\n            context.beginPath();\n            context.arc(point.x, point.y, radius, 0, Math.PI * 2);\n            context.stroke();\n            context.setLineDash([]);\n\n            context.strokeStyle = estimateColor(node, confidenceAlpha);\n            context.beginPath();\n            context.moveTo(point.x - 4, point.y);\n            context.lineTo(point.x + 4, point.y);\n            context.moveTo(point.x, point.y - 4);\n            context.lineTo(point.x, point.y + 4);\n            context.stroke();\n\n            const labelY = point.y + (index - (group.entities.length - 1) / 2) * 11;\n            context.fillStyle = estimateColor(node, isSelected ? 1 : 0.78);\n            context.font = `${isSelected ? 850 : 750} 8px ui-monospace, monospace`;\n            context.textAlign = \"left\";\n            context.fillText(\n              `E ${formatId(node.id)} · F ${formatFrameId(node.positionEstimate.frameId)} · ${node.positionEstimate.solution.toUpperCase()}`,\n              point.x + maximumRadius + 8,\n              labelY + 3\n            );\n          }\n        }\n\n        context.restore();\n      }\n\n      function roundedRectPath(x, y, width, height, radius) {\n        const r = Math.min(radius, width / 2, height / 2);\n        context.beginPath();\n        context.moveTo(x + r, y);\n        context.arcTo(x + width, y, x + width, y + height, r);\n        context.arcTo(x + width, y + height, x, y + height, r);\n        context.arcTo(x, y + height, x, y, r);\n        context.arcTo(x, y, x + width, y, r);\n        context.closePath();\n      }\n\n      function leaderPathLabel(node, compact = false) {\n        if (!node.isFollowing()) return compact ? \"SELF\" : \"self-originated\";\n        if (!simulation.fixedRelay) return compact ? `UP ${formatId(node.uplinkId)}` : \"legacy uplink\";\n        if (node.leaderViaId === 0) return compact ? \"WAIT RELAY\" : \"waiting for leader state\";\n        if (node.leaderViaId === node.uplinkId) return compact ? \"DIRECT\" : `direct from ${formatId(node.uplinkId)}`;\n        return compact ? `VIA ${formatId(node.leaderViaId)}` : `relayed via ${formatId(node.leaderViaId)}`;\n      }\n\n      function drawAnchor(entity) {\n        const node = entity.network;\n        const isSelected = entity === selected;\n        const topologyWarning = simulation.localMaximumWarning(entity);\n        const radius = 15;\n\n        context.save();\n        context.shadowColor = isSelected ? \"rgba(246, 211, 101, 0.52)\" : \"rgba(0, 0, 0, 0.72)\";\n        context.shadowBlur = isSelected ? 18 : 10;\n        context.fillStyle = isSelected ? \"rgba(246, 211, 101, 0.13)\" : \"rgba(3, 7, 12, 0.92)\";\n        context.beginPath();\n        context.arc(entity.x, entity.y, radius + 5, 0, Math.PI * 2);\n        context.fill();\n        context.shadowBlur = 0;\n\n        context.save();\n        context.translate(entity.x, entity.y);\n        context.rotate(Math.PI / 4);\n        roundedRectPath(-radius, -radius, radius * 2, radius * 2, 5);\n        context.fillStyle = \"#16202a\";\n        context.fill();\n        context.strokeStyle = isSelected ? \"#f6d365\" : \"rgba(246, 211, 101, 0.72)\";\n        context.lineWidth = isSelected ? 2 : 1.3;\n        context.stroke();\n        context.restore();\n\n        context.strokeStyle = isSelected ? \"#ffffff\" : \"rgba(220, 236, 242, 0.82)\";\n        context.fillStyle = isSelected ? \"#ffffff\" : \"rgba(220, 236, 242, 0.9)\";\n        context.lineWidth = isSelected ? 1.5 : 1.1;\n        context.beginPath();\n        context.moveTo(entity.x - 9, entity.y);\n        context.lineTo(entity.x - 3, entity.y);\n        context.moveTo(entity.x + 3, entity.y);\n        context.lineTo(entity.x + 9, entity.y);\n        context.moveTo(entity.x, entity.y - 9);\n        context.lineTo(entity.x, entity.y - 3);\n        context.moveTo(entity.x, entity.y + 3);\n        context.lineTo(entity.x, entity.y + 9);\n        context.stroke();\n        context.beginPath();\n        context.arc(entity.x, entity.y, 2, 0, Math.PI * 2);\n        context.fill();\n\n        context.textAlign = \"center\";\n        context.font = \"800 11px ui-monospace, SFMono-Regular, Menlo, monospace\";\n        context.fillStyle = isSelected ? \"#f4f7ff\" : \"rgba(226, 232, 244, 0.88)\";\n        context.fillText(formatId(node.id), entity.x, entity.y - 28);\n        context.font = \"800 8px ui-sans-serif, system-ui, sans-serif\";\n        context.fillStyle = node.status === STATUS.RECEIVING ? \"#667189\" : \"#f6d365\";\n        const statusLabel = node.status === STATUS.RECEIVING\n          ? \"ANCHOR · BOOT\"\n          : node.isFollowing()\n          ? simulation.fixedRelay\n            ? `ANCHOR · F ${formatId(node.uplinkId)} · ${leaderPathLabel(node, true)}`\n            : `ANCHOR · ↑${formatId(node.uplinkId)}`\n          : \"ANCHOR · LEAD\";\n        context.fillText(statusLabel, entity.x, entity.y + 31);\n\n        if (node.isRelayActive()) {\n          context.fillStyle = \"#f6d365\";\n          context.beginPath();\n          context.arc(entity.x + 21, entity.y - 15, 7, 0, Math.PI * 2);\n          context.fill();\n          context.fillStyle = \"#201807\";\n          context.font = \"900 8px ui-monospace, monospace\";\n          context.fillText(\"R\", entity.x + 21, entity.y - 12);\n        }\n\n        if (topologyWarning) {\n          context.fillStyle = \"#f6d365\";\n          context.beginPath();\n          context.arc(entity.x - 21, entity.y - 15, 7, 0, Math.PI * 2);\n          context.fill();\n          context.fillStyle = \"#201807\";\n          context.font = \"900 9px ui-monospace, monospace\";\n          context.fillText(\"!\", entity.x - 21, entity.y - 12);\n        }\n        context.restore();\n      }\n\n      function drawDevice(entity) {\n        const node = entity.network;\n        if (node.isAnchor) {\n          drawAnchor(entity);\n          return;\n        }\n        const isSelected = entity === selected;\n        const width = 25;\n        const height = 92;\n        const x = entity.x - width / 2;\n        const y = entity.y - height / 2;\n        const palette = PALETTES[node.dna.palette];\n        const topologyWarning = simulation.localMaximumWarning(entity);\n\n        context.save();\n        context.shadowColor = isSelected ? \"rgba(142, 240, 208, 0.42)\" : \"rgba(0, 0, 0, 0.72)\";\n        context.shadowBlur = isSelected ? 18 : 11;\n        roundedRectPath(x - 4, y - 4, width + 8, height + 8, 11);\n        context.fillStyle = isSelected ? \"rgba(142, 240, 208, 0.10)\" : \"rgba(2, 4, 8, 0.88)\";\n        context.fill();\n        context.shadowBlur = 0;\n\n        roundedRectPath(x, y, width, height, 8);\n        context.fillStyle = \"#151b25\";\n        context.fill();\n        context.strokeStyle = isSelected ? \"rgba(142, 240, 208, 0.8)\" : \"rgba(208, 218, 236, 0.2)\";\n        context.lineWidth = isSelected ? 1.5 : 1;\n        context.stroke();\n\n        const ledCount = 14;\n        const ledX = x + 5;\n        const ledWidth = width - 10;\n        const ledHeight = 4.2;\n        const gap = 1.65;\n        const startY = y + 6.7;\n        for (let index = 0; index &lt; ledCount; index += 1) {\n          const ledY = startY + (ledCount - 1 - index) * (ledHeight + gap);\n          roundedRectPath(ledX, ledY, ledWidth, ledHeight, 1.8);\n          context.fillStyle = node.status === STATUS.RECEIVING\n            ? \"rgba(90, 98, 114, 0.28)\"\n            : animationColor(node.dna, index, ledCount, node.patternTime());\n          context.fill();\n        }\n\n        const centerArm = isSelected ? 9 : 7;\n        const centerGap = isSelected ? 3.5 : 3;\n        context.strokeStyle = isSelected ? \"rgba(255,255,255,0.95)\" : \"rgba(235,241,252,0.64)\";\n        context.fillStyle = isSelected ? \"#ffffff\" : \"rgba(235,241,252,0.78)\";\n        context.lineWidth = isSelected ? 1.4 : 1;\n        context.beginPath();\n        context.moveTo(entity.x - centerArm, entity.y);\n        context.lineTo(entity.x - centerGap, entity.y);\n        context.moveTo(entity.x + centerGap, entity.y);\n        context.lineTo(entity.x + centerArm, entity.y);\n        context.moveTo(entity.x, entity.y - centerArm);\n        context.lineTo(entity.x, entity.y - centerGap);\n        context.moveTo(entity.x, entity.y + centerGap);\n        context.lineTo(entity.x, entity.y + centerArm);\n        context.stroke();\n        context.beginPath();\n        context.arc(entity.x, entity.y, isSelected ? 2 : 1.5, 0, Math.PI * 2);\n        context.fill();\n\n        context.textAlign = \"center\";\n        context.font = \"800 11px ui-monospace, SFMono-Regular, Menlo, monospace\";\n        context.fillStyle = isSelected ? \"#f4f7ff\" : \"rgba(226, 232, 244, 0.82)\";\n        context.fillText(formatId(node.id), entity.x, y - 12);\n\n        context.font = \"750 8px ui-sans-serif, system-ui, sans-serif\";\n        context.fillStyle = node.status === STATUS.RECEIVING\n          ? \"#667189\"\n          : !node.isFollowing() ? \"#8ef0d0\" : \"#94a0b8\";\n        const statusLabel = node.status === STATUS.RECEIVING\n          ? \"BOOT\"\n          : !node.isFollowing()\n          ? \"LEADING\"\n          : simulation.fixedRelay\n          ? `FOLLOW ${formatId(node.uplinkId)} · ${leaderPathLabel(node, true)}`\n          : `FOLLOW ↑${formatId(node.uplinkId)}`;\n        context.fillText(statusLabel, entity.x, y + height + 15);\n\n        const dotY = y + height + 25;\n        const dotColor = mixColor(palette.colors[0], palette.colors[1], 0.5);\n        context.fillStyle = `rgb(${dotColor.r},${dotColor.g},${dotColor.b})`;\n        context.beginPath();\n        context.arc(entity.x, dotY, 2.2, 0, Math.PI * 2);\n        context.fill();\n\n        if (node.isRelayActive()) {\n          context.fillStyle = \"#f6d365\";\n          context.beginPath();\n          context.arc(x + width + 5, y + 7, 7, 0, Math.PI * 2);\n          context.fill();\n          context.fillStyle = \"#201807\";\n          context.font = \"900 8px ui-monospace, monospace\";\n          context.textAlign = \"center\";\n          context.fillText(\"R\", x + width + 5, y + 10);\n        }\n\n        if (topologyWarning) {\n          context.fillStyle = \"#f6d365\";\n          context.beginPath();\n          context.arc(x - 5, y + 7, 7, 0, Math.PI * 2);\n          context.fill();\n          context.fillStyle = \"#201807\";\n          context.font = \"900 9px ui-monospace, monospace\";\n          context.textAlign = \"center\";\n          context.fillText(\"!\", x - 5, y + 10);\n        }\n        context.restore();\n      }\n\n      function draw() {\n        context.setTransform(canvasPixelRatio, 0, 0, canvasPixelRatio, 0, 0);\n        context.clearRect(0, 0, simulation.width, simulation.height);\n        context.fillStyle = \"#090d16\";\n        context.fillRect(0, 0, simulation.width, simulation.height);\n\n        context.save();\n        context.translate(camera.x, camera.y);\n        context.scale(camera.zoom, camera.zoom);\n        drawGrid();\n        drawRadioField();\n        drawTopology();\n        drawRadioWaves();\n        drawPulses();\n        drawEstimatedPositions();\n        const ordered = [...simulation.entities].sort((a, b) =&gt; (a === selected ? 1 : 0) - (b === selected ? 1 : 0));\n        for (const entity of ordered) drawDevice(entity);\n        context.restore();\n\n        context.fillStyle = \"rgba(143, 158, 187, 0.24)\";\n        context.font = \"700 9px ui-monospace, monospace\";\n        context.textAlign = \"left\";\n        context.fillText(`SIMULATION SPACE · ${Math.round(camera.zoom * 100)}% · POSITION IS OMNISCIENT`, 15, 19);\n      }\n\n      function formatBytes(bytes) {\n        if (bytes &lt; 1024) return `${Math.round(bytes)} B`;\n        return `${(bytes / 1024).toFixed(bytes &lt; 10240 ? 1 : 0)} KiB`;\n      }\n\n      function formatByteRate(bytesPerSecond) {\n        if (bytesPerSecond &lt; 1024) return `${Math.round(bytesPerSecond)} B/s`;\n        return `${(bytesPerSecond / 1024).toFixed(1)} KiB/s`;\n      }\n\n      function auditDNAStateLabel(state) {\n        if (!state?.dna) return \"no DNA state\";\n        const pattern = PATTERNS[state.dna.pattern]?.name || `P${state.dna.pattern}`;\n        const palette = PALETTES[state.dna.palette]?.name || `C${state.dna.palette}`;\n        return `P${state.dna.pattern} ${pattern} / C${state.dna.palette} ${palette}`;\n      }\n\n      function auditPayloadLabel(message) {\n        const states = message?.data?.states;\n        if (!states) return \"\";\n        const pattern = PATTERNS[states.current.patternId]?.name || `P${states.current.patternId}`;\n        const palette = PALETTES[states.current.paletteId]?.name || `C${states.current.paletteId}`;\n        return ` · payload P${states.current.patternId} ${pattern} / C${states.current.paletteId} ${palette}`;\n      }\n\n      function auditEventLabel(event) {\n        const command = event.message?.commandName || \"LOCAL\";\n        const trace = event.traceId === null ? \"\" : ` · trace #${event.traceId}`;\n        if (event.kind === \"send\") {\n          const relay = event.rebroadcast ? ` relay for ${formatId(event.behalfOfId)}` : \"\";\n          return `TX ${command}:${event.message.recipientsName}${relay}${trace}${auditPayloadLabel(event.message)}`;\n        }\n        if (event.kind === \"radio-drop\") {\n          const signal = event.radio?.meanStrength === null\n            ? \"\"\n            : ` · signal ${(event.radio.meanStrength * 100).toFixed(1)}%`;\n          const delivery = event.radio?.deliveryProbability === null\n            ? \"\"\n            : ` · delivery ${(event.radio.deliveryProbability * 100).toFixed(1)}%`;\n          return `NO RX ${command} from ${formatId(event.peerId)} · ${event.reason}${signal}${delivery}${trace}${auditPayloadLabel(event.message)}`;\n        }\n        if (event.kind === \"local-transition\") {\n          return `LOCAL ${event.reason} · ${auditDNAStateLabel(event.before)} → ${auditDNAStateLabel(event.after)}`;\n        }\n        const applied = event.appliedState\n          ? ` · applied ${auditDNAStateLabel(event.before)} → ${auditDNAStateLabel(event.after)}`\n          : \"\";\n        const relay = event.relayed ? \" · relayed\" : \"\";\n        const physicalPath = event.physicalPeerId !== null\n          &amp;&amp; event.physicalPeerId !== event.peerId\n          ? ` via ${formatId(event.physicalPeerId)}`\n          : \"\";\n        return `RX ${command} from ${formatId(event.peerId)}${physicalPath} · ${event.outcome}: ${event.reason}${applied}${relay}${trace}${auditPayloadLabel(event.message)}`;\n      }\n\n      function drawQualityChart() {\n        const chart = ui.qualityChart;\n        const rect = chart.getBoundingClientRect();\n        const ratio = Math.min(window.devicePixelRatio || 1, 2);\n        const width = Math.max(1, Math.floor(rect.width));\n        const height = Math.max(1, Math.floor(rect.height));\n        if (chart.width !== Math.floor(width * ratio) || chart.height !== Math.floor(height * ratio)) {\n          chart.width = Math.floor(width * ratio);\n          chart.height = Math.floor(height * ratio);\n        }\n        const chartContext = chart.getContext(\"2d\");\n        chartContext.setTransform(ratio, 0, 0, ratio, 0, 0);\n        chartContext.clearRect(0, 0, width, height);\n        chartContext.fillStyle = \"rgba(4, 7, 12, 0.72)\";\n        chartContext.fillRect(0, 0, width, height);\n\n        const left = 25;\n        const right = 8;\n        const top = 8;\n        const bottom = 17;\n        const plotWidth = Math.max(1, width - left - right);\n        const plotHeight = Math.max(1, height - top - bottom);\n        chartContext.font = \"700 8px ui-monospace, monospace\";\n        chartContext.textAlign = \"right\";\n        for (const score of [0, 50, 100]) {\n          const y = top + plotHeight * (1 - score / 100);\n          chartContext.strokeStyle = \"rgba(151, 167, 200, 0.13)\";\n          chartContext.lineWidth = 1;\n          chartContext.beginPath();\n          chartContext.moveTo(left, y);\n          chartContext.lineTo(width - right, y);\n          chartContext.stroke();\n          chartContext.fillStyle = \"rgba(148, 160, 184, 0.72)\";\n          chartContext.fillText(String(score), left - 4, y + 3);\n        }\n\n        const history = evaluator.history;\n        if (history.length) {\n          const firstAt = history[0].at;\n          const lastAt = Math.max(firstAt + 1, history[history.length - 1].at);\n          const pointFor = sample =&gt; ({\n            x: left + ((sample.at - firstAt) / (lastAt - firstAt)) * plotWidth,\n            y: top + (1 - sample.score / 100) * plotHeight\n          });\n\n          chartContext.strokeStyle = \"#8ef0d0\";\n          chartContext.lineWidth = 1.8;\n          chartContext.beginPath();\n          history.forEach((sample, index) =&gt; {\n            const point = pointFor(sample);\n            if (index === 0) chartContext.moveTo(point.x, point.y);\n            else chartContext.lineTo(point.x, point.y);\n          });\n          chartContext.stroke();\n\n          chartContext.fillStyle = \"#ff7f91\";\n          for (const sample of history) {\n            if (!sample.outlierCount) continue;\n            const point = pointFor(sample);\n            chartContext.beginPath();\n            chartContext.arc(point.x, point.y, 2.5, 0, Math.PI * 2);\n            chartContext.fill();\n          }\n\n          chartContext.fillStyle = \"rgba(148, 160, 184, 0.72)\";\n          chartContext.textAlign = \"left\";\n          chartContext.fillText(`${((lastAt - firstAt) / 1000).toFixed(0)}s history`, left, height - 5);\n        }\n      }\n\n      function updateEvaluationUI() {\n        const evaluation = evaluator.current;\n        ui.factEvaluationCoverage.textContent = `${evaluation.positioned} / ${evaluation.total}`;\n        ui.factWorstError.textContent = evaluation.worstError === null ? \"—\" : `${evaluation.worstError.toFixed(1)} px`;\n        ui.factPeerEvictions.textContent = String(simulation.stats.peerEvictions);\n        ui.factPeerDrops.textContent = String(simulation.stats.peerAdmissionDrops);\n        ui.factWireBytes.textContent = `${simulation.positionPayloadBytes()} B / ${simulation.positionPacketBytes()} B`;\n        ui.factCoordinateRange.textContent = `±${simulation.coordinateMaximum().toLocaleString()} px · ${simulation.stats.coordinateSaturations} clipped`;\n        ui.factTableBytes.textContent = `${simulation.peerCapacity} × ${simulation.peerEntryBytes()} B = ${formatBytes(simulation.peerTableBytes())}`;\n        ui.evaluationNote.textContent = `Quality registers one shared frame to physical truth for scoring only, choosing rotation and optional reflection by best fit. A tube never receives that registration or any true position. An outlier is reported after remaining more than ${simulation.outlierErrorThreshold} px wrong for ${(simulation.outlierDuration / 1000).toFixed(0)} simulated seconds.`;\n\n        ui.outlierList.replaceChildren();\n        const currentOutliers = evaluation.persistentOutliers.slice().sort((a, b) =&gt; b.error - a.error);\n        const recentEvents = evaluator.outlierEvents\n          .filter(event =&gt; !currentOutliers.some(outlier =&gt; outlier.nodeId === event.nodeId))\n          .slice(0, Math.max(0, 5 - currentOutliers.length));\n        if (!currentOutliers.length &amp;&amp; !recentEvents.length) {\n          const item = document.createElement(\"li\");\n          item.className = \"empty-state\";\n          item.textContent = \"No persistent position outliers detected.\";\n          ui.outlierList.appendChild(item);\n        } else {\n          for (const outlier of currentOutliers.slice(0, 5)) {\n            const item = document.createElement(\"li\");\n            item.className = \"outlier-item\";\n            item.textContent = `${formatId(outlier.nodeId)} · ${outlier.error.toFixed(1)} px wrong for ${(outlier.duration / 1000).toFixed(1)}s · max ${outlier.maximumError.toFixed(1)} px`;\n            ui.outlierList.appendChild(item);\n          }\n          for (const event of recentEvents) {\n            const item = document.createElement(\"li\");\n            item.className = \"outlier-item\";\n            item.textContent = `${formatId(event.nodeId)} · previous persistent outlier · max ${event.maximumError.toFixed(1)} px`;\n            ui.outlierList.appendChild(item);\n          }\n        }\n        drawQualityChart();\n      }\n\n      function createLightingCatalog() {\n        return {\n          patterns: PATTERNS.map((pattern, id) =&gt; ({ id, name: pattern.name })),\n          palettes: PALETTES.map((palette, id) =&gt; ({ id, name: palette.name, colors: [...palette.colors] }))\n        };\n      }\n\n      function createDeviceAuditExport(node) {\n        return {\n          schema: \"tubes-message-audit/v1\",\n          scope: \"device\",\n          capturedAtSimulationMs: Math.round(simulation.time),\n          deviceKey: node.auditDeviceKey,\n          currentMeshId: formatId(node.id),\n          lightingCatalog: createLightingCatalog(),\n          currentState: simulation.auditNodeState(node),\n          summary: { ...simulation.auditStatsForNode(node) },\n          events: simulation.auditForNode(node)\n        };\n      }\n\n      function createRunAuditExport() {\n        return {\n          schema: \"tubes-message-audit/v1\",\n          scope: \"run\",\n          capturedAtSimulationMs: Math.round(simulation.time),\n          scenario: {\n            tubes: simulation.currentTubeCount,\n            anchors: simulation.currentAnchorCount\n          },\n          lightingCatalog: createLightingCatalog(),\n          simulation: createSnapshot().simulation,\n          evaluation: {\n            current: evaluator.current,\n            history: evaluator.history,\n            outlierEvents: evaluator.outlierEvents\n          },\n          eventCount: simulation.messageAudit.length,\n          events: simulation.messageAudit\n        };\n      }\n\n      function createSnapshot() {\n        const warnings = simulation.entities\n          .map(entity =&gt; simulation.localMaximumWarning(entity))\n          .filter(Boolean);\n        const leaders = simulation.entities.filter(entity =&gt; !entity.network.isFollowing()).length;\n        const tubeEntities = simulation.entities.filter(entity =&gt; !entity.network.isAnchor);\n        const anchorEntities = simulation.entities.filter(entity =&gt; entity.network.isAnchor);\n        const clusters = new Set(tubeEntities.map(entity =&gt; dnaKey(entity.network.dna))).size;\n        const displayFrameIds = new Set(\n          simulation.entities.map(entity =&gt; entity.network.positionEstimate.frameId)\n        );\n        const displayRegistration = [...displayFrameIds].map(frameId =&gt; {\n          const transform = estimateDisplayTransform(frameId);\n          return {\n            frameId: formatFrameId(frameId),\n            rotationDegrees: +(transform.rotation * 180 / Math.PI).toFixed(2),\n            reflected: transform.reflection &lt; 0,\n            source: transform.reflectionSource,\n            fitError: transform.registrationError === null ? null : +transform.registrationError.toFixed(2),\n            alternateFitError: transform.alternativeError === null ? null : +transform.alternativeError.toFixed(2),\n            sampleCount: transform.registrationSampleCount\n          };\n        });\n\n        return {\n          schema: \"tubes-mesh-simulator/v4\",\n          capturedAtSimulationMs: Math.round(simulation.time),\n          simulation: {\n            paused: simulation.paused,\n            speed: simulation.speed,\n            radioRange: simulation.range,\n            dropoff: simulation.dropoff,\n            deliveryModel: simulation.deliveryModel,\n            fixedRelay: simulation.fixedRelay,\n            radioUncertainty: {\n              rssiJitterSigmaDb: simulation.rssiJitterSigmaDb,\n              transmitPowerSigmaDb: simulation.txPowerSigmaDb,\n              linkShadowSigmaDb: simulation.linkShadowSigmaDb\n            },\n            scenario: {\n              tubes: simulation.currentTubeCount,\n              anchors: simulation.currentAnchorCount\n            },\n            positioningResources: {\n              peerCapacity: simulation.peerCapacity,\n              solveCapacity: simulation.solveCapacity,\n              anchorReserve: simulation.anchorReserve,\n              modeledPeerEntryBytes: simulation.peerEntryBytes(),\n              modeledPeerTableBytesPerDevice: simulation.peerTableBytes()\n            },\n            positioningWire: {\n              payloadProfile: simulation.payloadProfileKey,\n              coordinateEncoding: simulation.coordinateEncodingKey,\n              coordinateQuantum: simulation.coordinateQuantum,\n              envelope: simulation.wireEnvelope,\n              positionPayloadBytes: simulation.positionPayloadBytes(),\n              positionPacketBytes: simulation.positionPacketBytes(),\n              broadcastPeriodMs: simulation.positionBroadcastPeriod,\n              modeledTrafficBytesPerSecond: +simulation.positionTrafficBytesPerSecond().toFixed(1)\n            },\n            evaluationRules: {\n              persistentOutlierError: simulation.outlierErrorThreshold,\n              persistentOutlierDurationMs: simulation.outlierDuration,\n              qualityErrorScale: QUALITY_ERROR_SCALE,\n              historySamplePeriodMs: QUALITY_SAMPLE_PERIOD\n            },\n            displayRegistration,\n            leaderBpm: simulation.leaderBpm\n          },\n          summary: {\n            nodes: simulation.entities.length,\n            tubes: tubeEntities.length,\n            anchors: anchorEntities.length,\n            leaders,\n            followers: simulation.entities.length - leaders,\n            dnaSets: clusters,\n            relayTransmissions: simulation.stats.rebroadcasts,\n            deliveredPackets: simulation.stats.delivered,\n            droppedPackets: simulation.stats.dropped,\n            pendingDeliveries: simulation.deliveryQueue.length,\n            activeRadioWaves: simulation.waves.length,\n            topologyWarnings: warnings.length,\n            peerEvictions: simulation.stats.peerEvictions,\n            peerAdmissionDrops: simulation.stats.peerAdmissionDrops,\n            positionTransmissions: simulation.stats.positionTransmissions,\n            positionApplicationBytes: simulation.stats.positionApplicationBytes,\n            coordinateSaturations: simulation.stats.coordinateSaturations,\n            messageAuditEvents: simulation.messageAudit.length,\n            locationQuality: {\n              score: +evaluator.current.score.toFixed(2),\n              positioned: evaluator.current.positioned,\n              total: evaluator.current.total,\n              medianError: evaluator.current.medianError === null ? null : +evaluator.current.medianError.toFixed(2),\n              p95Error: evaluator.current.p95Error === null ? null : +evaluator.current.p95Error.toFixed(2),\n              worstError: evaluator.current.worstError === null ? null : +evaluator.current.worstError.toFixed(2),\n              persistentOutliers: evaluator.current.persistentOutliers.length\n            }\n          },\n          nodes: simulation.entities.map((entity, index) =&gt; {\n            const node = entity.network;\n            const inRange = simulation.entities\n              .filter(candidate =&gt; candidate !== entity &amp;&amp; simulation.distance(entity, candidate) &lt; simulation.range)\n              .map(candidate =&gt; formatId(candidate.network.id));\n            return {\n              index,\n              deviceLocal: {\n                id: formatId(node.id),\n                kind: node.isAnchor ? \"anchor\" : \"tube\",\n                hasLights: !node.isAnchor,\n                role: node.role(),\n                transportStatus: node.status,\n                uplinkId: simulation.fixedRelay\n                  ? null\n                  : node.uplinkId ? formatId(node.uplinkId) : null,\n                leaderId: formatId(simulation.fixedRelay ? (node.uplinkId || node.id) : node.leaderId),\n                leaderViaId: simulation.fixedRelay &amp;&amp; node.leaderViaId\n                  ? formatId(node.leaderViaId)\n                  : null,\n                leaderPath: simulation.fixedRelay\n                  ? !node.isFollowing()\n                    ? \"self\"\n                    : node.leaderViaId === 0\n                    ? \"waiting\"\n                    : node.leaderViaId === node.uplinkId ? \"direct\" : \"relayed\"\n                  : \"legacy-uplink\",\n                relayDuty: {\n                  active: node.isRelayActive(),\n                  remainingMs: Math.max(0, Math.round(node.rebroadcastUntil - simulation.time))\n                },\n                positionEstimate: {\n                  frameId: formatFrameId(node.positionEstimate.frameId),\n                  fixed: node.isAnchor,\n                  axisId: node.positionEstimate.axisId ? formatId(node.positionEstimate.axisId) : null,\n                  orientationId: node.positionEstimate.orientationId ? formatId(node.positionEstimate.orientationId) : null,\n                  solution: node.positionEstimate.solution,\n                  x: +node.positionEstimate.x.toFixed(2),\n                  y: +node.positionEstimate.y.toFixed(2),\n                  confidence: +node.positionEstimate.confidence.toFixed(3),\n                  settled: node.positionEstimate.settled,\n                  sequence: node.positionEstimate.sequence,\n                  updatedAtMs: Math.round(node.positionEstimate.updatedAt),\n                  observations: node.positionEstimate.observations,\n                  targetDistance: node.positionEstimate.targetDistance === null\n                    ? null\n                    : +node.positionEstimate.targetDistance.toFixed(2),\n                  constraintCount: node.positionEstimate.constraintCount,\n                  residualError: node.positionEstimate.residualError === null\n                    ? null\n                    : +node.positionEstimate.residualError.toFixed(3),\n                  radialConstraint: node.positionEstimate.radialConstraint\n                    ? {\n                        centerId: formatId(node.positionEstimate.radialConstraint.centerId),\n                        x: +node.positionEstimate.radialConstraint.x.toFixed(2),\n                        y: +node.positionEstimate.radialConstraint.y.toFixed(2),\n                        radius: +node.positionEstimate.radialConstraint.radius.toFixed(2)\n                      }\n                    : null,\n                  mirrorCandidates: node.positionEstimate.mirrorCandidates.map(candidate =&gt; ({\n                    x: +candidate.x.toFixed(2),\n                    y: +candidate.y.toFixed(2)\n                  })),\n                  mirrorDecision: {\n                    selectedIndex: node.mirrorDecision.selectedIndex,\n                    pendingIndex: node.mirrorDecision.pendingIndex,\n                    confirmations: node.mirrorDecision.confirmations,\n                    confirmationsRequired: MIRROR_CONFIRMATIONS_REQUIRED,\n                    discriminatingPeers: node.mirrorDecision.discriminatingPeers,\n                    scores: node.mirrorDecision.scores.map(score =&gt; (\n                      score === null ? null : +score.toFixed(2)\n                    ))\n                  }\n                },\n                knownPeers: [...node.knownPeers.values()].map(peer =&gt; ({\n                  id: formatId(peer.id),\n                  kind: peer.isAnchor ? \"anchor\" : \"tube\",\n                  frameId: formatFrameId(peer.frameId),\n                  axisId: peer.axisId ? formatId(peer.axisId) : null,\n                  orientationId: peer.orientationId ? formatId(peer.orientationId) : null,\n                  solution: peer.solution,\n                  estimate: { x: +peer.x.toFixed(2), y: +peer.y.toFixed(2) },\n                  confidence: +peer.confidence.toFixed(3),\n                  settled: peer.settled,\n                  advertisedConstraintCount: peer.advertisedConstraintCount,\n                  advertisedResidual: peer.advertisedResidual,\n                  txCalibrationDb: peer.txCalibrationDb,\n                  rawDistance: +peer.rawDistance.toFixed(2),\n                  directDistance: +peer.directDistance.toFixed(2),\n                  rangeSigma: +peer.rangeSigma.toFixed(2),\n                  rangeSamples: peer.rangeSamples,\n                  outlierLimited: peer.outlierLimited,\n                  strength: +peer.strength.toFixed(3),\n                  lastHeardAtMs: Math.round(peer.lastHeardAt)\n                })),\n                current: cloneTubeState(node.current),\n                next: cloneTubeState(node.next),\n                currentPhrase: node.currentPhrase(),\n                  counters: {\n                  received: node.receivedCount,\n                  executed: node.executedCount,\n                  ignored: node.ignoredCount\n                },\n                peerTable: {\n                  used: node.knownPeers.size,\n                  capacity: simulation.peerCapacity,\n                  modeledBytes: simulation.peerTableBytes()\n                },\n                messageAudit: { ...simulation.auditStatsForNode(node) }\n              },\n              simulatorOnly: {\n                position: { x: Math.round(entity.x), y: Math.round(entity.y) },\n                radioPowerStandardScore: +entity.radioPowerStandardScore.toFixed(3),\n                activeTransmitPowerBiasDb: +(entity.radioPowerStandardScore * simulation.txPowerSigmaDb).toFixed(2),\n                idsInsideHardRange: inRange,\n                warning: simulation.localMaximumWarning(entity)\n              }\n            };\n          }),\n          topology: simulation.entities\n            .filter(entity =&gt; entity.network.uplinkId)\n            .map(entity =&gt; ({\n              from: formatId(entity.network.id),\n              relationship: simulation.fixedRelay ? \"logical-leader\" : \"uplink\",\n              target: formatId(entity.network.uplinkId),\n              uplink: simulation.fixedRelay ? null : formatId(entity.network.uplinkId),\n              leader: simulation.fixedRelay ? formatId(entity.network.uplinkId) : null\n            })),\n          warnings,\n          activeRadioWaves: simulation.waves.map(wave =&gt; {\n            const progress = clamp((simulation.time - wave.start) / RADIO_WAVE_TIME, 0, 1);\n            return {\n              senderId: formatId(wave.sender.network.id),\n              traceId: wave.traceId,\n              rebroadcast: wave.rebroadcast,\n              hop: wave.hop,\n              radius: Math.round(progress * wave.range),\n              maximumRange: wave.range,\n              progress: +progress.toFixed(3),\n              strengthAtWavefront: +simulation.signalForNormalizedDistance(progress, wave.dropoff).toFixed(3),\n              dropoff: wave.dropoff\n            };\n          }),\n          pendingDeliveries: simulation.deliveryQueue.map(delivery =&gt; ({\n            dueAtMs: Math.round(delivery.at),\n            targetId: formatId(delivery.target.id),\n            logicalHeaderId: formatId(delivery.message.header.id),\n            physicalTransmitterId: formatId(delivery.auditMeta.senderMeshId),\n            senderUplinkId: delivery.message.header.uplinkId ? formatId(delivery.message.header.uplinkId) : null,\n            recipients: simulation.recipientName(delivery.message.recipients),\n            command: delivery.message.command,\n            position: delivery.message.position ? {\n              kind: delivery.message.position.isAnchor ? \"anchor\" : \"tube\",\n              frameId: formatFrameId(delivery.message.position.frameId),\n              axisId: delivery.message.position.axisId ? formatId(delivery.message.position.axisId) : null,\n              orientationId: delivery.message.position.orientationId\n                ? formatId(delivery.message.position.orientationId)\n                : null,\n              solution: delivery.message.position.solution,\n              x: +delivery.message.position.x.toFixed(2),\n              y: +delivery.message.position.y.toFixed(2),\n              confidence: +delivery.message.position.confidence.toFixed(3),\n              settled: delivery.message.position.settled,\n              sequence: delivery.message.position.sequence,\n              leaderViaId: delivery.message.position.leaderViaId\n                ? formatId(delivery.message.position.leaderViaId)\n                : null\n            } : null,\n            strength: +delivery.strength.toFixed(3),\n            traceId: delivery.traceId,\n            hop: delivery.hop\n          })),\n          recentEvents: simulation.logs.slice(0, 50).map(log =&gt; ({\n            atMs: Math.round(log.at),\n            nodeId: formatId(log.node.id),\n            type: log.type,\n            message: log.message\n          })),\n          evaluationHistory: evaluator.history.map(sample =&gt; ({\n            atMs: Math.round(sample.at),\n            score: +sample.score.toFixed(2),\n            medianError: sample.medianError === null ? null : +sample.medianError.toFixed(2),\n            p95Error: sample.p95Error === null ? null : +sample.p95Error.toFixed(2),\n            outlierCount: sample.outlierCount\n          })),\n          outlierEvents: evaluator.outlierEvents.map(event =&gt; ({\n            nodeId: formatId(event.nodeId),\n            detectedAtMs: Math.round(event.detectedAt),\n            maximumError: +event.maximumError.toFixed(2)\n          }))\n        };\n      }\n\n      function createCompactSnapshot(snapshot = createSnapshot()) {\n        return {\n          v: 9,\n          t: snapshot.capturedAtSimulationMs,\n          p: snapshot.simulation.paused ? 1 : 0,\n          m: snapshot.simulation.fixedRelay ? 1 : 0,\n          r: [snapshot.simulation.radioRange, snapshot.simulation.dropoff, snapshot.simulation.deliveryModel],\n          u: [\n            snapshot.simulation.radioUncertainty.rssiJitterSigmaDb,\n            snapshot.simulation.radioUncertainty.transmitPowerSigmaDb,\n            snapshot.simulation.radioUncertainty.linkShadowSigmaDb\n          ],\n          e: [\n            snapshot.simulation.positioningResources.peerCapacity,\n            snapshot.simulation.positioningResources.solveCapacity,\n            snapshot.simulation.positioningResources.anchorReserve,\n            snapshot.simulation.positioningWire.payloadProfile,\n            snapshot.simulation.positioningWire.coordinateEncoding,\n            snapshot.simulation.positioningWire.coordinateQuantum,\n            snapshot.simulation.positioningWire.envelope,\n            snapshot.simulation.positioningWire.broadcastPeriodMs\n          ],\n          s: [\n            snapshot.summary.nodes,\n            snapshot.summary.tubes,\n            snapshot.summary.anchors,\n            snapshot.summary.leaders,\n            snapshot.summary.relayTransmissions,\n            snapshot.summary.topologyWarnings\n          ],\n          n: snapshot.nodes.map(node =&gt; [\n            node.deviceLocal.id,\n            node.deviceLocal.kind === \"anchor\" ? \"A\" : \"T\",\n            node.deviceLocal.leaderId || node.deviceLocal.uplinkId || \"-\",\n            node.deviceLocal.leaderViaId || \"-\",\n            node.deviceLocal.role === \"Leading\" ? \"L\" : \"F\",\n            node.deviceLocal.relayDuty.active ? 1 : 0,\n            node.deviceLocal.current.patternId,\n            node.deviceLocal.current.paletteId,\n            node.deviceLocal.currentPhrase,\n            node.deviceLocal.next.patternId,\n            node.deviceLocal.next.patternPhrase,\n            node.deviceLocal.next.paletteId,\n            node.deviceLocal.next.palettePhrase,\n            node.simulatorOnly.position.x,\n            node.simulatorOnly.position.y,\n            node.deviceLocal.positionEstimate.frameId,\n            node.deviceLocal.positionEstimate.x,\n            node.deviceLocal.positionEstimate.y,\n            node.deviceLocal.positionEstimate.confidence,\n            node.deviceLocal.positionEstimate.axisId || \"-\",\n            node.deviceLocal.positionEstimate.orientationId || \"-\",\n            node.deviceLocal.positionEstimate.solution\n          ]),\n          w: snapshot.warnings.map(warning =&gt; [\n            formatId(warning.nodeId),\n            formatId(warning.relayId),\n            formatId(warning.advertisedUplinkId)\n          ])\n        };\n      }\n\n      function encodeCompactSnapshot(snapshot) {\n        return btoa(JSON.stringify(createCompactSnapshot(snapshot)))\n          .replace(/\\+/g, \"-\")\n          .replace(/\\//g, \"_\")\n          .replace(/=+$/, \"\");\n      }\n\n      function updateDiagnostics(wallTime = performance.now(), force = false) {\n        if (!force &amp;&amp; wallTime - diagnosticsLastUpdated &lt; 500) return;\n        diagnosticsLastUpdated = wallTime;\n        const snapshot = createSnapshot();\n        const selectedNode = selected\n          ? snapshot.nodes.find(node =&gt; node.deviceLocal.id === formatId(selected.network.id))\n          : null;\n        ui.debugSnapshot.textContent = JSON.stringify({\n          schema: snapshot.schema,\n          capturedAtSimulationMs: snapshot.capturedAtSimulationMs,\n          summary: snapshot.summary,\n          selectedNode,\n          warnings: snapshot.warnings,\n          recentEvents: snapshot.recentEvents.slice(0, 8)\n        }, null, 2);\n\n        if (ui.mirrorSnapshot.checked) {\n          history.replaceState(null, \"\", `${location.href.split(\"#\")[0]}#tubes=${encodeCompactSnapshot(snapshot)}`);\n        }\n      }\n\n      function updateInspector(force = false) {\n        if (!selected) return;\n        if (!force &amp;&amp; simulation.time - inspectorLastUpdated &lt; 180) return;\n        inspectorLastUpdated = simulation.time;\n        const node = selected.network;\n        const palette = PALETTES[node.dna.palette];\n        const pattern = PATTERNS[node.dna.pattern];\n\n        ui.selectedId.textContent = formatId(node.id);\n        ui.selectedKind.textContent = node.isAnchor ? \"Selected fixed anchor\" : \"Selected tube\";\n        const leaderSuffix = node.isFollowing() ? ` ${formatId(node.uplinkId)}` : \"\";\n        ui.selectedRole.textContent = node.isAnchor\n          ? `Anchor · ${node.role()}${leaderSuffix}`\n          : `${node.role()}${leaderSuffix}`;\n        ui.dnaCard.hidden = node.isAnchor;\n        ui.lightingScheduleSection.hidden = node.isAnchor;\n        ui.dnaStrip.style.setProperty(\"--dna-gradient\", `linear-gradient(90deg, ${palette.colors.join(\", \")})`);\n        ui.dnaCode.textContent = `P${node.dna.pattern} · C${node.dna.palette}`;\n        ui.dnaName.textContent = `${pattern.name} · ${palette.name}`;\n        const topologyWarning = simulation.localMaximumWarning(selected);\n        ui.topologyWarning.hidden = !topologyWarning;\n        ui.topologyWarning.textContent = topologyWarning ? `Local maximum: ${topologyWarning.explanation}` : \"\";\n        ui.factId.textContent = formatId(node.id);\n        ui.leaderFactLabel.textContent = simulation.fixedRelay ? \"Chosen leader\" : \"Chosen uplink\";\n        ui.factUplink.textContent = node.uplinkId\n          ? formatId(node.uplinkId)\n          : \"none\";\n        ui.factLeaderPath.textContent = leaderPathLabel(node);\n        ui.factState.textContent = node.status === STATUS.RECEIVING\n          ? \"receiving / silent\"\n          : node.isAnchor ? `anchor / ${node.role().toLowerCase()}` : node.role().toLowerCase();\n        const relaySeconds = Math.max(0, (node.rebroadcastUntil - simulation.time) / 1000);\n        const relayFor = node.uplinkId ? `for ${formatId(node.uplinkId)}` : \"downstream\";\n        ui.factRelay.textContent = node.isRelayActive() ? `active ${relayFor} · ${relaySeconds.toFixed(1)}s` : \"inactive\";\n        ui.relayExplanation.textContent = simulation.fixedRelay\n          ? \"Leader via records the physical source of the latest valid leader state. A node renews relay duty while nearby advertisements say their state arrived through it, or that they are still waiting for a relay.\"\n          : \"With relay duty active, current-code mode rebroadcasts an accepted packet after replacing its header with the relay&#39;s own ID and uplink ID.\";\n        ui.factLastHeard.textContent = node.lastUplinkSeenAt === null\n          ? \"never\"\n          : `${Math.max(0, (simulation.time - node.lastUplinkSeenAt) / 1000).toFixed(1)} s ago`;\n        ui.factEstimate.textContent = `${node.positionEstimate.x.toFixed(1)}, ${node.positionEstimate.y.toFixed(1)} · ${Math.round(node.positionEstimate.confidence * 100)}%`;\n        ui.factEstimateFrame.textContent = node.positionEstimate.frameId === ANCHORED_FRAME_ID\n          ? \"ANCHORED (fixed canvas)\"\n          : node.positionEstimate.frameId === node.id\n          ? `${formatId(node.positionEstimate.frameId)} (self)`\n          : formatId(node.positionEstimate.frameId);\n        const positioningScope = node.isAnchor\n          ? \"fixed known position\"\n          : simulation.entities.length === 1\n          ? \"waiting\"\n          : simulation.entities.length &lt;= 3 ? `${simulation.entities.length}-device` : \"distributed adjustment\";\n        const pendingAnchoredEvidence = !node.isAnchor\n          &amp;&amp; node.positionEstimate.frameId !== ANCHORED_FRAME_ID\n          ? node.anchoredFrameEvidence()\n          : null;\n        const pendingAnchorLabel = pendingAnchoredEvidence?.peers.length\n          ? ` · ${pendingAnchoredEvidence.peers.length} anchored range${pendingAnchoredEvidence.peers.length === 1 ? \"\" : \"s\"} pending`\n          : \"\";\n        const axisLabel = node.positionEstimate.axisId ? ` · axis ${formatId(node.positionEstimate.axisId)}` : \"\";\n        const orientationLabel = node.positionEstimate.orientationId\n          ? ` · +Y ${formatId(node.positionEstimate.orientationId)}`\n          : \"\";\n        const constraintLabel = node.positionEstimate.constraintCount\n          ? ` · ${node.positionEstimate.constraintCount} range${node.positionEstimate.constraintCount === 1 ? \"\" : \"s\"}`\n          : \"\";\n        const residualLabel = node.positionEstimate.residualError === null\n          ? \"\"\n          : ` · residual ${node.positionEstimate.residualError.toFixed(2)}`;\n        const mirrorDecision = node.mirrorDecision;\n        const mirrorLabel = node.positionEstimate.mirrorCandidates.length\n          ? mirrorDecision.selectedIndex === null\n            ? ` · mirror evidence ${mirrorDecision.confirmations}/${MIRROR_CONFIRMATIONS_REQUIRED}`\n            : ` · branch ${mirrorDecision.selectedIndex === 0 ? \"+Y\" : \"−Y\"}`\n          : \"\";\n        ui.factPositionMode.textContent = `${positioningScope} · ${node.positionEstimate.solution}${axisLabel}${orientationLabel}${constraintLabel}${residualLabel}${mirrorLabel}${pendingAnchorLabel}`;\n        ui.factPeerTable.textContent = `${node.knownPeers.size} / ${simulation.peerCapacity} · solve ${Math.min(node.knownPeers.size, simulation.solveCapacity)}`;\n        const beat = node.current.beatFrame / BEAT_UNITS;\n        const phrase = node.currentPhrase();\n        ui.factClock.textContent = node.isAnchor ? \"n/a · no lights\" : `${beat.toFixed(2)} / ${phrase}`;\n        const patternWait = Math.max(0, node.next.patternPhrase - phrase);\n        const paletteWait = Math.max(0, node.next.palettePhrase - phrase);\n        const secondsUntilPhrase = targetPhrase =&gt; Math.max(\n          0,\n          ((targetPhrase * PHRASE_BEATS) - beat) * 60 / node.current.bpm\n        );\n        ui.factNextPattern.textContent = `P${node.next.patternId} ${PATTERNS[node.next.patternId].name} · phrase ${node.next.patternPhrase} · ${patternWait}P / ${secondsUntilPhrase(node.next.patternPhrase).toFixed(1)}s`;\n        ui.factNextPalette.textContent = `C${node.next.paletteId} ${PALETTES[node.next.paletteId].name} · phrase ${node.next.palettePhrase} · ${paletteWait}P / ${secondsUntilPhrase(node.next.palettePhrase).toFixed(1)}s`;\n        ui.factBpm.textContent = `${Math.round(node.current.bpm)} BPM`;\n        const patternRatio = scheduleRemainingRatio(node.current.patternPhrase, node.next.patternPhrase, node.current.beatFrame);\n        const paletteRatio = scheduleRemainingRatio(node.current.palettePhrase, node.next.palettePhrase, node.current.beatFrame);\n        const patternPercent = Math.round(patternRatio * 100);\n        const palettePercent = Math.round(paletteRatio * 100);\n        ui.patternProgressLabel.textContent = `Pattern → P${node.next.patternId} ${PATTERNS[node.next.patternId].name}`;\n        ui.patternProgressValue.value = `${patternPercent}% · ${secondsUntilPhrase(node.next.patternPhrase).toFixed(1)}s`;\n        ui.patternProgressTrack.setAttribute(\"aria-valuenow\", String(patternPercent));\n        ui.patternProgressFill.style.width = `${patternPercent}%`;\n        ui.paletteProgressLabel.textContent = `Palette → C${node.next.paletteId} ${PALETTES[node.next.paletteId].name}`;\n        ui.paletteProgressValue.value = `${palettePercent}% · ${secondsUntilPhrase(node.next.palettePhrase).toFixed(1)}s`;\n        ui.paletteProgressTrack.setAttribute(\"aria-valuenow\", String(palettePercent));\n        ui.paletteProgressFill.style.width = `${palettePercent}%`;\n        ui.paletteProgressFill.style.setProperty(\"--progress-color\", `linear-gradient(90deg, ${PALETTES[node.next.paletteId].colors.join(\", \")})`);\n        ui.factPosition.textContent = `${Math.round(selected.x)}, ${Math.round(selected.y)}`;\n\n        const signals = simulation.entities\n          .filter(entity =&gt; entity !== selected)\n          .map(entity =&gt; simulation.meanSignalBetween(entity, selected, simulation.distance(selected, entity)))\n          .filter(strength =&gt; strength &gt; 0);\n        ui.factNeighbors.textContent = String(signals.length);\n        ui.factSignal.textContent = signals.length ? `${Math.round(Math.max(...signals) * 100)}%` : \"none\";\n\n        const knownPeers = [...node.knownPeers.values()].sort((a, b) =&gt; b.id - a.id);\n        ui.positionKnowledgeList.replaceChildren();\n        if (!knownPeers.length) {\n          const item = document.createElement(\"li\");\n          item.className = \"empty-state\";\n          item.textContent = \"No positioning broadcasts received yet.\";\n          ui.positionKnowledgeList.appendChild(item);\n        } else {\n          for (const peer of knownPeers) {\n            const item = document.createElement(\"li\");\n            item.className = \"traffic-item\";\n            const peerId = document.createElement(\"span\");\n            peerId.className = \"traffic-time\";\n            peerId.textContent = formatId(peer.id);\n            const claim = document.createElement(\"span\");\n            const ageSeconds = Math.max(0, (simulation.time - peer.lastHeardAt) / 1000);\n            const outlierLabel = peer.outlierLimited ? \" · spike limited\" : \"\";\n            const peerKind = peer.isAnchor ? \"ANCHOR · \" : \"\";\n            claim.textContent = `${peerKind}F${formatFrameId(peer.frameId)} · ${peer.solution} (${peer.x.toFixed(1)}, ${peer.y.toFixed(1)}) · range ${peer.rawDistance.toFixed(1)}→${peer.directDistance.toFixed(1)} σ${peer.rangeSigma.toFixed(1)} n${peer.rangeSamples}${outlierLabel} · ${ageSeconds.toFixed(1)}s ago`;\n            item.append(peerId, claim);\n            ui.positionKnowledgeList.appendChild(item);\n          }\n        }\n\n        const relevant = simulation.logs.filter(log =&gt; log.node === node).slice(0, 7);\n        ui.trafficList.replaceChildren();\n        if (!relevant.length) {\n          const item = document.createElement(\"li\");\n          item.className = \"empty-state\";\n          item.textContent = \"No local protocol events yet.\";\n          ui.trafficList.appendChild(item);\n        } else {\n          for (const entry of relevant) {\n            const item = document.createElement(\"li\");\n            item.className = \"traffic-item\";\n            const time = document.createElement(\"span\");\n            time.className = \"traffic-time\";\n            time.textContent = `${(entry.at / 1000).toFixed(1)}s`;\n            const message = document.createElement(\"span\");\n            message.textContent = entry.message;\n            item.append(time, message);\n            ui.trafficList.appendChild(item);\n          }\n        }\n\n        const auditStats = simulation.auditStatsForNode(node);\n        ui.factAuditEvents.textContent = String(auditStats.total);\n        ui.factAuditTraffic.textContent = `${auditStats.sent} / ${auditStats.received}`;\n        ui.factAuditDecisions.textContent = `${auditStats.accepted} / ${auditStats.ignored}`;\n        ui.factAuditDrops.textContent = String(auditStats.radioMisses);\n        ui.factAuditApplied.textContent = String(auditStats.appliedStates);\n        ui.factAuditRelays.textContent = `${auditStats.relayed} / ${auditStats.localTransitions}`;\n        ui.messageAuditList.replaceChildren();\n        const recentAudit = simulation.recentAuditForNode(node, 12);\n        if (!recentAudit.length) {\n          const item = document.createElement(\"li\");\n          item.className = \"empty-state\";\n          item.textContent = \"No message audit events yet.\";\n          ui.messageAuditList.appendChild(item);\n        } else {\n          for (const event of recentAudit) {\n            const item = document.createElement(\"li\");\n            item.className = \"traffic-item\";\n            const time = document.createElement(\"span\");\n            time.className = \"traffic-time\";\n            time.textContent = `${(event.atMs / 1000).toFixed(1)}s`;\n            const message = document.createElement(\"span\");\n            message.textContent = auditEventLabel(event);\n            item.append(time, message);\n            ui.messageAuditList.appendChild(item);\n          }\n        }\n\n      }\n\n      function frame(now) {\n        const delta = now - lastFrame;\n        lastFrame = now;\n        simulation.update(delta);\n        if (evaluator.update()) updateEvaluationUI();\n        draw();\n        updateInspector();\n        updateDiagnostics(now);\n        requestAnimationFrame(frame);\n      }\n\n      const resizeObserver = new ResizeObserver(resizeCanvas);\n      resizeObserver.observe(space);\n      resizeCanvas();\n      evaluator = new EvaluationTracker(simulation);\n      selected = simulation.loadScenario(\n        Number(ui.scenarioDeviceCount.value),\n        Number(ui.scenarioAnchorCount.value)\n      );\n      applyPeerCapacity();\n      resetEvaluation();\n      updateInspector(true);\n      updateDiagnostics(performance.now(), true);\n      requestAnimationFrame(frame);\n\n      window.TubesMeshSimulator = {\n        simulation,\n        constants: {\n          PROTOCOL_VERSION,\n          POSITION_PROTOCOL_VERSION,\n          ANCHORED_FRAME_ID,\n          POSITION_SOLUTION,\n          POSITION_PAYLOAD_PROFILES,\n          COORDINATE_ENCODINGS,\n          DEVICE_COUNT_PRESETS,\n          ANCHOR_COUNT_PRESETS,\n          RECIPIENTS,\n          COMMAND\n        },\n        evaluator,\n        addDevice: (x, y) =&gt; addDeviceAt(x, y),\n        addAnchor: (x, y) =&gt; addAnchorAt(x, y),\n        clearField: () =&gt; {\n          clearCurrentField();\n          return createSnapshot();\n        },\n        loadScenario: (tubeCount, anchorCount = 0) =&gt; {\n          if (!DEVICE_COUNT_PRESETS.includes(tubeCount)) throw new Error(`Unsupported tube count: ${tubeCount}`);\n          if (!ANCHOR_COUNT_PRESETS.includes(anchorCount)) throw new Error(`Unsupported anchor count: ${anchorCount}`);\n          ui.scenarioDeviceCount.value = String(tubeCount);\n          ui.scenarioAnchorCount.value = String(anchorCount);\n          runSelectedScenario();\n          return createSnapshot();\n        },\n        getSnapshot: createSnapshot,\n        getMessageAudit: filters =&gt; simulation.queryMessageAudit(filters),\n        getRunAudit: createRunAuditExport,\n        getSelectedDeviceAudit: () =&gt; selected ? createDeviceAuditExport(selected.network) : null,\n        getCompactSnapshot: () =&gt; createCompactSnapshot(createSnapshot())\n      };\n    })();\n  &lt;/script&gt;\n&lt;/body&gt;\n&lt;/html&gt;\n'></iframe>")
